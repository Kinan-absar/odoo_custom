<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <!-- ── Discount Dialog ──────────────────────────────────────────────── -->
    <t t-name="bi_pos_discount.DiscountDialog">
        <Dialog title="component.title">
            <div class="bi-discount-dialog">
                <div class="mb-3">
                    <label class="form-label fw-semibold" for="biDiscountInput">
                        <t t-if="component.props.discountType === 'fixed'">
                            Enter fixed discount amount:
                        </t>
                        <t t-else="">
                            Enter discount percentage (0–100):
                        </t>
                    </label>
                    <div class="input-group">
                        <input
                            id="biDiscountInput"
                            type="number"
                            class="form-control form-control-lg"
                            t-att-placeholder="component.placeholder"
                            t-att-value="component.state.value"
                            t-on-input="component.onInput"
                            min="0"
                            t-att-max="component.props.discountType === 'percentage' ? 100 : undefined"
                            step="0.01"
                            autofocus="true"
                        />
                        <t t-if="component.suffix">
                            <span class="input-group-text"><t t-esc="component.suffix"/></span>
                        </t>
                    </div>
                </div>
            </div>

            <t t-set-slot="footer">
                <button class="btn btn-primary btn-lg me-2" t-on-click="component.confirm">
                    Apply Discount
                </button>
                <button class="btn btn-secondary btn-lg" t-on-click="component.cancel">
                    Cancel
                </button>
            </t>
        </Dialog>
    </t>

    <!-- ── ProductScreen: inject Discount Button ────────────────────────── -->
    <t t-name="bi_pos_discount.ProductScreenInherit"
       t-inherit="point_of_sale.ProductScreen"
       t-inherit-mode="extension">
        <!-- Add discount button near the action buttons -->
        <xpath expr="//div[hasclass('control-buttons')]" position="inside">
            <t t-if="component.showBiDiscountButton">
                <div class="bi-discount-section">
                    <button
                        class="btn btn-warning bi-discount-btn"
                        t-on-click="component.openBiDiscountDialog"
                        title="Apply Order Discount">
                        <i class="fa fa-tag me-1"/>
                        Discount
                        <t t-if="component.currentBiDiscount">
                            <span class="bi-discount-badge ms-1">
                                <t t-esc="component.currentBiDiscount"/>
                            </span>
                        </t>
                    </button>
                    <t t-if="component.currentBiDiscount">
                        <button
                            class="btn btn-sm btn-outline-danger ms-1 bi-remove-discount-btn"
                            t-on-click="component.removeBiDiscount"
                            title="Remove Discount">
                            <i class="fa fa-times"/>
                        </button>
                    </t>
                </div>
            </t>
        </xpath>
    </t>

    <!-- ── Receipt: show discount line ──────────────────────────────────── -->
    <t t-name="bi_pos_discount.OrderReceiptInherit"
       t-inherit="point_of_sale.OrderReceipt"
       t-inherit-mode="extension">
        <xpath expr="//div[hasclass('pos-receipt-amount')]" position="after">
            <t t-if="props.data.biDiscountType and props.data.biDiscountAmount">
                <div class="bi-receipt-discount">
                    <div class="bi-receipt-discount-label">
                        Discount
                        <t t-if="props.data.biDiscountType === 'percentage'">
                            (<t t-esc="props.data.biDiscountValue"/>%)
                        </t>
                    </div>
                    <div class="bi-receipt-discount-amount">
                        -<t t-esc="env.utils.formatCurrency(props.data.biDiscountAmount)"/>
                    </div>
                </div>
            </t>
        </xpath>
    </t>

</templates>

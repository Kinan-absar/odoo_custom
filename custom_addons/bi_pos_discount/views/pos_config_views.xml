<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── POS Config: add BI Discount section ───────────────────────────── -->
    <record id="view_pos_config_form_bi_discount" model="ir.ui.view">
        <field name="name">pos.config.form.bi.discount</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <!-- Insert after the existing Pricing section -->
            <xpath expr="//div[@name='pricing']" position="after">
                <group string="Custom Discount (BI)" name="bi_discount_group">
                    <field name="bi_show_discount_button"/>
                    <field name="bi_discount_type"
                           attrs="{'invisible': [('bi_show_discount_button', '=', False)]}"/>
                    <field name="bi_discount_value"
                           attrs="{'invisible': [('bi_show_discount_button', '=', False)]}"
                           widget="percentage"
                           string="Default Discount %"
                           options="{'placeholder': '0'}"
                    />
                </group>
            </xpath>
        </field>
    </record>

    <!-- ── POS Order: show discount columns in list view ─────────────────── -->
    <record id="view_pos_order_list_bi_discount" model="ir.ui.view">
        <field name="name">pos.order.list.bi.discount</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_total']" position="before">
                <field name="bi_discount_type" string="Disc. Type" optional="show"/>
                <field name="bi_discount_value" string="Disc. Value" optional="show"/>
                <field name="bi_discount_amount" string="Disc. Amount" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- ── POS Order: show discount in form view ─────────────────────────── -->
    <record id="view_pos_order_form_bi_discount" model="ir.ui.view">
        <field name="name">pos.order.form.bi.discount</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_total']" position="after">
                <field name="bi_discount_type" readonly="1"/>
                <field name="bi_discount_value" readonly="1"/>
                <field name="bi_discount_amount" readonly="1"/>
            </xpath>
        </field>
    </record>

</odoo>

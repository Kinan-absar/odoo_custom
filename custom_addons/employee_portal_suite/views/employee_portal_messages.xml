<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <template id="employee_portal_messages" name="Employee Portal Messages">
        <t t-call="employee_portal_suite.employee_portal_layout">
            <div class="eps-chat-page">
                <div class="eps-chat-hero">
                    <div>
                        <div class="eps-chat-eyebrow">Employee Portal Suite</div>
                        <h2>Messages</h2>
                        <p>Private employee-to-employee conversations for portal and internal users.</p>
                    </div>
                    <div class="eps-chat-hero-actions">
                        <t t-if="unread_total">
                            <span class="eps-chat-unread-total"><t t-esc="unread_total"/> unread</span>
                        </t>
                        <a href="/my/employee" class="btn btn-light eps-chat-hero-btn">
                            <i class="fa fa-home me-1"></i> Portal Home
                        </a>
                    </div>
                </div>

                <div class="eps-chat-app">
                    <aside class="eps-chat-sidebar">
                        <div class="eps-chat-compose-card">
                            <div class="eps-chat-section-title">
                                <span><i class="fa fa-edit"></i> New conversation</span>
                            </div>
                            <form action="/my/employee/messages/start" method="post" class="eps-chat-new-form">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <select name="partner_id" class="form-select eps-chat-control" required="required">
                                    <option value="">Choose employee...</option>
                                    <t t-foreach="employees" t-as="emp">
                                        <option t-att-value="emp.user_id.partner_id.id">
                                            <t t-esc="emp.name"/>
                                            <t t-if="emp.job_title"> — <t t-esc="emp.job_title"/></t>
                                        </option>
                                    </t>
                                </select>
                                <textarea name="body" class="form-control eps-chat-control" rows="3" placeholder="Optional first message..."></textarea>
                                <button class="btn btn-primary eps-chat-primary-btn" type="submit">
                                    <i class="fa fa-paper-plane"></i> Start chat
                                </button>
                            </form>
                        </div>

                        <div class="eps-chat-inbox-head">
                            <div class="eps-chat-section-title mb-0">
                                <span><i class="fa fa-inbox"></i> Inbox</span>
                            </div>
                            <span class="eps-chat-count"><t t-esc="len(conversations)"/> chats</span>
                        </div>

                        <div class="eps-chat-thread-list">
                            <t t-if="not conversations">
                                <div class="eps-chat-empty-small">
                                    <i class="fa fa-comments-o"></i>
                                    <span>No conversations yet</span>
                                </div>
                            </t>
                            <t t-foreach="conversations" t-as="conv">
                                <t t-set="is_active" t-value="active_channel and conv['channel'].id == active_channel.id"/>
                                <a t-att-href="'/my/employee/messages/%s' % conv['channel'].id" t-att-class="'eps-chat-thread active' if is_active else 'eps-chat-thread'">
                                    <div class="eps-chat-avatar"><t t-esc="(conv['title'] or 'E')[:1].upper()"/></div>
                                    <div class="eps-chat-thread-info">
                                        <div class="eps-chat-thread-top">
                                            <strong><t t-esc="conv['title']"/></strong>
                                            <small t-if="conv['last_message']"><t t-esc="conv['last_message'].date.strftime('%H:%M') if conv['last_message'].date else ''"/></small>
                                        </div>
                                        <div class="eps-chat-preview" t-if="conv['last_message']" t-raw="conv['last_message'].body"/>
                                        <div class="eps-chat-preview" t-if="not conv['last_message']">No messages yet.</div>
                                    </div>
                                    <span t-if="conv['unread_count']" class="eps-chat-badge"><t t-esc="conv['unread_count']"/></span>
                                </a>
                            </t>
                        </div>
                    </aside>

                    <main class="eps-chat-main">
                        <t t-if="not active_channel">
                            <div class="eps-chat-welcome">
                                <div class="eps-chat-welcome-icon"><i class="fa fa-comments"></i></div>
                                <h3>Choose a conversation</h3>
                                <p>Select a chat from the inbox or start a new conversation with any active employee account.</p>
                            </div>
                        </t>
                        <t t-if="active_channel">
                            <div class="eps-chat-header-bar">
                                <a href="/my/employee/messages" class="eps-chat-mobile-back"><i class="fa fa-arrow-left"></i></a>
                                <div class="eps-chat-avatar eps-chat-avatar-lg"><t t-esc="(summary['title'] or 'E')[:1].upper()"/></div>
                                <div class="eps-chat-header-text">
                                    <h3><t t-esc="summary['title']"/></h3>
                                    <span>Employee private conversation</span>
                                </div>
                            </div>

                            <div class="eps-chat-messages" id="eps_chat_messages">
                                <t t-if="not messages">
                                    <div class="eps-chat-welcome eps-chat-welcome-inline">
                                        <div class="eps-chat-welcome-icon"><i class="fa fa-comment-o"></i></div>
                                        <h3>No messages yet</h3>
                                        <p>Send the first message below.</p>
                                    </div>
                                </t>
                                <t t-foreach="messages" t-as="msg">
                                    <t t-set="mine" t-value="msg.author_id.id == request.env.user.partner_id.id"/>
                                    <div t-att-class="'eps-chat-message-row mine' if mine else 'eps-chat-message-row'">
                                        <div class="eps-chat-avatar eps-chat-message-avatar" t-if="not mine"><t t-esc="(msg.author_id.name or 'E')[:1].upper()"/></div>
                                        <div class="eps-chat-bubble">
                                            <div class="eps-chat-author" t-if="not mine"><t t-esc="msg.author_id.name or 'Employee'"/></div>
                                            <div class="eps-chat-body" t-raw="msg.body"/>
                                            <div class="eps-chat-time"><t t-esc="msg.date.strftime('%Y-%m-%d %H:%M') if msg.date else ''"/></div>
                                        </div>
                                    </div>
                                </t>
                            </div>

                            <form t-att-action="'/my/employee/messages/%s/send' % active_channel.id" method="post" class="eps-chat-composer">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <textarea name="body" class="form-control" rows="2" required="required" placeholder="Write your message..."></textarea>
                                <button class="btn btn-primary" type="submit"><i class="fa fa-paper-plane"></i><span> Send</span></button>
                            </form>
                        </t>
                    </main>
                </div>
            </div>
        </t>
    </template>

    <template id="employee_portal_message_thread" name="Employee Portal Message Thread">
        <t t-call="employee_portal_suite.employee_portal_messages"/>
    </template>

</odoo>

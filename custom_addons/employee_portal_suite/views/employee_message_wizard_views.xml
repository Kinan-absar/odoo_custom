<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_employee_message_wizard_form" model="ir.ui.view">
        <field name="name">employee.message.wizard.form</field>
        <field name="model">employee.message.wizard</field>
        <field name="arch" type="xml">
            <form string="New Employee Message">
                <group>
                    <field name="recipient_id" options="{'no_create': True, 'no_open': True}" placeholder="Type employee name..."/>
                    <field name="body" placeholder="Type your message..."/>
                </group>
                <footer>
                    <button name="action_send_message" type="object" string="Send Message" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_employee_message_wizard" model="ir.actions.act_window">
        <field name="name">New Employee Message</field>
        <field name="res_model">employee.message.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_employee_message_wizard"
              name="New Employee Message"
              parent="hr.menu_hr_root"
              action="action_employee_message_wizard"
              sequence="95"
              groups="base.group_user"/>
</odoo>

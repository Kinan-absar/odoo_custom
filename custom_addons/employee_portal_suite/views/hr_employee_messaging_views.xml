<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_employee_form_employee_portal_messaging" model="ir.ui.view">
        <field name="name">hr.employee.form.employee.portal.messaging</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_employee_portal_message"
                        type="object"
                        string="Message"
                        class="btn-primary"
                        icon="fa-comments"
                        invisible="not user_id"/>
            </xpath>
        </field>
    </record>
</odoo>

<odoo>
    <template id="employee_checkin_page" name="Employee Check In Page">
        <t t-call="employee_portal_suite.employee_portal_layout">
            <style>
                .o_checkin_fullwrap {
                    width: 100%;
                    max-width: 100%;
                    margin: 0;
                    padding: 0;
                }

                .o_checkin_frame_holder {
                    width: 100%;
                    max-width: 100%;
                    margin: 0;
                    padding: 0;
                    background: #fff;
                    border-radius: 0;
                    overflow: hidden;
                }

                .o_checkin_frame {
                    display: block;
                    width: 100%;
                    height: calc(100vh - 72px);
                    border: 0;
                    margin: 0;
                    padding: 0;
                    background: #fff;
                }

                @media (min-width: 992px) {
                    .o_checkin_full_bleed {
                        width: 100vw;
                        max-width: 100vw;
                        margin-left: calc(50% - 50vw);
                        margin-right: calc(50% - 50vw);
                    }

                    .o_checkin_frame {
                        height: calc(100vh - 64px);
                    }
                }

                @media (max-width: 991.98px) {
                    .o_checkin_frame {
                        height: calc(100vh - 56px);
                        min-height: calc(100vh - 56px);
                    }
                }

                @media (max-width: 767.98px) {
                    .o_checkin_frame {
                        height: calc(100vh - 52px);
                        min-height: calc(100vh - 52px);
                    }
                }
            </style>

            <div class="o_checkin_fullwrap o_checkin_full_bleed">
                <div class="o_checkin_frame_holder">
                    <iframe
                        id="pwa_iframe"
                        t-att-src="pwa_url"
                        class="o_checkin_frame"
                        allow="geolocation; camera; microphone; fullscreen"
                        referrerpolicy="strict-origin-when-cross-origin"
                    />
                </div>
            </div>
        </t>
    </template>
</odoo>
<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--
        The former combined Treasury dashboard card is no longer used.
        A minimal valid QWeb architecture is kept because Odoo requires an
        architecture when this external ID is created in a fresh database.
        The view remains inactive, while upgrades can safely update an
        existing record with the same external ID.
    -->
    <record id="employee_dashboard_treasury_card" model="ir.ui.view">
        <field name="name">Employee Dashboard Treasury Card (Disabled)</field>
        <field name="type">qweb</field>
        <field name="active" eval="False"/>
        <field name="arch" type="xml">
            <t t-name="employee_portal_suite.employee_dashboard_treasury_card_disabled"/>
        </field>
    </record>
</odoo>

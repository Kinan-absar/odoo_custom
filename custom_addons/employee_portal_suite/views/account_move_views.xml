<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_material_request_link" model="ir.ui.view">
        <field name="name">account.move.form.material.request.link</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='ref']" position="after">
                <field name="material_request_id" readonly="state != 'draft'"/>
            </xpath>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_attendance_salary_report_form" model="ir.ui.view">
        <field name="name">employee.attendance.salary.report.form</field>
        <field name="model">employee.attendance.salary.report</field>
        <field name="arch" type="xml">
            <form string="Instant Attendance Salary Report">
                <header>
                    <button name="action_generate" type="object" string="Generate / Refresh" class="btn-primary" groups="employee_portal_suite.group_employee_portal_hr,employee_portal_suite.group_employee_portal_admin"/>
                    <button name="action_create_payroll_batch" type="object" string="Create Payroll Batch" class="btn-secondary" groups="employee_portal_suite.group_employee_portal_admin"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,generated,batch_created"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>Instant Attendance Salary Report</h1>
                        <p class="text-muted">Backend payroll attendance calculation for the 26 to 25 cycle or any selected period.</p>
                    </div>
                    <group>
                        <group string="Period &amp; Filters">
                            <field name="company_id" options="{'no_create': True}"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="department_id"/>
                            <field name="employee_ids" widget="many2many_tags"/>
                            <field name="include_inactive"/>
                        </group>
                        <group string="Totals">
                            <field name="total_employees" readonly="1"/>
                            <field name="total_gross_salary" readonly="1"/>
                            <field name="total_basic_salary" readonly="1"/>
                            <field name="total_allowances" readonly="1"/>
                            <field name="total_attendance_deductions" readonly="1"/>
                            <field name="total_overtime_amount" readonly="1"/>
                            <field name="total_other_deductions" readonly="1"/>
                            <field name="total_reimbursements" readonly="1"/>
                            <field name="total_net_salary" readonly="1"/>
                            <field name="generated_on" readonly="1"/>
                            <field name="batch_created" readonly="1"/>
                            <field name="payroll_batch_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Employees">
                            <field name="line_ids" nolabel="1">
                                <list string="Report Lines" editable="bottom" decoration-danger="attendance_deduction &gt; 0" decoration-success="overtime_amount &gt; 0">
                                    <field name="company_id" optional="hide" readonly="1"/>
                                    <field name="employee_id" readonly="1"/>
                                    <field name="department_id" optional="show" readonly="1"/>
                                    <field name="calendar_id" optional="hide" readonly="1"/>
                                    <field name="attendance_not_required" optional="show" readonly="1"/>
                                    <field name="gross_salary" sum="Gross" readonly="1"/>
                                    <field name="basic_salary" optional="show" sum="Basic" readonly="1"/>
                                    <field name="total_allowances" optional="hide" sum="Allowances" readonly="1"/>
                                    <field name="expected_days" optional="show" readonly="1"/>
                                    <field name="public_holiday_days" optional="show" sum="PH" readonly="1"/>
                                    <field name="expected_hours" widget="float_time" sum="Target" readonly="1"/>
                                    <field name="worked_hours" widget="float_time" sum="System Worked" readonly="1" string="System Worked"/>
                                    <field name="manual_worked_hours" widget="float_time" string="Manual Worked"/>
                                    <field name="final_worked_hours" widget="float_time" sum="Final Worked" readonly="1"/>
                                    <field name="approved_leave_days" optional="show" sum="Time Off" readonly="1"/>
                                    <field name="unpaid_leave_days" optional="hide" sum="Deducted Leave" readonly="1"/>
                                    <field name="system_absent_days" optional="show" sum="System Abs." readonly="1"/>
                                    <field name="manual_absent_days" string="Manual Abs."/>
                                    <field name="final_absent_days" sum="Final Abs." readonly="1"/>
                                    <field name="shortage_hours" widget="float_time" sum="Shortage" readonly="1"/>
                                    <field name="overtime_hours" widget="float_time" sum="Overtime" readonly="1"/>
                                    <field name="leave_deduction" optional="show" sum="Leave Ded." readonly="1"/>
                                    <field name="absence_deduction" optional="hide" sum="Absent Ded." readonly="1"/>
                                    <field name="shortage_deduction" optional="show" sum="Hour Ded." readonly="1"/>
                                    <field name="attendance_deduction" sum="Attendance Ded." readonly="1"/>
                                    <field name="overtime_amount" sum="OT Amount" readonly="1"/>
                                    <field name="other_deductions" sum="Other Ded."/>
                                    <field name="reimbursements" sum="Reimb."/>
                                    <field name="net_salary" sum="Estimated Net" readonly="1"/>
                                </list>
                                <form string="Employee Report Line">
                                    <group>
                                        <field name="company_id" readonly="1"/>
                                        <field name="employee_id" readonly="1"/>
                                        <field name="department_id" readonly="1"/>
                                        <field name="contract_id" readonly="1"/>
                                        <field name="calendar_id" readonly="1"/>
                                        <field name="attendance_not_required" readonly="1"/>
                                    </group>
                                    <group>
                                        <group string="Salary Breakdown">
                                            <field name="gross_salary" readonly="1"/>
                                            <field name="basic_salary" readonly="1"/>
                                            <field name="housing_allowance" readonly="1"/>
                                            <field name="transport_allowance" readonly="1"/>
                                            <field name="other_allowances" readonly="1"/>
                                            <field name="total_allowances" readonly="1"/>
                                        </group>
                                        <group string="Attendance">
                                            <field name="expected_days" readonly="1"/>
                                            <field name="public_holiday_days" readonly="1"/>
                                            <field name="expected_hours" widget="float_time" readonly="1"/>
                                            <field name="attendance_worked_hours" widget="float_time" readonly="1"/>
                                            <field name="worked_hours" widget="float_time" readonly="1"/>
                                            <field name="manual_worked_hours" widget="float_time"/>
                                            <field name="final_worked_hours" widget="float_time" readonly="1"/>
                                            <field name="approved_leave_days" readonly="1"/>
                                            <field name="unpaid_leave_days" readonly="1"/>
                                            <field name="manual_absent_days"/>
                                            <field name="final_absent_days" readonly="1"/>
                                        </group>
                                    </group>
                                    <group>
                                        <group string="Rates &amp; Deductions">
                                            <field name="daily_rate" readonly="1"/>
                                            <field name="gross_hourly_rate" readonly="1"/>
                                            <field name="basic_hourly_rate" readonly="1"/>
                                            <field name="overtime_hourly_rate" readonly="1"/>
                                            <field name="shortage_hours" widget="float_time" readonly="1"/>
                                            <field name="overtime_hours" widget="float_time" readonly="1"/>
                                            <field name="leave_deduction" readonly="1"/>
                                            <field name="absence_deduction" readonly="1"/>
                                            <field name="shortage_deduction" readonly="1"/>
                                            <field name="attendance_deduction" readonly="1"/>
                                        </group>
                                        <group string="Manual Adjustments &amp; Net">
                                            <field name="overtime_amount" readonly="1"/>
                                            <field name="other_deductions"/>
                                            <field name="reimbursements"/>
                                            <field name="net_salary" readonly="1"/>
                                        </group>
                                    </group>
                                </form>
                            </field>
                        </page>
                        <page string="Field Source Notes">
                            <p>Gross salary is read from the active/latest employee contract wage. Basic salary is calculated as Gross - Housing - Transport - Other Allowances when those allowance fields exist. If no breakdown fields exist, the report falls back to Gross / 1.35.</p>
                            <p>Employees marked with an attendance-not-applicable/custom flag use fixed/standard hours instead of summed HR Attendance worked hours.</p>
                            <p>Time Off rule: all validated employee time off days are deducted from salary. Public holidays from resource calendar leaves reduce the attendance target but never create a deduction.</p>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_attendance_salary_report_tree" model="ir.ui.view">
        <field name="name">employee.attendance.salary.report.tree</field>
        <field name="model">employee.attendance.salary.report</field>
        <field name="arch" type="xml">
            <list string="Instant Attendance Salary Reports" decoration-success="state == 'batch_created'" decoration-info="state == 'generated'" decoration-muted="state == 'draft'">
                <field name="name"/>
                <field name="company_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="department_id"/>
                <field name="total_employees"/>
                <field name="total_gross_salary"/>
                <field name="total_attendance_deductions"/>
                <field name="total_overtime_amount"/>
                <field name="total_net_salary"/>
                <field name="state" widget="badge" decoration-success="state == 'batch_created'" decoration-info="state == 'generated'" decoration-muted="state == 'draft'"/>
                <field name="payroll_batch_id"/>
                <field name="generated_on"/>
            </list>
        </field>
    </record>

    <record id="view_attendance_salary_report_search" model="ir.ui.view">
        <field name="name">employee.attendance.salary.report.search</field>
        <field name="model">employee.attendance.salary.report</field>
        <field name="arch" type="xml">
            <search string="Instant Attendance Salary Reports">
                <field name="name"/>
                <field name="company_id"/>
                <field name="department_id"/>
                <filter name="not_batched" string="Not Batched" domain="[('state', '!=', 'batch_created')]"/>
                <filter name="batched" string="Batch Created" domain="[('state', '=', 'batch_created')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_company" string="Company" context="{'group_by': 'company_id'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_department" string="Department" context="{'group_by': 'department_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_attendance_salary_report" model="ir.actions.act_window">
        <field name="name">Instant Salary Report</field>
        <field name="res_model">employee.attendance.salary.report</field>
        <field name="view_mode">list,form</field>
        <field name="target">current</field>
        <field name="context">{'form_view_initial_mode': 'edit', 'search_default_not_batched': 1}</field>
    </record>

    <menuitem id="menu_attendance_salary_report"
              name="Instant Salary Reports"
              parent="menu_employee_portal_attendance_root"
              action="action_attendance_salary_report"
              sequence="10"
              groups="employee_portal_suite.group_employee_portal_hr,employee_portal_suite.group_employee_portal_admin"/>
</odoo>

<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================================================
         HR ATTENDANCE — Standalone views for HR/Admin
         (no inherit_id to avoid version-specific XML ID deps)
    ============================================================ -->

    <record id="view_hr_attendance_flag_list" model="ir.ui.view">
        <field name="name">hr.attendance.flag.list</field>
        <field name="model">hr.attendance</field>
        <field name="arch" type="xml">
            <list string="Attendance Records" decoration-danger="checkout_outside_location == True">
                <field name="employee_id" string="Employee"/>
                <field name="check_in"  string="Check In"/>
                <field name="check_out" string="Check Out"/>
                <field name="worked_hours" string="Worked Hours" widget="float_time"/>
                <field name="checkout_outside_location" string="Outside Location"/>
            </list>
        </field>
    </record>

    <record id="view_hr_attendance_flag_form" model="ir.ui.view">
        <field name="name">hr.attendance.flag.form</field>
        <field name="model">hr.attendance</field>
        <field name="arch" type="xml">
            <form string="Attendance">
                <sheet>
                    <group>
                        <field name="employee_id"/>
                        <field name="check_in"/>
                        <field name="check_out"/>
                        <field name="worked_hours" widget="float_time"/>
                        <field name="checkout_outside_location"
                               string="Checked Out Outside Location"
                               readonly="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_hr_attendance_flag_search" model="ir.ui.view">
        <field name="name">hr.attendance.flag.search</field>
        <field name="model">hr.attendance</field>
        <field name="arch" type="xml">
            <search string="Search Attendance">
                <field name="employee_id" string="Employee"/>
                <separator/>
                <filter string="Outside Location Check-outs"
                        name="checkout_outside_location"
                        domain="[('checkout_outside_location','=',True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Employee" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Check-In Date" name="group_date" context="{'group_by': 'check_in:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================
         Actions
    ============================================================ -->

    <record id="action_attendance_all_with_flag" model="ir.actions.act_window">
        <field name="name">Attendance Records</field>
        <field name="res_model">hr.attendance</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5,0,0),
            (0,0,{'view_mode':'list','view_id':ref('view_hr_attendance_flag_list')}),
            (0,0,{'view_mode':'form','view_id':ref('view_hr_attendance_flag_form')}),
        ]"/>
        <field name="search_view_id" ref="view_hr_attendance_flag_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No attendance records found.</p>
        </field>
    </record>

    <record id="action_attendance_outside_location" model="ir.actions.act_window">
        <field name="name">Outside Location Check-outs</field>
        <field name="res_model">hr.attendance</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('checkout_outside_location', '=', True)]</field>
        <field name="view_ids" eval="[(5,0,0),
            (0,0,{'view_mode':'list','view_id':ref('view_hr_attendance_flag_list')}),
            (0,0,{'view_mode':'form','view_id':ref('view_hr_attendance_flag_form')}),
        ]"/>
        <field name="search_view_id" ref="view_hr_attendance_flag_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No outside-location check-outs recorded yet.</p>
            <p>This list shows every check-out where the employee was outside their work location geofence.</p>
        </field>
    </record>

    <!-- ============================================================
         Menus
    ============================================================ -->

    <menuitem id="menu_employee_portal_attendance_root"
              name="Attendance"
              parent="menu_employee_portal_root"
              sequence="40"
              groups="employee_portal_suite.group_employee_portal_hr,
                      employee_portal_suite.group_employee_portal_admin"/>

    <menuitem id="menu_attendance_all"
              name="All Records"
              parent="menu_employee_portal_attendance_root"
              action="action_attendance_all_with_flag"
              sequence="10"
              groups="employee_portal_suite.group_employee_portal_hr,
                      employee_portal_suite.group_employee_portal_admin"/>

    <menuitem id="menu_attendance_outside_location"
              name="Outside Location Check-outs"
              parent="menu_employee_portal_attendance_root"
              action="action_attendance_outside_location"
              sequence="20"
              groups="employee_portal_suite.group_employee_portal_hr,
                      employee_portal_suite.group_employee_portal_admin"/>

</odoo>

        </div>
        <div class="row g-3 mb-4">
          <div class="col-12 col-lg-3"><div class="card border-0 shadow-sm h-100"><div class="card-body"><small class="text-muted">Opening cash</small><div class="fs-4 fw-bold"><span t-field="run.opening_balance" t-options="{'widget':'monetary','display_currency':run.currency_id}"/></div></div></div></div>

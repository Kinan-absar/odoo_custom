                  <tbody>
                    <tr><td>Inflows</td><td class="text-end text-success"><span t-field="run.forecast_inflow" t-options="{'widget':'monetary','display_currency':run.currency_id}"/></td><td class="text-end text-success"><span t-field="run.actual_inflow" t-options="{'widget':'monetary','display_currency':run.currency_id}"/></td><td t-attf-class="text-end fw-semibold #{'text-success' if (run.actual_inflow - run.forecast_inflow) &gt;= 0 else 'text-danger'}"><span t-out="run.actual_inflow - run.forecast_inflow" t-options="{'widget':'monetary','display_currency':run.currency_id}"/></td></tr>
                    <tr><td>Outflows</td><td class="text-end text-danger"><span t-field="run.forecast_outflow" t-options="{'widget':'monetary','display_currency':run.currency_id}"/></td><td class="text-end text-danger"><span t-field="run.actual_outflow" t-options="{'widget':'monetary','display_currency':run.currency_id}"/></td><td t-attf-class="text-end fw-semibold #{'text-success' if (run.actual_outflow - run.forecast_outflow) &lt;= 0 else 'text-danger'}"><span t-out="run.actual_outflow - run.forecast_outflow" t-options="{'widget':'monetary','display_currency':run.currency_id}"/></td></tr>
                    <tr><td>Net cash flow</td><td class="text-end"><span t-field="run.forecast_net" t-options="{'widget':'monetary','display_currency':run.currency_id}"/></td><td class="text-end"><span t-field="run.actual_net" t-options="{'widget':'monetary','display_currency':run.currency_id}"/></td><td t-attf-class="text-end fw-semibold #{'text-success' if (run.actual_net - run.forecast_net) &gt;= 0 else 'text-danger'}"><span t-out="run.actual_net - run.forecast_net" t-options="{'widget':'monetary','display_currency':run.currency_id}"/></td></tr>
                    <tr class="table-light fw-bold"><td>Closing cash balance</td><td class="text-end"><span t-field="run.forecast_closing" t-options="{'widget':'monetary','display_currency':run.currency_id}"/></td><td class="text-end"><span t-field="run.actual_closing" t-options="{'widget':'monetary','display_currency':run.currency_id}"/></td><td t-attf-class="text-end #{'text-success' if run.forecast_variance &gt;= 0 else 'text-danger'}"><span t-field="run.forecast_variance" t-options="{'widget':'monetary','display_currency':run.currency_id}"/></td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
        <div class="card border-0 shadow-sm mb-4"><div class="card-header bg-white"><strong>All planned cash movements</strong></div><div class="table-responsive">
          <table class="table align-middle mb-0"><thead class="table-light"><tr><th>Date</th><th>Flow</th><th>Description</th><th>Partner / Project</th><th>Forecast</th><th>CEO Approved</th><th>Actual</th><th>Variance</th><th>Decision / Status</th></tr></thead><tbody>
            <t t-foreach="run.line_ids" t-as="line"><tr>
              <td><t t-esc="line.planned_date"/></td><td><span t-attf-class="badge #{'text-bg-success' if line.flow_type == 'in' else 'text-bg-danger'}"><t t-esc="'Receipt' if line.flow_type == 'in' else 'Payment'"/></span></td>
              <td><div class="fw-semibold"><t t-esc="line.name"/></div><small class="text-muted"><t t-esc="line.category_id.name"/></small></td>
              <td><div t-if="line.partner_id"><t t-esc="line.partner_id.name"/></div><small t-if="line.project_id" class="text-muted"><t t-esc="line.project_id.name"/></small></td>
              <td><span t-field="line.forecast_amount" t-options="{'widget':'monetary','display_currency':line.currency_id}"/></td>
              <td><span t-if="line.flow_type == 'out'" t-field="line.approved_amount" t-options="{'widget':'monetary','display_currency':line.currency_id}"/><span t-else="" class="text-muted">Not required</span></td>
              <td><span t-field="line.actual_amount" t-options="{'widget':'monetary','display_currency':line.currency_id}"/></td>
              <td t-attf-class="#{'text-success' if ((line.flow_type == 'in' and line.variance_amount &gt;= 0) or (line.flow_type == 'out' and line.variance_amount &lt;= 0)) else 'text-danger'}"><span t-field="line.variance_amount" t-options="{'widget':'monetary','display_currency':line.currency_id}"/></td>
              <td><span t-if="line.flow_type == 'out'" class="badge text-bg-secondary"><t t-esc="dict(line._fields['ceo_decision'].selection).get(line.ceo_decision)"/></span><span t-else="" class="badge text-bg-info"><t t-esc="dict(line._fields['state'].selection).get(line.state)"/></span></td>
            </tr></t>
          </tbody></table>
        </div></div>
      </div>
    </t>
  </template>
</odoo>

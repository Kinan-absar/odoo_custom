<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- ================================================================
       HR EMPLOYEE FORM — "Instant Payroll" tab
       ================================================================ -->
  <record id="view_employee_instant_payroll_tab" model="ir.ui.view">
    <field name="name">hr.employee.instant.payroll.tab</field>
    <field name="model">hr.employee</field>
    <field name="inherit_id" ref="hr.view_employee_form"/>
    <field name="arch" type="xml">
      <notebook position="inside">
        <page string="Instant Payroll" name="instant_payroll"
              groups="hr.group_hr_manager,employee_portal_suite.group_employee_portal_hr,employee_portal_suite.group_employee_portal_admin">
          <group string="Salary (Instant Report)">
            <group>
              <field name="instant_gross_salary"
                     string="Gross Salary (SAR)"
                     help="Total monthly gross. Leave 0 to read from the active payroll contract."/>
              <field name="instant_basic_salary"     string="Basic Salary (SAR)"/>
              <field name="instant_housing_allowance" string="Housing Allowance (SAR)"/>
              <field name="instant_other_allowances"  string="Other Allowances (SAR)"/>
              <field name="instant_fixed_deductions"  string="Fixed Monthly Deductions (SAR)"/>
            </group>
            <group>
              <field name="instant_standard_hours"
                     string="Standard Monthly Hours"
                     help="Target hours per payroll cycle. Leave 0 to use the global default (240 h)."/>
              <field name="instant_disable_overtime"   string="Disable Overtime Pay"/>
              <field name="instant_disable_deductions" string="Disable Hour/Day Deductions"/>
            </group>
          </group>
          <group string="WPS / Mudad Export">
            <group>
              <field name="iqama_number" string="Iqama / National ID (10 digits)"/>
              <field name="bank_code"    string="Bank Code (4 chars, e.g. RJHI)"/>
              <field name="iban_number"  string="IBAN (SA… 24 chars)"/>
            </group>
          </group>
        </page>
      </notebook>
    </field>
  </record>

  <!-- ================================================================
       INSTANT PAYROLL ADJUSTMENT — list view
       ================================================================ -->
  <record id="view_instant_payroll_adj_list" model="ir.ui.view">
    <field name="name">hr.payroll.instant.adjustment.list</field>
    <field name="model">hr.payroll.instant.adjustment</field>
    <field name="arch" type="xml">
      <list string="Instant Payroll Adjustments" default_order="period_start desc, employee_id">
        <field name="employee_id"            string="Employee"/>
        <field name="period_start"           string="Period Start (26th)"/>
        <field name="period_end"             string="Period End (25th)"/>
        <field name="absent_days_adjustment" string="Extra Absent Days"/>
        <field name="other_deductions"       string="Other Ded. (SAR)"/>
        <field name="reimbursements"         string="Reimbursements (SAR)"/>
        <field name="notes"/>
      </list>
    </field>
  </record>

  <!-- ================================================================
       INSTANT PAYROLL ADJUSTMENT — form view
       ================================================================ -->
  <record id="view_instant_payroll_adj_form" model="ir.ui.view">
    <field name="name">hr.payroll.instant.adjustment.form</field>
    <field name="model">hr.payroll.instant.adjustment</field>
    <field name="arch" type="xml">
      <form string="Payroll Adjustment">
        <sheet>
          <group>
            <group string="Employee &amp; Period">
              <field name="employee_id"/>
              <field name="period_start" string="Period Start (26th)"/>
              <field name="period_end"   string="Period End (25th)"/>
            </group>
            <group string="Adjustments">
              <field name="absent_days_adjustment" string="Extra Absent Days"/>
              <field name="other_deductions"       string="Other Deductions (SAR)"/>
              <field name="reimbursements"         string="Reimbursements (SAR)"/>
            </group>
          </group>
          <group string="Notes">
            <field name="notes" nolabel="1" placeholder="Reason for adjustment…"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- ================================================================
       ACTIONS
       ================================================================ -->

  <!-- Open the web-based instant payroll report -->
  <record id="action_instant_payroll_web" model="ir.actions.act_url">
    <field name="name">Instance Report</field>
    <field name="url">/my/instant-payroll</field>
    <field name="target">self</field>
  </record>

  <!-- Backend list of manual adjustments -->
  <record id="action_instant_payroll_adjustments" model="ir.actions.act_window">
    <field name="name">Payroll Adjustments</field>
    <field name="res_model">hr.payroll.instant.adjustment</field>
    <field name="view_mode">list,form</field>
  </record>

  <!-- ================================================================
       MENU ITEMS — under the existing Employee Portal root menu
       ================================================================ -->
  <menuitem id="menu_instant_payroll_root"
            name="Instant Payroll"
            parent="employee_portal_suite.menu_employee_portal_root"
            sequence="40"
            groups="hr.group_hr_manager,employee_portal_suite.group_employee_portal_hr,employee_portal_suite.group_employee_portal_admin"/>

  <menuitem id="menu_instant_payroll_report"
            name="Instance Report"
            parent="menu_instant_payroll_root"
            action="action_instant_payroll_web"
            sequence="10"
            groups="hr.group_hr_manager,employee_portal_suite.group_employee_portal_hr,employee_portal_suite.group_employee_portal_admin"/>

  <menuitem id="menu_instant_payroll_adjustments"
            name="Manual Adjustments"
            parent="menu_instant_payroll_root"
            action="action_instant_payroll_adjustments"
            sequence="20"
            groups="hr.group_hr_manager,employee_portal_suite.group_employee_portal_hr,employee_portal_suite.group_employee_portal_admin"/>

</odoo>

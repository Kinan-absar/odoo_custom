<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_employee_instant_payroll_tab" model="ir.ui.view">
    <field name="name">hr.employee.instant.payroll.tab</field>
    <field name="model">hr.employee</field>
    <field name="inherit_id" ref="hr.view_employee_form"/>
    <field name="arch" type="xml">
      <notebook position="inside">
        <page string="Instant Payroll" name="instant_payroll" groups="hr.group_hr_manager,employee_portal_suite.group_employee_portal_hr,employee_portal_suite.group_employee_portal_admin">
          <group string="Salary (Instant Report)">
            <group>
              <field name="instant_gross_salary"/>
              <field name="instant_basic_salary"/>
              <field name="instant_housing_allowance"/>
              <field name="instant_other_allowances"/>
              <field name="instant_fixed_deductions"/>
            </group>
            <group>
              <field name="instant_standard_hours"/>
              <field name="instant_disable_overtime"/>
              <field name="instant_disable_deductions"/>
            </group>
          </group>
          <group string="WPS / Mudad Export">
            <group>
              <field name="iqama_number"/>
              <field name="bank_code"/>
              <field name="iban_number"/>
            </group>
          </group>
        </page>
      </notebook>
    </field>
  </record>

  <record id="view_instant_payroll_adjustment_list" model="ir.ui.view">
    <field name="name">hr.payroll.instant.adjustment.list</field>
    <field name="model">hr.payroll.instant.adjustment</field>
    <field name="arch" type="xml">
      <list string="Instant Payroll Adjustments" default_order="period_start desc, employee_id">
        <field name="employee_id"/>
        <field name="period_start"/>
        <field name="period_end"/>
        <field name="absent_days_adjustment"/>
        <field name="other_deductions"/>
        <field name="reimbursements"/>
        <field name="notes"/>
      </list>
    </field>
  </record>

  <record id="view_instant_payroll_adjustment_form" model="ir.ui.view">
    <field name="name">hr.payroll.instant.adjustment.form</field>
    <field name="model">hr.payroll.instant.adjustment</field>
    <field name="arch" type="xml">
      <form string="Instant Payroll Adjustment">
        <sheet>
          <group>
            <group string="Employee &amp; Period">
              <field name="employee_id"/>
              <field name="period_start"/>
              <field name="period_end"/>
            </group>
            <group string="Manual Adjustments">
              <field name="absent_days_adjustment"/>
              <field name="other_deductions"/>
              <field name="reimbursements"/>
            </group>
          </group>
          <group string="Notes">
            <field name="notes" nolabel="1"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_instant_payroll_adjustments" model="ir.actions.act_window">
    <field name="name">Payroll Adjustments</field>
    <field name="res_model">hr.payroll.instant.adjustment</field>
    <field name="view_mode">list,form</field>
  </record>

  <record id="view_hr_payroll_instant_report_form" model="ir.ui.view">
    <field name="name">hr.payroll.instant.report.form</field>
    <field name="model">hr.payroll.instant.report</field>
    <field name="arch" type="xml">
      <form string="Instant Attendance Salary Report" create="0" duplicate="0">
        <header>
          <button name="action_generate" type="object" string="Generate / Refresh" class="btn-primary"/>
          <button name="action_create_payroll_batch" type="object" string="Create Payroll Batch" class="btn-secondary"/>
        </header>
        <sheet>
          <div class="oe_title">
            <h1>Instant Attendance Salary Report</h1>
            <p class="text-muted">Backend live attendance and salary estimate for the selected 26 to 25 payroll cycle.</p>
          </div>

          <group>
            <group string="Period">
              <field name="date_start"/>
              <field name="date_end"/>
              <field name="standard_hours"/>
            </group>
            <group string="Filters">
              <field name="employee_ids" widget="many2many_tags"/>
              <field name="department_id"/>
              <field name="work_location_id"/>
            </group>
          </group>

          <group string="Totals" col="6">
            <field name="employee_count"/>
            <field name="total_worked_hours" widget="float_time"/>
            <field name="total_expected_days"/>
            <field name="total_absent_days"/>
            <field name="total_overtime_hours" widget="float_time"/>
            <field name="total_net_payable"/>
          </group>

          <notebook>
            <page string="Report Lines">
              <field name="line_ids" nolabel="1" readonly="1">
                <list string="Instant Attendance Salary Report Lines" create="0" edit="0" delete="0">
                  <field name="employee_id"/>
                  <field name="department_id"/>
                  <field name="job_id" optional="hide"/>
                  <field name="expected_working_days" sum="Expected Days"/>
                  <field name="days_worked" sum="Worked Days"/>
                  <field name="worked_hours" widget="float_time" sum="Worked Hours"/>
                  <field name="hourly_shortfall" widget="float_time" sum="Shortage Hours"/>
                  <field name="overtime_hours" widget="float_time" sum="Overtime Hours"/>
                  <field name="total_absent_days" sum="Absent Days"/>
                  <field name="gross" sum="Gross"/>
                  <field name="basic_salary" optional="hide"/>
                  <field name="housing_allowance" optional="hide"/>
                  <field name="other_allowances" optional="hide"/>
                  <field name="hourly_deduction" optional="hide"/>
                  <field name="absent_deduction" optional="hide"/>
                  <field name="deduction" sum="Deductions"/>
                  <field name="other_ded" sum="Other Deductions"/>
                  <field name="overtime" sum="Overtime Pay"/>
                  <field name="reimb" sum="Reimbursements"/>
                  <field name="net" sum="Net Payable"/>
                  <field name="leave_balance" optional="show"/>
                </list>
              </field>
            </page>
            <page string="Leave Details">
              <field name="line_ids" nolabel="1" readonly="1">
                <list string="Leave Details" create="0" edit="0" delete="0">
                  <field name="employee_id"/>
                  <field name="leave_allocation_total"/>
                  <field name="leave_taken_ytd"/>
                  <field name="leave_balance"/>
                  <field name="absent_days_from_leave"/>
                  <field name="adj_absent_days"/>
                </list>
              </field>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_hr_payroll_instant_report" model="ir.actions.act_window">
    <field name="name">Instant Attendance Salary Report</field>
    <field name="res_model">hr.payroll.instant.report</field>
    <field name="view_mode">form</field>
    <field name="target">current</field>
    <field name="context">{}</field>
  </record>

  <menuitem id="menu_instant_payroll_root" name="Instant Payroll" parent="hr.menu_hr_root" sequence="25" groups="hr.group_hr_manager,employee_portal_suite.group_employee_portal_hr,employee_portal_suite.group_employee_portal_admin"/>
  <menuitem id="menu_instant_payroll_report" name="Instant Attendance Salary Report" parent="menu_instant_payroll_root" action="action_hr_payroll_instant_report" sequence="10" groups="hr.group_hr_manager,employee_portal_suite.group_employee_portal_hr,employee_portal_suite.group_employee_portal_admin"/>
  <menuitem id="menu_instant_payroll_adjustments" name="Manual Adjustments" parent="menu_instant_payroll_root" action="action_instant_payroll_adjustments" sequence="20" groups="hr.group_hr_manager,employee_portal_suite.group_employee_portal_hr,employee_portal_suite.group_employee_portal_admin"/>

</odoo>

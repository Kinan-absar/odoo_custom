                    </t>

                    <t t-if="not request_rec.get_portal_timeline()">
                        <div class="text-muted small">
                            No approval activity yet.
                        </div>
                    </t>

                </div>
            </div>
<t t-foreach="request_rec.message_ids.filtered(lambda m: m.message_type == 'comment')" t-as="msg">
    <div class="border p-2 mb-2">
        <strong><t t-esc="msg.author_id.name or 'Unknown'"/></strong>
        <small class="text-muted ms-2">

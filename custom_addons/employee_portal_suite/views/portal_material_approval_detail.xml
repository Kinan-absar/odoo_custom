<?xml version="1.0" encoding="UTF-8"?>
<odoo>

        <template id="portal_material_approval_detail" name="Material Approval Detail">
        <t t-call="employee_portal_suite.employee_portal_layout">

        <div class="container mt-3 employee-req-detail">

            <!-- ========================= -->
            <!-- BACK BUTTON -->
            <!-- ========================= -->
            <div class="mb-4">
                <a href="/my/employee/material/approvals" class="app-back-btn">
                    <i class="fa fa-arrow-left"></i>
                    <span>Back</span>
                </a>
            </div>

            <!-- ========================= -->
            <!-- PAGE HEADER -->
            <!-- ========================= -->
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h4 class="mb-0 fw-bold">Material Approval</h4>
                    <div class="text-muted small">
                        <t t-esc="request_rec.name"/>
                    </div>
                </div>

                <div class="text-end">
                    <t t-raw="status_badge(request_rec)"/>

                    <t t-if="request_rec.state in ['approved','rejected']">
                        <a t-att-href="'/my/employee/material/pdf/%s' % request_rec.id"
                        class="btn btn-sm btn-outline-primary mt-2">
                            Download PDF
                        </a>
                    </t>
                </div>
            </div>

            <!-- ========================= -->
            <!-- ALERTS -->
            <!-- ========================= -->

            <t t-if="request_rec.state == 'rejected'">
                <div class="alert alert-danger small">
                    <strong>Rejected at:</strong>
                    <t t-esc="request_rec.state_before_reject"/> —
                    <strong>Reason:</strong>
                    <t t-esc="request_rec.get_rejection_reason()"/>
                </div>
            </t>

            <t t-if="request_rec.needs_clarification and request_rec.clarification_stage">
                <div class="alert alert-warning small">
                    <strong>
                        Clarification requested by 
                        <t t-esc="dict(request_rec._fields['state'].selection).get(request_rec.clarification_stage)"/>.
                    </strong>
                </div>
            </t>

            <!-- ========================= -->
            <!-- OVERVIEW CARD -->
            <!-- ========================= -->
            <div class="card mb-3 rounded-4 shadow-sm">
                <div class="card-body small">
                    <div class="row g-3">
                        <div class="col-6">
                            <div class="text-muted">Employee</div>
                            <div class="fw-semibold">
                                <t t-esc="request_rec.employee_id.name"/>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="text-muted">Worksite</div>
                            <div class="fw-semibold">
                                <t t-esc="request_rec.worksite"/>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="text-muted">Request Date</div>
                            <div class="fw-semibold">
                                <t t-esc="request_rec.request_date"/>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="text-muted">Delivery Date</div>
                            <div class="fw-semibold">
                                <t t-esc="request_rec.delivery_date"/>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ========================= -->
            <!-- QUOTATION DOCUMENTS - PURCHASE REPRESENTATIVE ONLY -->
            <!-- ========================= -->
            <t t-if="is_purchase_rep">
                <div class="card mb-3 rounded-4 shadow-sm border-primary">
                    <div class="card-header bg-white">
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <div>
                                <div class="fw-semibold">Quotation Collection</div>
                                <div class="text-muted small">Upload supplier quotations separately from general MR attachments.</div>
                            </div>
                            <span t-att-class="'badge ' + ('bg-secondary' if request_rec.quotation_status == 'pending' else 'bg-warning text-dark' if request_rec.quotation_status in ['remaining_2','remaining_1'] else 'bg-success' if request_rec.quotation_status == 'uploaded' else 'bg-info text-dark')">
                                <t t-esc="dict(request_rec._fields['quotation_status'].selection).get(request_rec.quotation_status)"/>
                            </span>
                        </div>
                    </div>
                    <div class="card-body small">
                        <div class="row g-2 mb-3">
                            <div class="col-md-4 col-6">
                                <div class="p-2 rounded-3 bg-light border h-100">
                                    <div class="text-muted">Quotation Files</div>
                                    <div class="fw-semibold"><t t-esc="len(quotation_attachments)"/> uploaded</div>
                                </div>
                            </div>
                            <div class="col-md-4 col-6">
                                <div class="p-2 rounded-3 bg-light border h-100">
                                    <div class="text-muted">Target</div>
                                    <div class="fw-semibold">3 quotations</div>
                                </div>
                            </div>
                            <div class="col-md-4 col-12">
                                <div class="p-2 rounded-3 bg-light border h-100">
                                    <div class="text-muted">Backend Override</div>
                                    <div class="fw-semibold text-truncate">
                                        <t t-if="request_rec.quotation_status_override"><t t-esc="dict(request_rec._fields['quotation_status_override'].selection).get(request_rec.quotation_status_override)"/></t>
                                        <t t-else="">Automatic</t>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <t t-if="quotation_attachments">
                            <div class="list-group list-group-flush mb-3">
                                <t t-foreach="quotation_attachments" t-as="att">
                                    <div class="list-group-item px-0">
                                        <div class="d-flex justify-content-between align-items-center gap-2">
                                            <div class="overflow-hidden d-flex align-items-center gap-2">
                                                <i t-att-class="'fa ' + ('fa-file-pdf-o text-danger' if (att.mimetype or '').find('pdf') >= 0 else 'fa-file-image-o text-primary' if (att.mimetype or '').find('image') >= 0 else 'fa-file-excel-o text-success' if ((att.mimetype or '').find('sheet') >= 0 or (att.name or '').lower().endswith(('.xls', '.xlsx'))) else 'fa-file-o text-muted')"></i>
                                                <div class="overflow-hidden">
                                                    <div class="fw-semibold text-truncate"><t t-esc="att.name"/></div>
                                                    <div class="text-muted small">
                                                        <t t-if="att.file_size"><t t-esc="'%.1f KB' % (att.file_size / 1024.0)"/></t>
                                                        <t t-if="att.create_date"> · Uploaded <t t-esc="att.create_date"/></t>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="d-flex gap-2 flex-shrink-0">
                                                <a t-att-href="'/web/content/%s' % att.id" target="_blank" class="attachment-icon-btn text-primary" title="Preview"><i class="fa fa-eye"></i></a>
                                                <a t-att-href="'/web/content/%s?download=true' % att.id" target="_blank" class="attachment-icon-btn text-secondary" title="Download"><i class="fa fa-download"></i></a>
                                                <a href="#" class="attachment-icon-btn text-danger delete-trigger" t-att-data-url="'/my/employee/material/attachment/delete/%s/%s' % (att.id, request_rec.id)" title="Delete"><i class="fa fa-trash"></i></a>
                                            </div>
                                        </div>
                                        <div class="delete-confirmation d-none mt-3">
                                            <div class="confirm-box p-3 rounded-3">
                                                <div class="small mb-2 text-muted">Delete this quotation document?</div>
                                                <div class="d-flex gap-2 justify-content-end">
                                                    <button type="button" class="btn btn-sm btn-light cancel-delete">Cancel</button>
                                                    <a href="#" class="btn btn-sm btn-danger confirm-delete-link">Delete</a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </t>
                        <t t-else="">
                            <div class="alert alert-light border small mb-3">No quotation documents uploaded yet.</div>
                        </t>

                        <form method="post" action="/my/employee/material/attachment/upload" enctype="multipart/form-data" class="mb-0">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <input type="hidden" name="req_id" t-att-value="request_rec.id"/>
                            <input type="hidden" name="attachment_tag" value="Quotation Documents"/>
                            <div id="dropzone-quotation" class="border rounded-4 p-4 text-center bg-light mb-2" style="cursor:pointer;">
                                <div class="fw-semibold mb-1">Upload Quotation Documents</div>
                                <div class="text-muted small">Only quotation files uploaded here count toward quotation status.</div>
                                <div class="mt-2">
                                    <span class="badge bg-white text-dark border">PDF</span>
                                    <span class="badge bg-white text-dark border">JPG/PNG</span>
                                    <span class="badge bg-white text-dark border">XLS/XLSX</span>
                                    <span class="badge bg-white text-dark border">DOC/DOCX</span>
                                    <span class="badge bg-white text-dark border">Max 10 MB each</span>
                                </div>
                                <input type="file" name="attachments" id="fileInput-quotation" class="d-none" accept=".pdf,.jpg,.jpeg,.png,.xls,.xlsx,.doc,.docx,application/pdf,image/jpeg,image/png,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document" multiple="multiple"/>
                            </div>
                            <div id="previewArea-quotation"></div>
                            <div class="d-flex justify-content-end">
                                <button type="submit" class="btn btn-outline-primary px-4">Upload Quotations</button>
                            </div>
                        </form>
                    </div>
                </div>
            </t>

            <!-- ========================= -->
            <!-- ACCOUNTING DOCUMENTS - PURCHASE REPRESENTATIVE ONLY -->
            <!-- ========================= -->
            <t t-if="is_purchase_rep and request_rec.state == 'approved'">
                <div class="card mb-3 rounded-4 shadow-sm border-success">
                    <div class="card-header bg-white">
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <div>
                                <div class="fw-semibold">Invoice Submission to Accounting</div>
                                <div class="text-muted small">Upload invoice/supporting files separately from quotation and general MR attachments, then submit them to Accounting.</div>
                            </div>
                            <span t-att-class="'badge ' + ('bg-secondary' if request_rec.accounting_docs_status == 'pending' else 'bg-primary' if request_rec.accounting_docs_status == 'submitted' else 'bg-info text-dark' if request_rec.accounting_docs_status == 'received' else 'bg-warning text-dark' if request_rec.accounting_docs_status == 'need_more' else 'bg-success' if request_rec.accounting_docs_status == 'processed' else 'bg-danger')">
                                <t t-esc="dict(request_rec._fields['accounting_docs_status'].selection).get(request_rec.accounting_docs_status)"/>
                            </span>
                        </div>
                    </div>

                    <div class="card-body small">
                        <!-- Progress stepper -->
                        <div class="d-flex align-items-center justify-content-between text-center mb-3 accounting-stepper">
                            <div t-att-class="'flex-fill ' + ('text-success fw-semibold' if accounting_attachments else 'text-muted')">
                                <div class="rounded-circle border mx-auto mb-1 d-flex align-items-center justify-content-center" style="width:32px;height:32px;">
                                    <i class="fa fa-upload"></i>
                                </div>
                                <div>Upload</div>
                            </div>
                            <div class="border-top flex-fill mx-2"></div>
                            <div t-att-class="'flex-fill ' + ('text-success fw-semibold' if request_rec.accounting_docs_status in ['submitted','received','need_more','processed','rejected'] else 'text-muted')">
                                <div class="rounded-circle border mx-auto mb-1 d-flex align-items-center justify-content-center" style="width:32px;height:32px;">
                                    <i class="fa fa-paper-plane"></i>
                                </div>
                                <div>Submitted</div>
                            </div>
                            <div class="border-top flex-fill mx-2"></div>
                            <div t-att-class="'flex-fill ' + ('text-success fw-semibold' if request_rec.accounting_docs_status == 'processed' else 'text-muted')">
                                <div class="rounded-circle border mx-auto mb-1 d-flex align-items-center justify-content-center" style="width:32px;height:32px;">
                                    <i class="fa fa-check"></i>
                                </div>
                                <div>Processed</div>
                            </div>
                        </div>

                        <!-- Context strip -->
                        <div class="row g-2 mb-3">
                            <div class="col-md-3 col-6">
                                <div class="p-2 rounded-3 bg-light border h-100">
                                    <div class="text-muted">PO / Bill</div>
                                    <div class="fw-semibold text-truncate">
                                        <t t-if="request_rec.po_created"><t t-esc="request_rec.po_name"/></t>
                                        <t t-elif="request_rec.no_po_required and request_rec.vendor_bill_ids">Bill Created</t>
                                        <t t-elif="request_rec.no_po_required">No PO Required</t>
                                        <t t-else="">No PO Created</t>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3 col-6">
                                <div class="p-2 rounded-3 bg-light border h-100">
                                    <div class="text-muted">Files</div>
                                    <div class="fw-semibold"><t t-esc="len(accounting_attachments)"/> uploaded</div>
                                </div>
                            </div>
                            <div class="col-md-3 col-6">
                                <div class="p-2 rounded-3 bg-light border h-100">
                                    <div class="text-muted">Submitted By</div>
                                    <div class="fw-semibold text-truncate">
                                        <t t-if="request_rec.docs_submitted_by"><t t-esc="request_rec.docs_submitted_by.name"/></t>
                                        <t t-else="">-</t>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3 col-6">
                                <div class="p-2 rounded-3 bg-light border h-100">
                                    <div class="text-muted">Submitted Date</div>
                                    <div class="fw-semibold text-truncate">
                                        <t t-if="request_rec.docs_submitted_date"><t t-esc="request_rec.docs_submitted_date"/></t>
                                        <t t-else="">-</t>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <t t-if="request_rec.no_po_required and request_rec.no_po_reason">
                            <div class="alert alert-light border small mb-3">
                                <strong>No PO Reason:</strong> <t t-esc="request_rec.no_po_reason"/>
                            </div>
                        </t>

                        <!-- Uploaded accounting files -->
                        <t t-if="accounting_attachments">
                            <div class="list-group list-group-flush mb-3">
                                <t t-foreach="accounting_attachments" t-as="att">
                                    <div class="list-group-item px-0">
                                        <div class="d-flex justify-content-between align-items-center gap-2">
                                            <div class="overflow-hidden d-flex align-items-center gap-2">
                                                <i t-att-class="'fa ' + ('fa-file-pdf-o text-danger' if (att.mimetype or '').find('pdf') >= 0 else 'fa-file-image-o text-primary' if (att.mimetype or '').find('image') >= 0 else 'fa-file-excel-o text-success' if ((att.mimetype or '').find('sheet') >= 0 or (att.name or '').lower().endswith(('.xls', '.xlsx'))) else 'fa-file-o text-muted')"></i>
                                                <div class="overflow-hidden">
                                                    <div class="fw-semibold text-truncate"><t t-esc="att.name"/></div>
                                                    <div class="text-muted small">
                                                        <t t-if="att.file_size"><t t-esc="'%.1f KB' % (att.file_size / 1024.0)"/></t>
                                                        <t t-if="att.create_date"> · Uploaded <t t-esc="att.create_date"/></t>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="d-flex gap-2 flex-shrink-0">
                                                <a t-att-href="'/web/content/%s' % att.id" target="_blank" class="attachment-icon-btn text-primary" title="Preview">
                                                    <i class="fa fa-eye"></i>
                                                </a>
                                                <a t-att-href="'/web/content/%s?download=true' % att.id" target="_blank" class="attachment-icon-btn text-secondary" title="Download">
                                                    <i class="fa fa-download"></i>
                                                </a>
                                                <t t-if="request_rec.accounting_docs_status == 'pending'">
                                                    <a href="#" class="attachment-icon-btn text-danger delete-trigger" t-att-data-url="'/my/employee/material/attachment/delete/%s/%s' % (att.id, request_rec.id)" title="Remove">
                                                        <i class="fa fa-times"></i>
                                                    </a>
                                                </t>
                                            </div>
                                        </div>
                                        <div class="delete-confirmation d-none mt-3">
                                            <div class="confirm-box p-3 rounded-3">
                                                <div class="small mb-2 text-muted">Delete this accounting document?</div>
                                                <div class="d-flex gap-2 justify-content-end">
                                                    <button type="button" class="btn btn-sm btn-light cancel-delete">Cancel</button>
                                                    <a href="#" class="btn btn-sm btn-danger confirm-delete-link">Delete</a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </t>
                        <t t-else="">
                            <div class="alert alert-warning small mb-3">
                                Upload at least one invoice/supporting document before submitting to Accounting.
                            </div>
                        </t>

                        <form method="post"
                              action="/my/employee/material/attachment/upload"
                              enctype="multipart/form-data"
                              class="mb-3">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <input type="hidden" name="req_id" t-att-value="request_rec.id"/>
                            <input type="hidden" name="attachment_tag" value="Accounting Documents"/>

                            <div id="dropzone-accounting"
                                 class="border rounded-4 p-4 text-center bg-light mb-2"
                                 style="cursor:pointer;">
                                <div class="fw-semibold mb-1">Upload Invoice Documents</div>
                                <div class="text-muted small">Drag files here or click to choose files.</div>
                                <div class="mt-2">
                                    <span class="badge bg-white text-dark border">PDF</span>
                                    <span class="badge bg-white text-dark border">JPG/PNG</span>
                                    <span class="badge bg-white text-dark border">XLS/XLSX</span>
                                    <span class="badge bg-white text-dark border">Max 10 MB each</span>
                                </div>
                                <input type="file"
                                       name="attachments"
                                       id="fileInput-accounting"
                                       class="d-none"
                                       accept=".pdf,.jpg,.jpeg,.png,.xls,.xlsx,application/pdf,image/jpeg,image/png,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
                                       multiple="multiple"/>
                            </div>

                            <div id="previewArea-accounting"></div>

                            <div class="d-flex justify-content-end">
                                <button type="submit" class="btn btn-outline-success px-4">
                                    Upload Documents
                                </button>
                            </div>
                        </form>

                        <form method="post" action="/my/employee/material/submit_docs_to_accounting">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <input type="hidden" name="req_id" t-att-value="request_rec.id"/>
                            <div class="mb-3">
                                <label class="form-label fw-semibold small">Note to Accounting <span class="text-muted fw-normal">(optional)</span></label>
                                <textarea name="accounting_docs_note" class="form-control" rows="2" placeholder="Example: partial delivery, split invoice, urgent processing..."><t t-esc="request_rec.accounting_docs_note or ''"/></textarea>
                            </div>
                            <t t-if="not accounting_attachments">
                                <div class="alert alert-light border small mb-3">
                                    Submit is disabled because no accounting documents are uploaded yet.
                                </div>
                            </t>
                            <t t-elif="not can_submit_accounting_docs">
                                <div class="alert alert-success border small mb-3">
                                    All uploaded accounting documents have already been submitted. The Submit button will appear again after you upload a new document.
                                </div>
                            </t>
                            <t t-if="can_submit_accounting_docs">
                                <div class="d-flex justify-content-end">
                                    <button type="submit" class="btn btn-success px-4">
                                        Submit to Accounting
                                    </button>
                                </div>
                            </t>
                        </form>

                    </div>
                </div>
            </t>

            <!-- ========================= -->
            <!-- MATERIAL LIST -->
            <!-- ========================= -->
            <div class="card mb-3 rounded-4 shadow-sm">
                <div class="card-header bg-white fw-semibold">
                    Requested Materials
                </div>
                <div class="list-group list-group-flush small">
                    <t t-foreach="request_rec.line_ids" t-as="line">
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <div class="fw-semibold">
                                    <t t-esc="line.item_name"/>
                                </div>
                                <div class="text-muted small">
                                    <t t-esc="line.uom_id.name"/>
                                </div>
                            </div>
                            <div class="fw-bold fs-6">
                                <t t-esc="line.qty_required"/>
                            </div>
                        </div>
                    </t>
                </div>
            </div>

            <!-- ========================= -->
            <!-- ATTACHMENTS -->
            <!-- ========================= -->
            <div class="card mb-3 rounded-4 shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center bg-white">
                    <span class="fw-semibold">Attachments</span>
                    <span class="badge bg-light text-dark">
                        <t t-esc="len(attachments)"/>
                    </span>
                </div>

                <div class="card-body p-0">

                    <t t-if="attachments">
                        <div class="list-group list-group-flush small">
                            <t t-foreach="attachments" t-as="att">
                                <div class="list-group-item">

                                    <div class="d-flex justify-content-between align-items-center">

                                        <div class="overflow-hidden">
                                            <div class="fw-semibold text-truncate">
                                                <t t-esc="att.name"/>
                                            </div>
                                            <div class="text-muted small">
                                                <t t-esc="att.description or 'General'"/>
                                            </div>
                                        </div>

                                        <div class="d-flex gap-2">

                                            <a t-att-href="'/web/content/%s' % att.id"
                                            target="_blank"
                                            class="attachment-icon-btn text-primary">
                                                <i class="fa fa-eye"></i>
                                            </a>

                                            <a t-att-href="'/web/content/%s?download=true' % att.id"
                                            target="_blank"
                                            class="attachment-icon-btn text-secondary">
                                                <i class="fa fa-download"></i>
                                            </a>

                                            <a href="#"
                                            class="attachment-icon-btn text-danger delete-trigger"
                                            t-att-data-url="'/my/employee/material/attachment/delete/%s/%s' % (att.id, request_rec.id)">
                                                <i class="fa fa-times"></i>
                                            </a>

                                        </div>
                                    </div>

                                    <!-- Delete Confirmation -->
                                    <div class="delete-confirmation d-none mt-3">
                                        <div class="confirm-box p-3 rounded-3">
                                            <div class="small mb-2 text-muted">
                                                Delete this attachment?
                                            </div>
                                            <div class="d-flex gap-2 justify-content-end">
                                                <button type="button"
                                                        class="btn btn-sm btn-light cancel-delete">
                                                    Cancel
                                                </button>
                                                <a href="#"
                                                class="btn btn-sm btn-danger confirm-delete">
                                                    Delete
                                                </a>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </t>
                        </div>
                    </t>

                    <t t-else="">
                        <div class="p-3 text-muted small">
                            No attachments uploaded.
                        </div>
                    </t>

                </div>
            </div>
            <!-- ========================= -->
                <!-- UPLOAD SECTION -->
                <!-- ========================= -->

                <div class="card mb-3 rounded-4 shadow-sm">
                    <div class="card-header bg-white fw-semibold">
                        Upload New Attachments
                    </div>

                    <div class="card-body small">

                        <form method="post"
                            action="/my/employee/material/attachment/upload"
                            enctype="multipart/form-data">

                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <input type="hidden" name="req_id" t-att-value="request_rec.id"/>

                            <select name="attachment_tag" class="form-select mb-3">

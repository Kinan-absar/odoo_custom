<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_hr_work_location_form_inherit_project" model="ir.ui.view">
        <field name="name">hr.work.location.form.inherit.project</field>
        <field name="model">hr.work.location</field>
        <field name="inherit_id" ref="hr.hr_work_location_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group" position="inside">

                <group string="Project">
                    <field name="project_id"/>
                </group>

                <group string="Geofencing">
                    <field name="geo_enforce"/>
                    <field name="geo_latitude"
                           attrs="{'invisible': [('geo_enforce','=',False)]}"
                           placeholder="e.g. 24.7136"/>
                    <field name="geo_longitude"
                           attrs="{'invisible': [('geo_enforce','=',False)]}"
                           placeholder="e.g. 46.6753"/>
                    <field name="geo_radius"
                           attrs="{'invisible': [('geo_enforce','=',False)]}"
                           help="Employees must check in within this distance (metres) from the coordinates above."/>
                </group>

            </xpath>
        </field>
    </record>

</odoo>

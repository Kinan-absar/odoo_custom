<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <record id="action_report_attendance_payroll" model="ir.actions.report">
    <field name="name">Attendance Payroll Report</field>
    <field name="model">attendance.payroll.report</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">employee_portal_suite.report_attendance_payroll_document</field>
    <field name="report_file">employee_portal_suite.report_attendance_payroll_document</field>
    <field name="print_report_name">'Attendance Payroll Report - %s to %s' % (object.date_from, object.date_to)</field>
  </record>

  <template id="report_attendance_payroll_document">
    <t t-call="web.html_container">
      <t t-foreach="docs" t-as="o">
        <t t-call="web.external_layout">
          <div class="page">
            <h2>Attendance Payroll Report</h2>
            <p><strong>Period:</strong> <span t-field="o.date_from"/> to <span t-field="o.date_to"/></p>
            <table class="table table-sm o_main_table" style="font-size:10px;">
              <thead>
                <tr>
                  <th>Employee</th><th>Dept.</th><th>Shifts</th><th>Days</th><th>Absent</th><th>Hours</th><th>Diff</th><th>Gross</th><th>Deductions</th><th>OT</th><th>Reimb.</th><th>Net</th>
                </tr>
              </thead>
              <tbody>
                <tr t-foreach="o.line_ids" t-as="l">
                  <td><span t-field="l.employee_id.name"/><t t-if="l.is_on_leave"> (On Leave)</t></td>
                  <td><span t-field="l.department_id.name"/></td>
                  <td class="text-end"><span t-field="l.shift_count"/></td>
                  <td class="text-end"><span t-field="l.days_worked"/> / <span t-field="l.expected_days"/></td>
                  <td class="text-end"><span t-field="l.total_absent_days"/></td>
                  <td class="text-end"><span t-esc="'%.2f' % l.total_hours"/></td>
                  <td class="text-end"><span t-esc="'%.2f' % l.hour_diff"/></td>
                  <td class="text-end"><span t-esc="'%.2f' % l.gross_salary"/></td>
                  <td class="text-end"><span t-esc="'%.2f' % l.total_deductions"/></td>
                  <td class="text-end"><span t-esc="'%.2f' % l.overtime_pay"/></td>
                  <td class="text-end"><span t-esc="'%.2f' % l.reimbursements"/></td>
                  <td class="text-end"><strong><span t-esc="'%.2f' % l.net_salary"/></strong></td>
                </tr>
              </tbody>
              <tfoot>
                <tr>
                  <td colspan="5"><strong>Totals</strong></td>
                  <td class="text-end"><strong><span t-esc="'%.2f' % o.total_hours"/></strong></td>
                  <td></td>
                  <td class="text-end"><strong><span t-esc="'%.2f' % o.total_gross"/></strong></td>
                  <td class="text-end"><strong><span t-esc="'%.2f' % o.total_deductions"/></strong></td>
                  <td class="text-end"><strong><span t-esc="'%.2f' % o.total_overtime"/></strong></td>
                  <td></td>
                  <td class="text-end"><strong><span t-esc="'%.2f' % o.total_net"/></strong></td>
                </tr>
              </tfoot>
            </table>
          </div>
        </t>
      </t>
    </t>
  </template>
</odoo>

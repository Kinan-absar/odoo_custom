<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         QWeb Report Template — Salary Summary Print
         Columns: Employee | Gross | Deductions | Reimbursements | Net
    ================================================================ -->
    <template id="report_salary_summary_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="report">
                <t t-call="web.external_layout">
                    <div class="page">

                        <!-- Report header -->
                        <div style="margin-bottom: 24px;">
                            <h2 style="margin: 0; font-size: 16pt; font-weight: 700; color: #1a1a2e;">
                                Salary Report
                            </h2>
                            <p style="margin: 4px 0 0 0; font-size: 9pt; color: #6b7280;">
                                Period: <strong><t t-esc="report.date_from"/> — <t t-esc="report.date_to"/></strong>
                                <t t-if="report.department_id">
                                     |  Department: <strong><t t-esc="report.department_id.name"/></strong>
                                </t>
                                <t t-if="report.work_location_id">
                                     |  Work Location: <strong><t t-esc="report.work_location_id.name"/></strong>
                                </t>
                                 |  Generated: <t t-esc="report.generated_on"/>
                            </p>
                        </div>

                        <!-- Main table -->
                        <table style="width: 100%; border-collapse: collapse; font-size: 9pt;">
                            <thead>
                                <tr style="background-color: #1a1a2e; color: #ffffff;">
                                    <th style="padding: 8px 10px; text-align: left; font-weight: 700; border: 1px solid #1a1a2e;">#</th>
                                    <th style="padding: 8px 10px; text-align: left; font-weight: 700; border: 1px solid #1a1a2e;">Employee</th>
                                    <th style="padding: 8px 10px; text-align: left; font-weight: 700; border: 1px solid #1a1a2e;">Department</th>
                                    <th style="padding: 8px 10px; text-align: left; font-weight: 700; border: 1px solid #1a1a2e;">Work Location</th>
                                    <th style="padding: 8px 10px; text-align: right; font-weight: 700; border: 1px solid #1a1a2e;">Gross Salary</th>
                                    <th style="padding: 8px 10px; text-align: right; font-weight: 700; border: 1px solid #1a1a2e;">Deductions</th>
                                    <th style="padding: 8px 10px; text-align: right; font-weight: 700; border: 1px solid #1a1a2e;">Reimbursements</th>
                                    <th style="padding: 8px 10px; text-align: right; font-weight: 700; border: 1px solid #1a1a2e;">Net Salary</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="row_num" t-value="0"/>
                                <t t-foreach="report.line_ids" t-as="line">
                                    <t t-set="row_num" t-value="row_num + 1"/>
                                    <tr t-attf-style="background-color: {{ '#f8fafc' if row_num % 2 == 0 else '#ffffff' }};">
                                        <td style="padding: 7px 10px; border: 1px solid #e2e8f0; color: #94a3b8; font-size: 8pt;">
                                            <t t-esc="row_num"/>
                                        </td>
                                        <td style="padding: 7px 10px; border: 1px solid #e2e8f0; font-weight: 600; color: #1e293b;">
                                            <t t-esc="line.employee_id.name"/>
                                        </td>
                                        <td style="padding: 7px 10px; border: 1px solid #e2e8f0; color: #475569;">
                                            <t t-esc="line.department_id.name or '—'"/>
                                        </td>
                                        <td style="padding: 7px 10px; border: 1px solid #e2e8f0; color: #475569;">
                                            <t t-esc="line.work_location_id.name or '—'"/>
                                        </td>
                                        <td style="padding: 7px 10px; border: 1px solid #e2e8f0; text-align: right; font-family: monospace; color: #334155;">
                                            <t t-esc="'{:,.2f}'.format(line.gross_salary)"/>
                                        </td>
                                        <td t-attf-style="padding: 7px 10px; border: 1px solid #e2e8f0; text-align: right; font-family: monospace; color: {{ '#dc2626' if (line.attendance_deduction + line.other_deductions) > 0 else '#94a3b8' }};">
                                            <t t-if="(line.attendance_deduction + line.other_deductions) > 0">
                                                (<t t-esc="'{:,.2f}'.format(line.attendance_deduction + line.other_deductions)"/>)
                                            </t>
                                            <t t-else="">—</t>
                                        </td>
                                        <td t-attf-style="padding: 7px 10px; border: 1px solid #e2e8f0; text-align: right; font-family: monospace; color: {{ '#16a34a' if line.reimbursements > 0 else '#94a3b8' }};">
                                            <t t-if="line.reimbursements > 0">
                                                <t t-esc="'{:,.2f}'.format(line.reimbursements)"/>
                                            </t>
                                            <t t-else="">—</t>
                                        </td>
                                        <td style="padding: 7px 10px; border: 1px solid #e2e8f0; text-align: right; font-family: monospace; font-weight: 700; color: #1e293b;">
                                            <t t-esc="'{:,.2f}'.format(line.net_salary)"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>

                            <!-- Totals row -->
                            <tfoot>
                                <tr style="background-color: #1a1a2e; color: #ffffff; font-weight: 700;">
                                    <td colspan="4" style="padding: 8px 10px; border: 1px solid #1a1a2e; font-size: 8pt; letter-spacing: 0.05em;">
                                        TOTAL — <t t-esc="report.total_employees"/> Employees
                                    </td>
                                    <td style="padding: 8px 10px; border: 1px solid #1a1a2e; text-align: right; font-family: monospace;">
                                        <t t-esc="'{:,.2f}'.format(report.total_gross_salary)"/>
                                    </td>
                                    <td style="padding: 8px 10px; border: 1px solid #1a1a2e; text-align: right; font-family: monospace;">
                                        (<t t-esc="'{:,.2f}'.format(report.total_attendance_deductions + report.total_other_deductions)"/>)
                                    </td>
                                    <td style="padding: 8px 10px; border: 1px solid #1a1a2e; text-align: right; font-family: monospace;">
                                        <t t-esc="'{:,.2f}'.format(report.total_reimbursements)"/>
                                    </td>
                                    <td style="padding: 8px 10px; border: 1px solid #1a1a2e; text-align: right; font-family: monospace;">
                                        <t t-esc="'{:,.2f}'.format(report.total_net_salary)"/>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- Currency note -->
                        <p style="margin-top: 12px; font-size: 7.5pt; color: #94a3b8;">
                            All amounts in <t t-esc="report.currency_id.name or 'SAR'"/>.
                            Deductions include attendance shortfalls, absent days, and other deductions.
                            This report is generated automatically and does not constitute a payslip.
                        </p>

                    </div>
                </t>
            </t>
        </t>
    </template>


</odoo>

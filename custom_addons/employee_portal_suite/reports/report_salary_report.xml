<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <template id="report_salary_summary_template">
        <t t-name="employee_portal_suite.report_salary_summary_template">
            <t t-call="web.external_layout">
                <t t-foreach="docs" t-as="report">
                    <div class="page">

                        <!-- Report title and period -->
                        <div style="margin-bottom: 20px;">
                            <h2 style="margin: 0; font-size: 15pt; font-weight: 700;">
                                Salary Report
                            </h2>
                            <p style="margin: 4px 0 0 0; font-size: 9pt; color: #555;">
                                Period:
                                <strong><t t-esc="report.date_from"/> to <t t-esc="report.date_to"/></strong>
                                <t t-if="report.department_id">
                                    &#160;|&#160; Department: <strong><t t-esc="report.department_id.name"/></strong>
                                </t>
                                <t t-if="report.generated_on">
                                    &#160;|&#160; Generated: <t t-esc="report.generated_on"/>
                                </t>
                            </p>
                        </div>

                        <!-- Main table -->
                        <table style="width: 100%; border-collapse: collapse; font-size: 9pt;">
                            <thead>
                                <tr style="background-color: #1e293b; color: #ffffff;">
                                    <th style="padding: 8px 10px; text-align: left; border: 1px solid #1e293b;">#</th>
                                    <th style="padding: 8px 10px; text-align: left; border: 1px solid #1e293b;">Employee</th>
                                    <th style="padding: 8px 10px; text-align: left; border: 1px solid #1e293b;">Department</th>
                                    <th style="padding: 8px 10px; text-align: right; border: 1px solid #1e293b;">Gross Salary</th>
                                    <th style="padding: 8px 10px; text-align: right; border: 1px solid #1e293b;">Deductions</th>
                                    <th style="padding: 8px 10px; text-align: right; border: 1px solid #1e293b;">Reimbursements</th>
                                    <th style="padding: 8px 10px; text-align: right; border: 1px solid #1e293b;">Net Salary</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="row_num" t-value="0"/>
                                <t t-foreach="report.line_ids" t-as="line">
                                    <t t-set="row_num" t-value="row_num + 1"/>
                                    <t t-set="total_ded" t-value="line.attendance_deduction + line.other_deductions"/>
                                    <tr t-att-style="'background-color: %s;' % ('#f8fafc' if row_num % 2 == 0 else '#ffffff')">
                                        <td style="padding: 7px 10px; border: 1px solid #e2e8f0; color: #94a3b8; font-size: 8pt;">
                                            <t t-esc="row_num"/>
                                        </td>
                                        <td style="padding: 7px 10px; border: 1px solid #e2e8f0; font-weight: 600;">
                                            <t t-esc="line.employee_id.name"/>
                                        </td>
                                        <td style="padding: 7px 10px; border: 1px solid #e2e8f0; color: #475569;">
                                            <t t-if="line.department_id">
                                                <t t-esc="line.department_id.name"/>
                                            </t>
                                            <t t-else="">&#8212;</t>
                                        </td>
                                        <td style="padding: 7px 10px; border: 1px solid #e2e8f0; text-align: right; font-family: monospace;">
                                            <t t-esc="'{:,.2f}'.format(line.gross_salary)"/>
                                        </td>
                                        <td t-att-style="'padding: 7px 10px; border: 1px solid #e2e8f0; text-align: right; font-family: monospace; color: %s;' % ('#dc2626' if total_ded > 0 else '#94a3b8')">
                                            <t t-if="total_ded &gt; 0">
                                                (<t t-esc="'{:,.2f}'.format(total_ded)"/>)
                                            </t>
                                            <t t-else="">&#8212;</t>
                                        </td>
                                        <td t-att-style="'padding: 7px 10px; border: 1px solid #e2e8f0; text-align: right; font-family: monospace; color: %s;' % ('#16a34a' if line.reimbursements > 0 else '#94a3b8')">
                                            <t t-if="line.reimbursements &gt; 0">
                                                <t t-esc="'{:,.2f}'.format(line.reimbursements)"/>
                                            </t>
                                            <t t-else="">&#8212;</t>
                                        </td>
                                        <td style="padding: 7px 10px; border: 1px solid #e2e8f0; text-align: right; font-family: monospace; font-weight: 700;">
                                            <t t-esc="'{:,.2f}'.format(line.net_salary)"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr style="background-color: #1e293b; color: #ffffff; font-weight: 700;">
                                    <td colspan="3" style="padding: 8px 10px; border: 1px solid #1e293b; font-size: 8pt; letter-spacing: 0.05em;">
                                        TOTAL &#8212; <t t-esc="report.total_employees"/> Employees
                                    </td>
                                    <td style="padding: 8px 10px; border: 1px solid #1e293b; text-align: right; font-family: monospace;">
                                        <t t-esc="'{:,.2f}'.format(report.total_gross_salary)"/>
                                    </td>
                                    <td style="padding: 8px 10px; border: 1px solid #1e293b; text-align: right; font-family: monospace;">
                                        (<t t-esc="'{:,.2f}'.format(report.total_attendance_deductions + report.total_other_deductions)"/>)
                                    </td>
                                    <td style="padding: 8px 10px; border: 1px solid #1e293b; text-align: right; font-family: monospace;">
                                        <t t-esc="'{:,.2f}'.format(report.total_reimbursements)"/>
                                    </td>
                                    <td style="padding: 8px 10px; border: 1px solid #1e293b; text-align: right; font-family: monospace;">
                                        <t t-esc="'{:,.2f}'.format(report.total_net_salary)"/>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>

                        <p style="margin-top: 12px; font-size: 7.5pt; color: #94a3b8;">
                            All amounts in <t t-esc="report.currency_id.name or 'SAR'"/>.
                            Deductions include attendance shortfalls, absent days, and other deductions.
                            This report is automatically generated and does not constitute a payslip.
                        </p>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>

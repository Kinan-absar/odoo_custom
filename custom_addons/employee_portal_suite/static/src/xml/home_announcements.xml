<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-inherit="web_enterprise.HomeMenu" t-inherit-mode="extension">
        <xpath expr="//div[contains(@class, 'o_home_menu')]" position="inside">
            <div class="eps_backend_announcements"
                 t-if="backendAnnouncementState and backendAnnouncementState.announcements.length">
                <t t-foreach="backendAnnouncementState.announcements" t-as="ann" t-key="ann.id">
                    <div t-attf-class="eps_backend_announcement_card eps_backend_announcement_#{ann.type or 'info'}">
                        <div class="eps_backend_announcement_title">
                            <span class="eps_backend_announcement_icon">📢</span>
                            <t t-esc="ann.title"/>
                        </div>
                        <div class="eps_backend_announcement_message" t-if="ann.message">
                            <t t-esc="ann.message"/>
                        </div>
                        <div class="eps_backend_announcement_links" t-if="ann.links and ann.links.length">
                            <t t-foreach="ann.links" t-as="link" t-key="link.url">
                                <a t-att-href="link.url"
                                   target="_blank"
                                   rel="noopener noreferrer"
                                   class="btn btn-primary btn-sm eps_backend_announcement_link">
                                    <t t-esc="link.label"/>
                                </a>
                            </t>
                        </div>
                    </div>
                </t>
            </div>
        </xpath>
    </t>

</templates>

<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-inherit="web_enterprise.HomeMenu" t-inherit-mode="extension">
        <xpath expr="//div[contains(@class,'o_home_menu')]" position="inside">

            <div class="eps_panel" t-if="annState and annState.announcements.length">

                <!-- ── Top bar ── -->
                <div class="eps_panel_topbar">
                    <span class="eps_panel_label">
                        <span class="eps_panel_label_icon">📢</span>
                        Announcements
                    </span>
                    <span class="eps_panel_counter">
                        <t t-esc="annState.activeIndex + 1"/>/<t t-esc="annState.announcements.length"/>
                    </span>
                </div>

                <!-- ── Active card ── -->
                <t t-set="ann" t-value="annState.announcements[annState.activeIndex]"/>
                <div t-attf-class="eps_card eps_card_#{ann.type or 'info'}">
                    <div class="eps_card_accent"/>
                    <div class="eps_card_body">
                        <div class="eps_card_title">
                            <t t-esc="ann.title"/>
                        </div>
                        <div class="eps_card_message">
                            <t t-out="ann.message"/>
                        </div>
                    </div>
                </div>

                <!-- ── Navigation ── -->
                <div class="eps_nav" t-if="annState.announcements.length > 1">
                    <button class="eps_nav_btn" t-on-click="annPrev">&#8592;</button>

                    <div class="eps_nav_dots">
                        <t t-foreach="annState.announcements" t-as="a" t-key="a.id">
                            <span t-attf-class="eps_dot #{annState.activeIndex === a_index ? 'eps_dot_active' : ''}"
                                  t-on-click="() => this.annSetActive(a_index)"/>
                        </t>
                    </div>

                    <button class="eps_nav_btn" t-on-click="annNext">&#8594;</button>
                </div>

            </div>

        </xpath>
    </t>

</templates>

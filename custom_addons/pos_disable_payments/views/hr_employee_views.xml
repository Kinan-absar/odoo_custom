<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── HR Employee: add POS Access Rights tab ────────────────────────── -->
    <record id="view_employee_form_pos_disable_payments" model="ir.ui.view">
        <field name="name">hr.employee.form.pos.disable.payments</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="POS Access Rights" name="pos_access_rights">
                    <group string="Point of Sale Feature Access">
                        <group string="Transaction">
                            <field name="pos_allow_payment"/>
                            <field name="pos_allow_discount"/>
                            <field name="pos_allow_edit_price"/>
                        </group>
                        <group string="Order Management">
                            <field name="pos_allow_qty"/>
                            <field name="pos_allow_remove_line"/>
                            <field name="pos_allow_customer"/>
                        </group>
                        <group string="Interface">
                            <field name="pos_allow_numpad"/>
                            <field name="pos_allow_plus_minus"/>
                        </group>
                    </group>
                    <div class="alert alert-warning" role="alert">
                        <strong>Note:</strong> These settings are used only when this employee has
                        <em>no linked Odoo user</em>. If a related user exists, that user's
                        POS Access Rights take priority.
                    </div>
                </page>
            </notebook>
        </field>
    </record>

</odoo>

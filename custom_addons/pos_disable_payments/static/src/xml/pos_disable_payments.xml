<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <!-- ── PaymentScreen: hide "Validate Payment" when not allowed ─────────── -->
    <t t-name="pos_disable_payments.PaymentScreenInherit" t-inherit="point_of_sale.PaymentScreen" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('payment-buttons')]" position="attributes">
            <attribute name="t-att-class">
                {'d-none': !component.isPaymentAllowed}
            </attribute>
        </xpath>
        <!-- Also disable the validate button -->
        <xpath expr="//button[hasclass('validate-button') or @class='button validation']" position="attributes">
            <attribute name="t-att-disabled">!component.isPaymentAllowed || undefined</attribute>
            <attribute name="t-att-class">
                {'d-none': !component.isPaymentAllowed}
            </attribute>
        </xpath>
    </t>

    <!-- ── ProductScreen: hide customer button when not allowed ────────────── -->
    <t t-name="pos_disable_payments.ProductScreenInherit" t-inherit="point_of_sale.ProductScreen" t-inherit-mode="extension">
        <!-- Customer button -->
        <xpath expr="//button[hasclass('customer-button')]" position="attributes">
            <attribute name="t-att-class">
                {'d-none': !component.canSelectCustomer}
            </attribute>
        </xpath>
        <!-- Discount field/button -->
        <xpath expr="//button[hasclass('discount-button')]" position="attributes">
            <attribute name="t-att-class">
                {'d-none': !component.canApplyDiscount}
            </attribute>
        </xpath>
    </t>

    <!-- ── NumpadWidget: disable numpad entirely when not allowed ───────────── -->
    <t t-name="pos_disable_payments.NumpadWidgetInherit" t-inherit="point_of_sale.Numpad" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('numpad')]" position="attributes">
            <attribute name="t-att-class">
                {'pos-numpad-disabled': !component.isNumpadAllowed}
            </attribute>
        </xpath>
    </t>

</templates>

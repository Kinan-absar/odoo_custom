<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_po_revision_inherit"
              inherit_id="purchase.report_purchaseorder_document">

        <!-- Purchase Order state -->
        <xpath expr="//t[@t-if=&quot;o.state in ['purchase', 'done']&quot;]/span[@t-field='o.name']" position="after">
            <t t-if="o.revision &gt; 0"> (R-<t t-esc="o.revision"/>)</t>
        </xpath>

        <!-- RFQ state -->
        <xpath expr="//t[@t-if=&quot;o.state in ['draft', 'sent', 'to approve']&quot;]/span[@t-field='o.name']" position="after">
            <t t-if="o.revision &gt; 0"> (R-<t t-esc="o.revision"/>)</t>
        </xpath>

    </template>
</odoo>

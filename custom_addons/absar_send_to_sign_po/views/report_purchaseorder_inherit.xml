<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_po_revision_inherit"
              inherit_id="purchase.report_purchaseorder_document">

        <!-- Add Revision right after the PO number (targets the name span directly) -->
        <xpath expr="//span[@t-field='o.name']" position="after">
            <span t-if="o.revision &gt; 0" style="margin-left:4px;">
                (R-<t t-esc="o.revision"/>)
            </span>
        </xpath>

    </template>
</odoo>

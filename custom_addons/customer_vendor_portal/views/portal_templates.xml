<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- ================================================================
     INJECT VENDOR BUTTONS into default portal home (portal_my_home)
     Only My Invoices + Upload Invoice — no PO button
     ================================================================ -->
<template id="vendor_buttons" inherit_id="portal.portal_my_home">
    <xpath expr="//div[@id='portal_vendor_category']" position="inside">
        <t t-if="request.env.user.partner_id.supplier_rank > 0">
            <div class="col-md-6 mb-3">
                <a href="/vendor/invoices" class="btn btn-secondary w-100">
                    <i class="fa fa-file-text-o me-1"/> <span t-translate="yes">My Invoices</span>
                </a>
            </div>
            <div class="col-md-6 mb-3">
                <a href="/vendor/invoice/upload" class="btn btn-info w-100">
                    <i class="fa fa-upload me-1"/> <span t-translate="yes">Upload Invoice</span>
                </a>
            </div>
        </t>
    </xpath>
</template>

<!-- ================================================================
     HIDE CUSTOMER SECTIONS FOR VENDORS
     ================================================================ -->
<template id="hide_customer_category" inherit_id="portal.portal_my_home">
    <xpath expr="//div[@id='portal_client_category']" position="attributes">
        <attribute name="t-if">not request.env.user.partner_id.supplier_rank > 0</attribute>
    </xpath>
</template>

<!-- ================================================================
     HIDE VENDOR CATEGORY FROM NON-VENDORS
     ================================================================ -->
<template id="hide_vendor_category" inherit_id="portal.portal_my_home">
    <xpath expr="//div[@id='portal_vendor_category']" position="attributes">
        <attribute name="t-if">request.env.user.partner_id.supplier_rank > 0</attribute>
    </xpath>
</template>

<!-- ================================================================
     VENDOR DASHBOARD  — at /vendor/dashboard
     ================================================================ -->
<template id="vendor_dashboard" name="Vendor Dashboard">
    <t t-call="portal.portal_layout">
        <div class="vp-page">
            <div class="container">

                <!-- Page header -->
                <div class="vp-page-header mb-4">
                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                        <div>
                            <h2 class="mb-1">
                                <i class="fa fa-tachometer me-2"/>
                                <span t-translate="yes">Vendor Dashboard</span>
                            </h2>
                            <p class="mb-0 opacity-75">
                                <span t-translate="yes">Welcome back,</span>
                                <strong> <t t-esc="partner.name"/></strong>
                            </p>
                        </div>
                        <a href="/vendor/invoice/upload" class="vp-btn vp-btn-success align-self-start">
                            <i class="fa fa-plus"/> <span t-translate="yes">Upload Invoice</span>
                        </a>
                    </div>
                </div>

                <!-- Stats row -->
                <div class="row g-3 mb-4">
                    <div class="col-6 col-md-4 col-lg-2">
                        <div class="vp-stat-card accent-navy">
                            <div class="vp-stat-icon"><i class="fa fa-files-o"/></div>
                            <div class="vp-stat-value"><t t-esc="stats['total']"/></div>
                            <div class="vp-stat-label" t-translate="yes">Total</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg-2">
                        <div class="vp-stat-card accent-blue">
                            <div class="vp-stat-icon"><i class="fa fa-paper-plane"/></div>
                            <div class="vp-stat-value"><t t-esc="stats['submitted']"/></div>
                            <div class="vp-stat-label" t-translate="yes">Submitted</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg-2">
                        <div class="vp-stat-card accent-orange">
                            <div class="vp-stat-icon"><i class="fa fa-hourglass-half"/></div>
                            <div class="vp-stat-value"><t t-esc="stats['review']"/></div>
                            <div class="vp-stat-label" t-translate="yes">Under Review</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg-2">
                        <div class="vp-stat-card accent-green">
                            <div class="vp-stat-icon"><i class="fa fa-check-circle"/></div>
                            <div class="vp-stat-value"><t t-esc="stats['approved']"/></div>
                            <div class="vp-stat-label" t-translate="yes">Approved</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg-2">
                        <div class="vp-stat-card accent-red">
                            <div class="vp-stat-icon"><i class="fa fa-times-circle"/></div>
                            <div class="vp-stat-value"><t t-esc="stats['rejected']"/></div>
                            <div class="vp-stat-label" t-translate="yes">Rejected</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg-2">
                        <div class="vp-stat-card accent-green">
                            <div class="vp-stat-icon"><i class="fa fa-money"/></div>
                            <div class="vp-stat-value" style="font-size:1.1rem;line-height:1.2">
                                <t t-esc="stats['currency'].symbol"/>
                                <t t-esc="'{:,.0f}'.format(stats['total_amount'])"/>
                            </div>
                            <div class="vp-stat-label" t-translate="yes">Approved Amt</div>
                        </div>
                    </div>
                </div>

                <!-- Quick actions -->
                <div class="row g-3 mb-4">
                    <div class="col-12">
                        <h6 class="text-uppercase fw-bold mb-2"
                            style="font-size:.75rem;letter-spacing:.08em;color:#6c757d"
                            t-translate="yes">Quick Actions</h6>
                    </div>
                    <div class="col-6 col-md-3">
                        <a href="/vendor/invoice/upload" class="vp-action-card">
                            <div class="vp-action-icon" style="background:#e8f5ee;color:#2e7d52">
                                <i class="fa fa-upload"/>
                            </div>
                            <span t-translate="yes">Upload Invoice</span>
                        </a>
                    </div>
                    <div class="col-6 col-md-3">
                        <a href="/vendor/invoices" class="vp-action-card">
                            <div class="vp-action-icon">
                                <i class="fa fa-list-alt"/>
                            </div>
                            <span t-translate="yes">All Invoices</span>
                        </a>
                    </div>
                    <div class="col-6 col-md-3">
                        <a href="/vendor/invoices?state=review" class="vp-action-card">
                            <div class="vp-action-icon" style="background:#fef3e8;color:#e67e22">
                                <i class="fa fa-hourglass-half"/>
                            </div>
                            <span t-translate="yes">Under Review</span>
                            <t t-if="stats['review']">
                                <small class="text-warning fw-bold">(<t t-esc="stats['review']"/>)</small>
                            </t>
                        </a>
                    </div>
                    <div class="col-6 col-md-3">
                        <a href="/my/account" class="vp-action-card">
                            <div class="vp-action-icon">
                                <i class="fa fa-user-circle-o"/>
                            </div>
                            <span t-translate="yes">My Profile</span>
                        </a>
                    </div>
                </div>

                <!-- Recent Invoices -->
                <div class="vp-card">
                    <div class="vp-card-header">
                        <h5><i class="fa fa-clock-o me-1"/> <span t-translate="yes">Recent Invoices</span></h5>
                        <a href="/vendor/invoices" class="vp-btn vp-btn-outline vp-btn-sm" t-translate="yes">View All</a>
                    </div>
                    <t t-if="recent_invoices">
                        <div class="table-responsive">
                            <table class="vp-invoice-table">
                                <thead>
                                    <tr>
                                        <th t-translate="yes">Reference</th>
                                        <th t-translate="yes">Invoice #</th>
                                        <th t-translate="yes">Date</th>
                                        <th t-translate="yes">Amount</th>
                                        <th t-translate="yes">Status</th>
                                        <th t-translate="yes">Comment</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="recent_invoices" t-as="inv">
                                        <tr class="vp-row-link"
                                            t-att-onclick="'window.location=\'/vendor/invoice/' + str(inv.id) + '\''">
                                            <td><strong><t t-esc="inv.name"/></strong></td>
                                            <td class="text-muted"><t t-esc="inv.vendor_invoice_number or '-'"/></td>
                                            <td><t t-esc="inv.invoice_date or '-'"/></td>
                                            <td style="white-space:nowrap">
                                                <t t-esc="inv.currency_id.symbol"/>&#160;<t t-esc="'{:,.2f}'.format(inv.amount_total)"/>
                                            </td>
                                            <td>
                                                <span t-attf-class="vp-badge vp-badge-#{inv.state}">
                                                    <t t-if="inv.state == 'submitted'" t-translate="yes">Submitted</t>
                                                    <t t-elif="inv.state == 'review'" t-translate="yes">Under Review</t>
                                                    <t t-elif="inv.state == 'approved'" t-translate="yes">Approved</t>
                                                    <t t-elif="inv.state == 'rejected'" t-translate="yes">Rejected</t>
                                                </span>
                                            </td>
                                            <td>
                                                <t t-if="inv.review_comment">
                                                    <span class="text-info"><i class="fa fa-comment" title="Has review comment"/></span>
                                                </t>
                                                <t t-else=""><span class="text-muted">—</span></t>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="vp-empty">
                            <div class="vp-empty-icon"><i class="fa fa-inbox"/></div>
                            <h5 t-translate="yes">No invoices yet</h5>
                            <p t-translate="yes">Submit your first invoice to get started.</p>
                            <a href="/vendor/invoice/upload" class="vp-btn vp-btn-primary mt-2">
                                <i class="fa fa-upload"/> <span t-translate="yes">Upload Invoice</span>
                            </a>
                        </div>
                    </t>
                </div>

            </div>
        </div>
    </t>
</template>

<!-- ================================================================
     VENDOR INVOICE LIST
     ================================================================ -->
<template id="vendor_invoice_list" name="Vendor Invoice List">
    <t t-call="portal.portal_layout">
        <div class="vp-page">
            <div class="container">

                <div class="vp-page-header mb-4">
                    <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
                        <div>
                            <h2><i class="fa fa-file-text-o me-2"/> <span t-translate="yes">My Invoices</span></h2>
                            <p class="mb-0" t-translate="yes">Track the status of all your submitted invoices.</p>
                        </div>
                        <a href="/vendor/invoice/upload" class="vp-btn vp-btn-success align-self-start">
                            <i class="fa fa-plus"/> <span t-translate="yes">Upload New Invoice</span>
                        </a>
                    </div>
                </div>

                <t t-if="submitted">
                    <div class="vp-success-banner mb-3">
                        <span class="icon"><i class="fa fa-check-circle"/></span>
                        <span t-translate="yes">Your invoice has been submitted successfully. We will review it shortly.</span>
                    </div>
                </t>

                <div class="d-flex gap-2 flex-wrap mb-3">
                    <a href="/vendor/invoices"
                       t-attf-class="vp-btn vp-btn-sm #{'vp-btn-primary' if not active_state else 'vp-btn-outline'}"
                       t-translate="yes">All</a>
                    <a href="/vendor/invoices?state=submitted"
                       t-attf-class="vp-btn vp-btn-sm #{'vp-btn-primary' if active_state == 'submitted' else 'vp-btn-outline'}"
                       t-translate="yes">Submitted</a>
                    <a href="/vendor/invoices?state=review"
                       t-attf-class="vp-btn vp-btn-sm #{'vp-btn-primary' if active_state == 'review' else 'vp-btn-outline'}"
                       t-translate="yes">Under Review</a>
                    <a href="/vendor/invoices?state=approved"
                       t-attf-class="vp-btn vp-btn-sm #{'vp-btn-primary' if active_state == 'approved' else 'vp-btn-outline'}"
                       t-translate="yes">Approved</a>
                    <a href="/vendor/invoices?state=rejected"
                       t-attf-class="vp-btn vp-btn-sm #{'vp-btn-primary' if active_state == 'rejected' else 'vp-btn-outline'}"
                       t-translate="yes">Rejected</a>
                </div>

                <div class="vp-card">
                    <t t-if="invoices">
                        <div class="table-responsive">
                            <table class="vp-invoice-table">
                                <thead>
                                    <tr>
                                        <th t-translate="yes">Reference</th>
                                        <th t-translate="yes">Invoice #</th>
                                        <th t-translate="yes">Purchase Order</th>
                                        <th t-translate="yes">Date</th>
                                        <th t-translate="yes">Amount</th>
                                        <th t-translate="yes">Status</th>
                                        <th t-translate="yes">Comment</th>
                                        <th/>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="invoices" t-as="inv">
                                        <tr class="vp-row-link"
                                            t-att-onclick="'window.location=\'/vendor/invoice/' + str(inv.id) + '\''">
                                            <td><strong><t t-esc="inv.name"/></strong></td>
                                            <td class="text-muted"><t t-esc="inv.vendor_invoice_number or '-'"/></td>
                                            <td><t t-esc="inv.po_id.name if inv.po_id else '-'"/></td>
                                            <td><t t-esc="inv.invoice_date or '-'"/></td>
                                            <td style="white-space:nowrap">
                                                <t t-esc="inv.currency_id.symbol"/>&#160;<t t-esc="'{:,.2f}'.format(inv.amount_total)"/>
                                            </td>
                                            <td>
                                                <span t-attf-class="vp-badge vp-badge-#{inv.state}">
                                                    <t t-if="inv.state == 'submitted'" t-translate="yes">Submitted</t>
                                                    <t t-elif="inv.state == 'review'" t-translate="yes">Under Review</t>
                                                    <t t-elif="inv.state == 'approved'" t-translate="yes">Approved</t>
                                                    <t t-elif="inv.state == 'rejected'" t-translate="yes">Rejected</t>
                                                </span>
                                            </td>
                                            <td>
                                                <t t-if="inv.review_comment">
                                                    <span class="text-info"><i class="fa fa-comment"/></span>
                                                </t>
                                            </td>
                                            <td>
                                                <a t-attf-href="/vendor/invoice/#{inv.id}"
                                                   class="vp-btn vp-btn-outline vp-btn-sm"
                                                   onclick="event.stopPropagation()">
                                                    <i class="fa fa-eye"/>
                                                </a>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                        <div class="p-3"><t t-call="portal.pager"/></div>
                    </t>
                    <t t-else="">
                        <div class="vp-empty">
                            <div class="vp-empty-icon"><i class="fa fa-inbox"/></div>
                            <h5 t-translate="yes">No invoices found</h5>
                            <p t-translate="yes">No invoices match your current filter.</p>
                            <a href="/vendor/invoice/upload" class="vp-btn vp-btn-primary mt-2">
                                <i class="fa fa-upload"/> <span t-translate="yes">Upload Invoice</span>
                            </a>
                        </div>
                    </t>
                </div>

            </div>
        </div>
    </t>
</template>

<!-- ================================================================
     VENDOR INVOICE DETAIL  — no download button, no supplier field
     ================================================================ -->
<template id="vendor_invoice_detail" name="Vendor Invoice Detail">
    <t t-call="portal.portal_layout">
        <div class="vp-page">
            <div class="container">

                <nav class="mb-3">
                    <a href="/vendor/invoices" class="text-muted" style="font-size:.88rem">
                        <i class="fa fa-arrow-left me-1"/> <span t-translate="yes">Back to Invoices</span>
                    </a>
                </nav>

                <!-- Hero -->
                <div class="vp-detail-hero mb-3">
                    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                        <div>
                            <div class="invoice-ref"><t t-esc="invoice.name"/></div>
                            <div class="invoice-amount">
                                <t t-esc="invoice.currency_id.symbol"/>&#160;<t t-esc="'{:,.2f}'.format(invoice.amount_total)"/>
                            </div>
                            <div class="invoice-meta">
                                <span t-translate="yes">Invoice #</span><t t-esc="invoice.vendor_invoice_number or '-'"/>
                                &#160;·&#160;
                                <t t-esc="invoice.invoice_date or '-'"/>
                                <t t-if="invoice.po_id">
                                    &#160;·&#160; PO: <t t-esc="invoice.po_id.name"/>
                                </t>
                            </div>
                        </div>
                        <span t-attf-class="vp-badge vp-badge-#{invoice.state}"
                              style="font-size:.9rem;padding:.4rem 1rem;align-self:flex-start">
                            <t t-if="invoice.state == 'submitted'" t-translate="yes">Submitted</t>
                            <t t-elif="invoice.state == 'review'" t-translate="yes">Under Review</t>
                            <t t-elif="invoice.state == 'approved'" t-translate="yes">Approved</t>
                            <t t-elif="invoice.state == 'rejected'" t-translate="yes">Rejected</t>
                        </span>
                    </div>
                </div>

                <!-- Progress tracker -->
                <div class="vp-card mb-3">
                    <div class="vp-card-header">
                        <h5><i class="fa fa-road me-1"/> <span t-translate="yes">Invoice Progress</span></h5>
                    </div>
                    <div class="vp-card-body">
                        <div class="vp-tracker">
                            <div t-attf-class="vp-tracker-step #{'done' if invoice.state in ('review','approved') else 'active'}">
                                <div class="step-dot">
                                    <t t-if="invoice.state in ('review','approved')"><i class="fa fa-check"/></t>
                                    <t t-else="">1</t>
                                </div>
                                <div class="step-label" t-translate="yes">Submitted</div>
                            </div>
                            <div t-attf-class="vp-tracker-line #{'done' if invoice.state in ('review','approved') else ''}"/>
                            <div t-attf-class="vp-tracker-step #{'done' if invoice.state == 'approved' else ('active' if invoice.state == 'review' else ('rejected' if invoice.state == 'rejected' else ''))}">
                                <div class="step-dot">
                                    <t t-if="invoice.state == 'approved'"><i class="fa fa-check"/></t>
                                    <t t-elif="invoice.state == 'rejected'"><i class="fa fa-times"/></t>
                                    <t t-else="">2</t>
                                </div>
                                <div class="step-label" t-translate="yes">Under Review</div>
                            </div>
                            <div t-attf-class="vp-tracker-line #{'done' if invoice.state == 'approved' else ''}"/>
                            <div t-attf-class="vp-tracker-step #{'done' if invoice.state == 'approved' else ('rejected' if invoice.state == 'rejected' else '')}">
                                <div class="step-dot">
                                    <t t-if="invoice.state == 'approved'"><i class="fa fa-check"/></t>
                                    <t t-elif="invoice.state == 'rejected'"><i class="fa fa-times"/></t>
                                    <t t-else="">3</t>
                                </div>
                                <div class="step-label">
                                    <t t-if="invoice.state == 'rejected'" t-translate="yes">Rejected</t>
                                    <t t-else="" t-translate="yes">Approved</t>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-lg-7">
                        <div class="vp-card mb-3">
                            <div class="vp-card-header">
                                <h5><i class="fa fa-info-circle me-1"/> <span t-translate="yes">Invoice Details</span></h5>
                            </div>
                            <div class="vp-card-body">
                                <div class="vp-info-grid">
                                    <div class="vp-info-item">
                                        <div class="vp-info-label" t-translate="yes">Reference</div>
                                        <div class="vp-info-value"><t t-esc="invoice.name"/></div>
                                    </div>
                                    <div class="vp-info-item">
                                        <div class="vp-info-label" t-translate="yes">Invoice Number</div>
                                        <div class="vp-info-value"><t t-esc="invoice.vendor_invoice_number or '-'"/></div>
                                    </div>
                                    <div class="vp-info-item">
                                        <div class="vp-info-label" t-translate="yes">Date</div>
                                        <div class="vp-info-value"><t t-esc="invoice.invoice_date or '-'"/></div>
                                    </div>
                                    <div class="vp-info-item">
                                        <div class="vp-info-label" t-translate="yes">Amount</div>
                                        <div class="vp-info-value">
                                            <t t-esc="invoice.currency_id.symbol"/>&#160;<t t-esc="'{:,.2f}'.format(invoice.amount_total)"/>
                                        </div>
                                    </div>
                                    <t t-if="invoice.po_id">
                                        <div class="vp-info-item">
                                            <div class="vp-info-label" t-translate="yes">Purchase Order</div>
                                            <div class="vp-info-value"><t t-esc="invoice.po_id.name"/></div>
                                        </div>
                                    </t>
                                    <div class="vp-info-item">
                                        <div class="vp-info-label" t-translate="yes">Submitted On</div>
                                        <div class="vp-info-value">
                                            <t t-esc="invoice.create_date.strftime('%d %b %Y') if invoice.create_date else '-'"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <t t-if="invoice.notes">
                            <div class="vp-card">
                                <div class="vp-card-header">
                                    <h5><i class="fa fa-sticky-note-o me-1"/> <span t-translate="yes">Your Notes</span></h5>
                                </div>
                                <div class="vp-card-body">
                                    <p style="white-space:pre-line;font-size:.94rem;color:#2d3748;margin:0">
                                        <t t-esc="invoice.notes"/>
                                    </p>
                                </div>
                            </div>
                        </t>
                    </div>

                    <!-- Review comments -->
                    <div class="col-lg-5">
                        <div class="vp-card">
                            <div class="vp-card-header">
                                <h5><i class="fa fa-comments me-1"/> <span t-translate="yes">Review Comments</span></h5>
                            </div>
                            <div class="vp-card-body">
                                <t t-if="invoice.review_comment">
                                    <div t-attf-class="vp-comment #{'vp-comment-warning' if invoice.state == 'rejected' else ''}">
                                        <div class="vp-comment-meta">
                                            <i class="fa fa-user-circle-o me-1"/>
                                            <span t-translate="yes">Review Team</span>
                                            <t t-if="invoice.write_date">
                                                &#160;·&#160;<t t-esc="invoice.write_date.strftime('%d %b %Y')"/>
                                            </t>
                                        </div>
                                        <div class="vp-comment-text"><t t-esc="invoice.review_comment"/></div>
                                    </div>
                                </t>
                                <t t-else="">
                                    <div class="vp-empty" style="padding:2rem .5rem">
                                        <div class="vp-empty-icon" style="font-size:2rem"><i class="fa fa-comment-o"/></div>
                                        <p style="font-size:.88rem;color:#adb5bd" t-translate="yes">
                                            No comments yet. Our team will leave feedback here once review begins.
                                        </p>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </t>
</template>

<!-- ================================================================
     VENDOR INVOICE UPLOAD FORM
     ================================================================ -->
<template id="vendor_invoice_upload_form" name="Vendor Invoice Upload Form">
    <t t-call="portal.portal_layout">
        <div class="vp-page">
            <div class="container" style="max-width:760px">

                <div class="vp-page-header mb-4">
                    <h2><i class="fa fa-upload me-2"/> <span t-translate="yes">Upload Invoice</span></h2>
                    <p class="mb-0" t-translate="yes">Fill in the details below and attach your invoice document.</p>
                </div>

                <t t-if="error_message">
                    <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2">
                        <i class="fa fa-exclamation-circle"/>
                        <span><t t-esc="error_message"/></span>
                        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"/>
                    </div>
                </t>

                <form action="/vendor/invoice/upload" method="POST" enctype="multipart/form-data" class="vp-form-card">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <div class="vp-form-section">
                        <div class="vp-form-section-title">
                            <i class="fa fa-file-text"/> <span t-translate="yes">Invoice Details</span>
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="vp-form-label" t-translate="yes">Invoice Number <span class="text-danger">*</span></label>
                                <input type="text" name="vendor_invoice_number" class="form-control vp-form-control"
                                       required="required" placeholder="e.g. INV-2025-001"
                                       t-att-value="form_data.get('vendor_invoice_number','') if form_data else ''"/>
                            </div>
                            <div class="col-md-6">
                                <label class="vp-form-label" t-translate="yes">Invoice Date <span class="text-danger">*</span></label>
                                <input type="date" name="invoice_date" class="form-control vp-form-control"
                                       required="required"
                                       t-att-value="form_data.get('invoice_date','') if form_data else ''"/>
                            </div>
                            <div class="col-md-6">
                                <label class="vp-form-label" t-translate="yes">Total Amount <span class="text-danger">*</span></label>
                                <input type="number" name="amount_total" class="form-control vp-form-control"
                                       required="required" step="0.01" min="0" placeholder="0.00"
                                       t-att-value="form_data.get('amount_total','') if form_data else ''"/>
                            </div>
                            <div class="col-md-6">
                                <label class="vp-form-label" t-translate="yes">Related Purchase Order</label>
                                <select class="form-control vp-form-control" name="po_id">
                                    <option value="0" t-translate="yes">— None / Not Applicable —</option>
                                    <t t-foreach="purchase_orders" t-as="po">
                                        <option t-att-value="po.id"><t t-esc="po.name"/></option>
                                    </t>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="vp-form-section">
                        <div class="vp-form-section-title">
                            <i class="fa fa-sticky-note-o"/> <span t-translate="yes">Notes (Optional)</span>
                        </div>
                        <textarea name="notes" class="form-control vp-form-control" rows="3"
                                  placeholder="Any additional information for our team..."><t t-if="form_data" t-esc="form_data.get('notes','')"/></textarea>
                    </div>

                    <div class="vp-form-section">
                        <div class="vp-form-section-title">
                            <i class="fa fa-paperclip"/> <span t-translate="yes">Invoice Document <span class="text-danger">*</span></span>
                        </div>
                        <div class="vp-dropzone" id="vpDropzone">
                            <input type="file" name="invoice_file" id="vpFileInput"
                                   required="required" accept=".pdf,.jpg,.jpeg,.png"/>
                            <div class="vp-dropzone-icon"><i class="fa fa-cloud-upload"/></div>
                            <div class="vp-dropzone-text" id="vpDropText" t-translate="yes">Click to browse or drag &amp; drop</div>
                            <div class="vp-dropzone-hint" t-translate="yes">PDF, JPG, PNG — Max 10 MB</div>
                        </div>
                    </div>

                    <div class="d-flex align-items-center justify-content-between mt-3 flex-wrap gap-2">
                        <a href="/vendor/invoices" class="vp-btn vp-btn-outline">
                            <i class="fa fa-arrow-left"/> <span t-translate="yes">Cancel</span>
                        </a>
                        <button type="submit" class="vp-btn vp-btn-success">
                            <i class="fa fa-paper-plane"/> <span t-translate="yes">Submit Invoice</span>
                        </button>
                    </div>
                </form>

                <script>
                (function() {
                    var inp = document.getElementById('vpFileInput');
                    var txt = document.getElementById('vpDropText');
                    var zone = document.getElementById('vpDropzone');
                    if (!inp) return;
                    inp.addEventListener('change', function() {
                        if (inp.files.length) {
                            txt.textContent = inp.files[0].name;
                            zone.style.borderColor = 'var(--vp-accent)';
                        }
                    });
                    ['dragover','dragenter'].forEach(function(e) {
                        zone.addEventListener(e, function(ev) { ev.preventDefault(); zone.classList.add('drag-over'); });
                    });
                    ['dragleave','drop'].forEach(function(e) {
                        zone.addEventListener(e, function() { zone.classList.remove('drag-over'); });
                    });
                })();
                </script>
            </div>
        </div>
    </t>
</template>

<!-- ================================================================
     VENDOR PO LIST
     ================================================================ -->
<template id="vendor_po_list" name="Vendor Purchase Orders">
    <t t-call="portal.portal_layout">
        <div class="vp-page">
            <div class="container">
                <div class="vp-page-header mb-4">
                    <h2><i class="fa fa-shopping-cart me-2"/> <span t-translate="yes">Purchase Orders</span></h2>
                    <p class="mb-0" t-translate="yes">Confirmed purchase orders issued to your company.</p>
                </div>
                <div class="vp-card">
                    <t t-if="pos">
                        <div class="table-responsive">
                            <table class="vp-invoice-table">
                                <thead>
                                    <tr>
                                        <th t-translate="yes">PO Number</th>
                                        <th t-translate="yes">Date</th>
                                        <th t-translate="yes">Amount</th>
                                        <th t-translate="yes">Status</th>
                                        <th/>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="pos" t-as="po">
                                        <tr>
                                            <td><strong><t t-esc="po.name"/></strong></td>
                                            <td><t t-esc="po.date_approve or po.date_order or '-'"/></td>
                                            <td><t t-esc="po.currency_id.symbol"/>&#160;<t t-esc="'{:,.2f}'.format(po.amount_total)"/></td>
                                            <td>
                                                <span class="vp-badge vp-badge-approved" t-if="po.state == 'done'" t-translate="yes">Done</span>
                                                <span class="vp-badge vp-badge-submitted" t-else="" t-translate="yes">Confirmed</span>
                                            </td>
                                            <td>
                                                <a t-attf-href="/vendor/po/#{po.id}" class="vp-btn vp-btn-outline vp-btn-sm">
                                                    <i class="fa fa-eye"/>
                                                </a>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                        <div class="p-3"><t t-call="portal.pager"/></div>
                    </t>
                    <t t-else="">
                        <div class="vp-empty">
                            <div class="vp-empty-icon"><i class="fa fa-shopping-cart"/></div>
                            <h5 t-translate="yes">No purchase orders</h5>
                            <p t-translate="yes">No confirmed purchase orders found for your account.</p>
                        </div>
                    </t>
                </div>
            </div>
        </div>
    </t>
</template>

<!-- ================================================================
     VENDOR PO DETAIL
     ================================================================ -->
<template id="vendor_po_detail" name="Vendor PO Detail">
    <t t-call="portal.portal_layout">
        <div class="vp-page">
            <div class="container">
                <nav class="mb-3">
                    <a href="/vendor/pos" class="text-muted" style="font-size:.88rem">
                        <i class="fa fa-arrow-left me-1"/> <span t-translate="yes">Back to Purchase Orders</span>
                    </a>
                </nav>
                <div class="vp-detail-hero mb-3">
                    <div class="invoice-ref"><t t-esc="po.name"/></div>
                    <div class="invoice-amount">
                        <t t-esc="po.currency_id.symbol"/>&#160;<t t-esc="'{:,.2f}'.format(po.amount_total)"/>
                    </div>
                    <div class="invoice-meta">
                        <span t-translate="yes">Approved:</span> <t t-esc="po.date_approve or '-'"/>
                    </div>
                </div>
                <div class="vp-card">
                    <div class="vp-card-header">
                        <h5><i class="fa fa-list me-1"/> <span t-translate="yes">Order Lines</span></h5>
                    </div>
                    <div class="table-responsive">
                        <table class="vp-invoice-table">
                            <thead>
                                <tr>
                                    <th t-translate="yes">Product</th>
                                    <th t-translate="yes">Qty</th>
                                    <th t-translate="yes">Unit Price</th>
                                    <th t-translate="yes">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="po.order_line" t-as="line">
                                    <tr>
                                        <td><t t-esc="line.product_id.name if line.product_id else '-'"/></td>
                                        <td><t t-esc="line.product_qty"/> <t t-esc="line.product_uom.name if line.product_uom else ''"/></td>
                                        <td><t t-esc="po.currency_id.symbol"/>&#160;<t t-esc="'{:,.2f}'.format(line.price_unit)"/></td>
                                        <td><t t-esc="po.currency_id.symbol"/>&#160;<t t-esc="'{:,.2f}'.format(line.price_subtotal)"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                    <div class="p-3 text-end">
                        <strong t-translate="yes">Total:</strong>
                        <t t-esc="po.currency_id.symbol"/>&#160;<t t-esc="'{:,.2f}'.format(po.amount_total)"/>
                    </div>
                </div>
                <div class="mt-3 text-center">
                    <a href="/vendor/invoice/upload" class="vp-btn vp-btn-success">
                        <i class="fa fa-upload"/> <span t-translate="yes">Upload Invoice for this PO</span>
                    </a>
                </div>
            </div>
        </div>
    </t>
</template>

</odoo>

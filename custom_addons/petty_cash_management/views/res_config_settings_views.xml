<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_petty_cash_user_config_list" model="ir.ui.view">
        <field name="name">petty.cash.user.config.list</field>
        <field name="model">petty.cash.user.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="partner_id"/>
                <field name="company_id"/>
                <field name="petty_cash_journal_id"/>
                <field name="petty_cash_account_id"/>
                <field name="input_vat_account_id"/>
            </list>
        </field>
    </record>

    <record id="view_petty_cash_user_config_form" model="ir.ui.view">
        <field name="name">petty.cash.user.config.form</field>
        <field name="model">petty.cash.user.config</field>
        <field name="arch" type="xml">
            <form string="Petty Cash Configuration">
                <sheet>
                    <group>
                        <field name="partner_id"/>
                        <field name="company_id"/>
                        <field name="petty_cash_journal_id"/>
                        <field name="petty_cash_account_id"/>
                        <field name="input_vat_account_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_petty_cash_user_config" model="ir.actions.act_window">
        <field name="name">Petty Cash Configuration</field>
        <field name="res_model">petty.cash.user.config</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
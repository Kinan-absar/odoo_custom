<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_payment_voucher_overpayment_confirm_form" model="ir.ui.view">
        <field name="name">account.payment.voucher.overpayment.confirm.form</field>
        <field name="model">account.payment.voucher.overpayment.confirm</field>
        <field name="arch" type="xml">
            <form string="Confirm Purchase Order Overpayment">
                <group>
                    <div class="alert alert-warning" role="alert">
                        This payment exceeds the remaining amount on one or more Purchase Orders.
                    </div>
                    <field name="voucher_id"/>
                    <field name="message" nolabel="1" readonly="1"/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Confirm and Post" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>

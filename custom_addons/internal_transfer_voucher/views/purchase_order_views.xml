<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_purchase_order_kpis_tree_inherit_amount_paid" model="ir.ui.view">
        <field name="name">purchase.order.kpis.tree.amount.paid</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="amount_paid" widget="monetary" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="view_purchase_order_form_amount_paid" model="ir.ui.view">
        <field name="name">purchase.order.form.amount.paid</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Payments" name="payments">
                    <group>
                        <group string="Payment Summary">
                            <field name="amount_paid" widget="monetary" readonly="1"/>
                            <field name="amount_paid_residual" widget="monetary" readonly="1"/>
                        </group>
                    </group>
                    <div class="d-flex gap-2 mb-2">
                        <button name="action_new_payment_voucher"
                                type="object"
                                string="Create Payment Voucher"
                                class="btn-primary"
                                icon="fa-plus"/>
                        <button name="action_link_existing_payment_voucher"
                                type="object"
                                string="Link Existing Voucher"
                                class="btn-secondary"
                                icon="fa-link"/>
                    </div>
                    <field name="payment_voucher_allocation_ids" nolabel="1" readonly="1">
                        <list create="0" delete="0">
                            <field name="voucher_id" string="Payment Voucher"/>
                            <field name="voucher_state" string="Status" widget="badge"/>
                            <field name="po_paid_before" string="Paid Before" widget="monetary"/>
                            <field name="amount" string="This Payment" widget="monetary"/>
                            <field name="projected_paid" string="Paid After" widget="monetary"/>
                            <field name="overpayment_amount" string="Overpayment" widget="monetary" decoration-danger="overpayment_amount &gt; 0"/>
                            <field name="currency_id" column_invisible="True"/>
                            <field name="po_currency_id" column_invisible="True"/>
                            <field name="purchase_order_id" column_invisible="True"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>

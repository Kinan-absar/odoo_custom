<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- LIST VIEW EXTENSION (RFQ list) -->
    <!-- Add "Amount Paid" column right after the Status field -->
    <record id="view_purchase_order_kpis_tree_inherit_amount_paid" model="ir.ui.view">
        <field name="name">purchase.order.kpis.tree.amount.paid</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="amount_paid" widget="monetary" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- FORM VIEW EXTENSION -->
    <!-- Dedicated "Payments" tab showing totals and the linked payment vouchers -->
    <record id="view_purchase_order_form_amount_paid" model="ir.ui.view">
        <field name="name">purchase.order.form.amount.paid</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//notebook" position="inside">
                <page string="Payments" name="payments">
                    <group>
                        <group string="Payment Summary">
                            <field name="amount_paid" widget="monetary"/>
                            <field name="amount_paid_residual" widget="monetary"/>
                        </group>
                    </group>
                    <field name="payment_voucher_ids" nolabel="1">
                        <list>
                            <field name="name"/>
                            <field name="date"/>
                            <field name="partner_id"/>
                            <field name="amount" widget="monetary"/>
                            <field name="payment_method"/>
                            <field name="state" widget="badge" decoration-success="state == 'posted'" decoration-info="state == 'draft'" decoration-danger="state == 'cancel'"/>
                        </list>
                    </field>
                </page>
            </xpath>

        </field>
    </record>

</odoo>

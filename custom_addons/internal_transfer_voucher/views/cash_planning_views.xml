<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <record id="view_cash_plan_run_list" model="ir.ui.view"><field name="name">cash.plan.run.list</field><field name="model">cash.plan.run</field><field name="arch" type="xml"><list decoration-success="state == 'done'" decoration-info="state in ('approved','in_progress')"><field name="name"/><field name="date_from"/><field name="date_to"/><field name="opening_balance" sum="Opening"/><field name="forecast_inflow" sum="Inflows"/><field name="forecast_outflow" sum="Outflows"/><field name="forecast_closing" sum="Closing"/><field name="actual_closing"/><field name="forecast_variance"/><field name="state" widget="badge"/></list></field></record>
  <record id="view_cash_plan_run_form" model="ir.ui.view"><field name="name">cash.plan.run.form</field><field name="model">cash.plan.run</field><field name="arch" type="xml"><form string="Weekly Cash Plan"><header><button name="action_submit" type="object" string="Submit" class="btn-primary" invisible="state != 'draft'"/><button name="action_approve" type="object" string="Approve" class="btn-primary" invisible="state != 'submitted'" groups="account.group_account_manager"/><button name="action_start" type="object" string="Start Week" invisible="state != 'approved'"/><button name="action_done" type="object" string="Complete" class="btn-primary" invisible="state != 'in_progress'"/><button name="action_cancel" type="object" string="Cancel" invisible="state in ('done','cancel')"/><button name="action_draft" type="object" string="Reset to Draft" invisible="state != 'cancel'"/><field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,in_progress,done"/></header><sheet><div class="oe_title"><label for="name"/><h1><field name="name"/></h1></div><group><group><field name="date_from"/><field name="date_to"/><field name="company_id" groups="base.group_multi_company"/></group><group><field name="opening_balance"/><field name="budget_amount"/><field name="budget_remaining" readonly="1"/></group></group><group string="Forecast Summary" col="4"><field name="forecast_inflow" readonly="1"/><field name="forecast_outflow" readonly="1"/><field name="forecast_net" readonly="1"/><field name="forecast_closing" readonly="1"/></group><group string="Actual and Variance" col="4"><field name="actual_inflow" readonly="1"/><field name="actual_outflow" readonly="1"/><field name="actual_net" readonly="1"/><field name="actual_closing" readonly="1"/><field name="forecast_variance" readonly="1"/></group><notebook><page string="Planned Cash Movements"><field name="line_ids" context="{'default_planned_date': date_from}"><list editable="bottom"><field name="planned_date"/><field name="flow_type"/><field name="category_id"/><field name="transaction_type"/><field name="partner_id"/><field name="project_id" optional="show"/><field name="forecast_amount" sum="Forecast"/><field name="actual_amount" sum="Actual" readonly="1"/><field name="variance_amount" sum="Variance" readonly="1"/><field name="priority" widget="priority"/><field name="funding_status" widget="badge"/><field name="state" widget="badge"/></list></field></page><page string="Weekly Notes"><field name="notes"/></page></notebook></sheet><chatter/></form></field></record>
  <record id="view_cash_plan_line_list" model="ir.ui.view"><field name="name">cash.plan.line.list</field><field name="model">cash.plan.line</field><field name="arch" type="xml"><list decoration-success="state == 'executed'" decoration-danger="funding_status == 'unfunded'"><field name="planned_date"/><field name="run_id"/><field name="flow_type"/><field name="category_id"/><field name="name"/><field name="partner_id"/><field name="project_id" optional="show"/><field name="forecast_amount" sum="Forecast"/><field name="actual_amount" sum="Actual"/><field name="variance_amount" sum="Variance"/><field name="priority" widget="priority"/><field name="funding_status" widget="badge"/><field name="state" widget="badge"/></list></field></record>
  <record id="view_cash_plan_line_form" model="ir.ui.view"><field name="name">cash.plan.line.form</field><field name="model">cash.plan.line</field><field name="arch" type="xml"><form><header><button name="action_approve" type="object" string="Approve" class="btn-primary" invisible="state != 'planned'"/><button name="action_execute" type="object" string="Create Voucher / Transfer" class="btn-primary" invisible="state in ('executed','cancel')"/><button name="action_open_document" type="object" string="Open Executed Document" invisible="state != 'executed'"/><button name="action_cancel" type="object" string="Cancel" invisible="state == 'cancel'"/><field name="state" widget="statusbar"/></header><sheet><div class="oe_title"><h1><field name="name"/></h1></div><group><group><field name="run_id"/><field name="planned_date"/><field name="flow_type"/><field name="transaction_type"/><field name="category_id"/><field name="priority" widget="priority"/><field name="funding_status"/></group><group><field name="partner_id"/><field name="project_id"/><field name="forecast_amount"/><field name="actual_amount" readonly="1"/><field name="variance_amount" readonly="1"/><field name="journal_id"/><field name="destination_journal_id" invisible="transaction_type != 'transfer'"/><field name="account_id" invisible="transaction_type == 'transfer'"/></group></group><notebook><page string="Documents"><field name="purchase_order_ids" widget="many2many_tags" invisible="flow_type != 'out'"/><field name="bill_ids" widget="many2many_tags" invisible="flow_type != 'out'"/><field name="invoice_ids" widget="many2many_tags" invisible="flow_type != 'in'"/></page><page string="Notes"><field name="description"/></page><page string="Execution"><group><field name="payment_voucher_id"/><field name="receipt_voucher_id"/><field name="internal_transfer_id"/></group></page></notebook></sheet><chatter/></form></field></record>
  <record id="view_cash_plan_line_calendar" model="ir.ui.view"><field name="name">cash.plan.line.calendar</field><field name="model">cash.plan.line</field><field name="arch" type="xml"><calendar string="Treasury Calendar" date_start="planned_date" color="flow_type" mode="month"><field name="name"/><field name="partner_id"/><field name="forecast_amount"/><field name="category_id"/></calendar></field></record>
  <record id="view_cash_plan_line_pivot" model="ir.ui.view"><field name="name">cash.plan.line.pivot</field><field name="model">cash.plan.line</field><field name="arch" type="xml"><pivot string="Cash Forecast Analysis"><field name="planned_date" type="row" interval="week"/><field name="flow_type" type="col"/><field name="category_id" type="row"/><field name="forecast_amount" type="measure"/><field name="actual_amount" type="measure"/><field name="variance_amount" type="measure"/></pivot></field></record>
  <record id="view_cash_plan_line_graph" model="ir.ui.view"><field name="name">cash.plan.line.graph</field><field name="model">cash.plan.line</field><field name="arch" type="xml"><graph string="Forecast vs Actual" type="bar"><field name="planned_date" interval="week"/><field name="forecast_amount" type="measure"/><field name="actual_amount" type="measure"/></graph></field></record>
  <record id="action_cash_plan_run" model="ir.actions.act_window"><field name="name">Weekly Planner</field><field name="res_model">cash.plan.run</field><field name="view_mode">list,form</field></record>
  <record id="action_cash_plan_line" model="ir.actions.act_window"><field name="name">Planned Payments &amp; Receipts</field><field name="res_model">cash.plan.line</field><field name="view_mode">list,calendar,pivot,graph,form</field></record>
  <record id="action_cash_plan_payments" model="ir.actions.act_window"><field name="name">Planned Payments</field><field name="res_model">cash.plan.line</field><field name="view_mode">list,calendar,pivot,graph,form</field><field name="domain">[('flow_type','=','out')]</field><field name="context">{'default_flow_type':'out'}</field></record>
  <record id="action_cash_plan_receipts" model="ir.actions.act_window"><field name="name">Planned Receipts</field><field name="res_model">cash.plan.line</field><field name="view_mode">list,calendar,pivot,graph,form</field><field name="domain">[('flow_type','=','in')]</field><field name="context">{'default_flow_type':'in'}</field></record>
  <record id="action_cash_plan_category" model="ir.actions.act_window"><field name="name">Cash Planning Categories</field><field name="res_model">cash.plan.category</field><field name="view_mode">list,form</field></record>
</odoo>

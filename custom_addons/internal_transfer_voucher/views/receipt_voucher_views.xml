<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- SEARCH -->
    <record id="view_receipt_voucher_search" model="ir.ui.view">
        <field name="name">account.receipt.voucher.search</field>
        <field name="model">account.receipt.voucher</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Voucher"/>
                <field name="partner_id"/>
                <field name="journal_id"/>
                <field name="description" string="Notes"/>
                <field name="amount"/>
                <filter name="draft"  string="Draft"     domain="[('state','=','draft')]"/>
                <filter name="posted" string="Posted"    domain="[('state','=','posted')]"/>
                <filter name="cancel" string="Cancelled" domain="[('state','=','cancel')]"/>
                <separator/>
                <filter name="cash"          string="Cash"          domain="[('receipt_method','=','cash')]"/>
                <filter name="cheque"        string="Cheque"        domain="[('receipt_method','=','cheque')]"/>
                <filter name="bank_transfer" string="Bank Transfer" domain="[('receipt_method','=','bank_transfer')]"/>
                <separator/>
                <filter name="my_vouchers" string="My Vouchers" domain="[('create_uid','=',uid)]"/>
            </search>
        </field>
    </record>

    <!-- LIST — uses dashboard js_class -->
    <record id="view_receipt_voucher_list" model="ir.ui.view">
        <field name="name">account.receipt.voucher.list</field>
        <field name="model">account.receipt.voucher</field>
        <field name="arch" type="xml">
            <list js_class="receipt_voucher_dashboard_list">
                <field name="name"/>
                <field name="date"/>
                <field name="partner_id"/>
                <field name="amount"/>
                <field name="journal_id"/>
                <field name="receipt_method"/>
                <field name="state"/>
                <field name="company_id" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- FORM -->
    <record id="view_receipt_voucher_form" model="ir.ui.view">
        <field name="name">account.receipt.voucher.form</field>
        <field name="model">account.receipt.voucher</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_post"
                            string="Post"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_reset_to_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state not in ('posted','cancel')"/>

                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            invisible="state != 'draft'"/>

                    <button name="%(action_receipt_voucher_pdf)d"
                            string="Print"
                            type="action"
                            class="btn-secondary"
                            invisible="state != 'posted'"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,posted,cancel"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Receipt Information">
                            <field name="company_id" invisible="1"/>
                            <field name="date"/>
                            <field name="partner_id"/>
                            <field name="amount"/>
                            <field name="currency_id"
                                   groups="base.group_multi_currency"/>
                            <field name="description"
                                   placeholder="Add any notes or description..."/>
                        </group>

                        <group string="Accounting">
                            <field name="receipt_method"/>
                            <field name="journal_id" domain="[('default_account_id', '!=', False), ('company_id', '=', company_id)]"/>
                            <field name="account_id" domain="[('company_ids', 'in', company_id)]"/>
                        </group>
                    </group>

                    <!-- Analytic on Income / Receivable Account -->
                    <group string="Analytic"
                           groups="analytic.group_analytic_accounting">
                        <group>
                            <field name="analytic_distribution"
                                   widget="analytic_distribution"
                                   options="{'force_applicability': 'optional'}"
                                   string="Account Analytic"/>
                        </group>
                        <group/>
                    </group>

                    <!-- Generated Journal Entry -->
                    <group string="Journal Entry">
                        <field name="move_id" readonly="1"/>
                    </group>

                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_receipt_voucher" model="ir.actions.act_window">
        <field name="name">Receipt Vouchers</field>
        <field name="res_model">account.receipt.voucher</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('company_id', 'in', allowed_company_ids)]</field>
    </record>

</odoo>

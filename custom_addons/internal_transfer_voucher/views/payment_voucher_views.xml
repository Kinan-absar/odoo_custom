<?xml version="1.0" encoding="UTF-8"?>
<odoo>
<record id="view_payment_voucher_search" model="ir.ui.view">
    <field name="name">account.payment.voucher.search</field>
    <field name="model">account.payment.voucher</field>
    <field name="arch" type="xml">
        <search>
            <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
            <filter name="posted" string="Posted" domain="[('state','=','posted')]"/>
            <filter name="cancel" string="Cancelled" domain="[('state','=','cancel')]"/>
            <separator/>
            <filter name="cash" string="Cash" domain="[('payment_method','=','cash')]"/>
            <filter name="cheque" string="Cheque" domain="[('payment_method','=','cheque')]"/>
            <filter name="bank_transfer" string="Bank Transfer" domain="[('payment_method','=','bank_transfer')]"/>
            <filter name="journal_transfer" string="Journal Transfer" domain="[('payment_method','=','journal_transfer')]"/>
            <separator/>
            <filter name="my_vouchers" string="My Vouchers" domain="[('create_uid','=',uid)]"/>
        </search>
    </field>
</record>

<record id="view_payment_voucher_list" model="ir.ui.view">
    <field name="name">account.payment.voucher.list</field>
    <field name="model">account.payment.voucher</field>
    <field name="arch" type="xml">
        <list js_class="payment_voucher_dashboard_list">
            <field name="name"/>
            <field name="date"/>
            <field name="partner_id"/>
            <field name="amount"/>
            <field name="journal_id"/>
            <field name="payment_method"/>
            <field name="state"/>
        </list>
    </field>
</record>

    <!-- FORM -->
    <record id="view_payment_voucher_form" model="ir.ui.view">
        <field name="name">account.payment.voucher.form</field>
        <field name="model">account.payment.voucher</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_post"
                            string="Post"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_reset_to_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state not in ('posted','cancel')"/>

                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            invisible="state != 'draft'"/>

                    <button name="%(action_payment_voucher_pdf)d"
                            string="Print"
                            type="action"
                            class="btn-secondary"
                            invisible="state != 'posted'"/>

                    <button name="action_find_matching_bills"
                            string="Find Bills"
                            type="object"
                            class="btn-secondary"
                            invisible="payment_method == 'journal_transfer' or not is_payable_account or bill_reconciled"/>

                    <button name="action_reconcile_bills"
                            string="Reconcile Bills"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'posted' or payment_method == 'journal_transfer' or not is_payable_account or not bill_ids or bill_reconciled"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,posted,cancel"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>

                    <field name="is_payable_account" invisible="1"/>
                    <field name="bill_reconciled" invisible="1"/>
                    <field name="company_id" invisible="1"/>

                    <!-- Main Info -->
                    <group>
                        <group string="Payment Information">
                            <field name="date"/>
                            <field name="partner_id"/>
                            <field name="amount"/>
                            <field name="currency_id"
                                   groups="base.group_multi_currency"/>
                            <field name="description"
                                   placeholder="Add any notes or description..."/>
                        </group>

                        <group string="Accounting">
                            <field name="payment_method"/>
                            <field name="journal_id"
                                   string="Source Journal"
                                   invisible="payment_method == 'journal_transfer'"/>
                            <field name="journal_id"
                                   string="Journal"
                                   invisible="payment_method != 'journal_transfer'"/>
                            <!-- Account — hidden for journal transfer -->
                            <field name="account_id"
                                   invisible="payment_method == 'journal_transfer'"/>
                            <!-- Analytic — inline under account, hidden for journal transfer -->
                            <field name="analytic_distribution"
                                   widget="analytic_distribution"
                                   options="{'force_applicability': 'optional'}"
                                   string="Analytic"
                                   groups="analytic.group_analytic_accounting"
                                   invisible="payment_method == 'journal_transfer'"/>
                        </group>
                    </group>

                    <!-- Destination Journals — journal transfer only -->
                    <group string="Destination Journals"
                           invisible="payment_method != 'journal_transfer'">
                        <group colspan="4">
                            <div class="text-muted" style="margin-bottom:8px;">
                                Split the amount across one or more destination journals. Total must equal the transfer amount (minus any bank fees).
                            </div>
                        </group>
                        <field name="line_ids" nolabel="1" colspan="4">
                            <list editable="bottom">
                                <field name="journal_id"/>
                                <field name="amount"/>
                            </list>
                        </field>
                    </group>

                    <!-- Bank Fees — bank transfer and journal transfer only -->
                    <group string="Bank Fees"
                           invisible="payment_method not in ('bank_transfer', 'journal_transfer')">
                        <group>
                            <field name="has_bank_fees"/>
                            <field name="fee_amount"
                                   invisible="not has_bank_fees"/>
                            <field name="fee_account_id"
                                   invisible="not has_bank_fees"/>
                            <field name="fee_tax_id"
                                   invisible="not has_bank_fees"/>
                        </group>
                        <group string="Fee Analytic"
                               groups="analytic.group_analytic_accounting"
                               invisible="not has_bank_fees">
                            <field name="fee_analytic_distribution"
                                   widget="analytic_distribution"
                                   options="{'force_applicability': 'optional'}"
                                   string="Bank Fee Analytic"/>
                        </group>
                    </group>

                    <!-- Vendor Bill Matching / Reconciliation -->
                    <group string="Vendor Bill Matching"
                           invisible="payment_method == 'journal_transfer' or not is_payable_account">
                        <group>
                            <field name="bill_ids"
                                   widget="many2many_tags"
                                   readonly="bill_reconciled"
                                   domain="[('partner_id', '=', partner_id), ('company_id', '=', company_id), ('move_type', '=', 'in_invoice'), ('state', '=', 'posted'), ('payment_state', 'in', ['not_paid', 'partial'])]"
                                   options="{'no_create': True}"/>
                            <field name="reconciled_bill_ids"
                                   widget="many2many_tags"
                                   readonly="1"
                                   invisible="not reconciled_bill_ids"/>
                            <field name="bill_reconciliation_state" readonly="1"/>
                        </group>
                        <group>
                            <field name="bill_total" readonly="1"/>
                            <field name="difference_amount" readonly="1"/>
                        </group>
                    </group>

                    <!-- Generated Journal Entry -->
                    <group string="Journal Entry">
                        <field name="move_id" readonly="1"/>
                    </group>

                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_payment_voucher" model="ir.actions.act_window">
        <field name="name">Payment Vouchers</field>
        <field name="res_model">account.payment.voucher</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>

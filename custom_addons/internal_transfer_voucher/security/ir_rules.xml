<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Multi-company safety rules: users see/use only vouchers from currently allowed companies. -->
    <record id="rule_payment_voucher_multi_company" model="ir.rule">
        <field name="name">Payment Voucher: multi-company</field>
        <field name="model_id" ref="model_account_payment_voucher"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('account.group_account_user'))]"/>
    </record>

    <record id="rule_receipt_voucher_multi_company" model="ir.rule">
        <field name="name">Receipt Voucher: multi-company</field>
        <field name="model_id" ref="model_account_receipt_voucher"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('account.group_account_user'))]"/>
    </record>

    <record id="rule_internal_transfer_multi_company" model="ir.rule">
        <field name="name">Internal Transfer: multi-company</field>
        <field name="model_id" ref="model_account_internal_transfer"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('account.group_account_user'))]"/>
    </record>

    <record id="rule_payment_voucher_line_multi_company" model="ir.rule">
        <field name="name">Payment Voucher Lines: multi-company</field>
        <field name="model_id" ref="model_account_payment_voucher_line"/>
        <field name="domain_force">[('voucher_id.company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('account.group_account_user'))]"/>
    </record>

    <record id="rule_internal_transfer_line_multi_company" model="ir.rule">
        <field name="name">Internal Transfer Lines: multi-company</field>
        <field name="model_id" ref="model_account_internal_transfer_line"/>
        <field name="domain_force">[('transfer_id.company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('account.group_account_user'))]"/>
    </record>
</odoo>

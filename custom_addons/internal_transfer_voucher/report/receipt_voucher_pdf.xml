<?xml version="1.0" encoding="UTF-8"?>
<odoo>

<template id="receipt_voucher_pdf">
    <t t-call="web.external_layout">
        <main>

<style>

/* ===== Page Base ===== */
.page {
    font-size: 12px;
    line-height: 1.4;
}

/* ===== Title ===== */
.rv-title {
    text-align: center;
    margin-bottom: 60px;
}

.rv-title h2 {
    font-size: 18px;
    margin: 0;
    letter-spacing: 1px;
}

.rv-title h3 {
    font-size: 14px;
    margin: 3px 0 0 0;
}

/* ===== Tables ===== */
table {
    width: 100%;
    border-collapse: collapse;
}

.table-bordered td,
.table-bordered th {
    border: 1px solid #000;
    padding: 6px 8px;
    vertical-align: middle;
}

/* ===== Header Table ===== */
.rv-header-table td {
    font-size: 12px;
}

/* ===== Amount Box ===== */
.amount-box td {
    font-size: 18px;
    font-weight: bold;
    padding: 28px 10px;
    text-align: center;
    background-color: #f0f7f0;
    border: 2px solid #4a8c5c;
}

/* ===== Main Info Table ===== */
.rv-main-table td {
    font-size: 12px;
}

.rv-main-table tr:nth-child(even) {
    background-color: #fafafa;
}

/* Labels alignment */
.rv-header-table td:first-child,
.rv-main-table td:first-child {
    text-align: center;
    font-weight: 600;
}

.rv-header-table td:last-child,
.rv-main-table td:last-child {
    text-align: center;
    direction: rtl;
    font-weight: 600;
}

/* ===== Signatures ===== */
.signature-block {
    margin-top: 60px;
}

.signature {
    width: 45%;
    text-align: center;
    float: left;
}

.signature.right {
    float: right;
}

.signature .line {
    margin-top: 60px;
    border-top: 1px solid #000;
    width: 80%;
    margin-left: auto;
    margin-right: auto;
}

.signature-label {
    margin-top: 5px;
    font-size: 14px;
}

.clearfix {
    clear: both;
}

</style>

<t t-foreach="docs" t-as="o">
<div class="page">

    <!-- TITLE -->
    <div class="rv-title">
        <h2>RECEIPT VOUCHER</h2>
        <h3>سند قبض</h3>
    </div>

    <!-- TOP STRIP: Voucher/Date on left, Amount box on right -->
    <div style="width:65%; float:left;">
        <table class="table-bordered rv-header-table">
            <tr>
                <td width="30%"><strong>Voucher No</strong></td>
                <td width="40%" style="text-align:center;">
                    <span t-esc="o.name"/>
                </td>
                <td width="30%"><strong>رقم السند</strong></td>
            </tr>
            <tr>
                <td><strong>Date</strong></td>
                <td style="text-align:center;">
                    <span t-esc="o.date"/>
                </td>
                <td><strong>التاريخ</strong></td>
            </tr>
        </table>
    </div>

    <div style="width:30%; float:right;">
        <table class="table-bordered amount-box">
            <tr>
                <td>
                    <span t-field="o.amount"
                          t-options="{'widget':'monetary','currency_field':'currency_id'}"/>
                </td>
            </tr>
        </table>
    </div>

    <div class="clearfix"></div>

    <!-- MAIN INFO TABLE -->
    <table class="table-bordered rv-main-table" style="margin-top:25px;">

        <tr>
            <td width="25%"><strong>Received From</strong></td>
            <td width="50%" style="text-align:center;">
                <span t-esc="o.partner_id.display_name"/>
            </td>
            <td width="25%"><strong>استلمنا من</strong></td>
        </tr>

        <tr>
            <td><strong>Amount in Words</strong></td>
            <td style="text-align:center; direction:rtl;">
                <span t-esc="o.amount_in_words_ar"/> فقط لا غير
            </td>
            <td><strong>المبلغ كتابةً</strong></td>
        </tr>

        <tr>
            <td><strong>Received For</strong></td>
            <td style="text-align:center;">
                <span t-esc="o.description"/>
            </td>
            <td><strong>وذلك مقابل</strong></td>
        </tr>

        <tr>
            <td><strong>Receipt Method</strong></td>
            <td style="text-align:center;">
                <t t-if="o.receipt_method == 'cash'">Cash / نقداً</t>
                <t t-if="o.receipt_method == 'cheque'">Cheque / شيك</t>
                <t t-if="o.receipt_method == 'bank_transfer'">Bank Transfer / تحويل بنكي</t>
            </td>
            <td><strong>طريقة الاستلام</strong></td>
        </tr>

        <tr>
            <td><strong>Deposited To</strong></td>
            <td style="text-align:center;">
                <span t-esc="o.journal_id.name"/>
            </td>
            <td><strong>أودع في</strong></td>
        </tr>

    </table>

    <!-- SIGNATURES -->
    <div class="signature-block">

        <div class="signature">
            <div class="line"></div>
            <div class="signature-label">Received By / استلمه</div>
        </div>

        <div class="signature right">
            <div class="line"></div>
            <div class="signature-label">Paid By / دفعه</div>
        </div>

        <div class="clearfix"></div>
    </div>

</div>
</t>

        </main>
    </t>
</template>

</odoo>

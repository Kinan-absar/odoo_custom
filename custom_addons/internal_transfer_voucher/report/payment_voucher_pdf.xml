<?xml version="1.0" encoding="UTF-8"?>
<odoo>

<template id="payment_voucher_pdf">
    <t t-call="web.external_layout">
        <main>

<style>

/* ===== Page Base ===== */
.page {
    font-size: 12px;
    line-height: 1.4;
}

/* ===== Titles ===== */
.pv-title {
    text-align: center;
    margin-bottom: 60px;
}
.pv-title h2 {
    font-size: 18px;
    margin: 0;
    letter-spacing: 1px;
}
.pv-title h3 {
    font-size: 14px;
    margin: 3px 0 0 0;
}

/* ===== Tables ===== */
table {
    width: 100%;
    border-collapse: collapse;
}
.table-bordered td,
.table-bordered th {
    border: 1px solid #000;
    padding: 6px 8px;
    vertical-align: middle;
}

/* ===== Header Table ===== */
.pv-header-table td {
    font-size: 12px;
}

/* ===== Amount Box ===== */
.amount-box td {
    font-size: 18px;
    font-weight: bold;
    padding: 28px 10px;
    text-align: center;
    background-color: #f3f6f9;
    border: 2px solid #637fa9ff;
}

/* ===== Main Info Table ===== */
.pv-main-table td {
    font-size: 12px;
}
.pv-main-table tr:nth-child(even) {
    background-color: #fafafa;
}
.pv-header-table td:first-child,
.pv-main-table td:first-child {
    text-align: center;
    font-weight: 600;
}
.pv-header-table td:last-child,
.pv-main-table td:last-child {
    text-align: center;
    direction: rtl;
    font-weight: 600;
}

/* ===== Transfer Destinations Table ===== */
.dest-table th {
    background-color: #f3f6f9;
    text-align: center;
    padding: 6px 8px;
    font-size: 12px;
}
.dest-table td {
    text-align: center;
    font-size: 12px;
    padding: 6px 8px;
}

/* ===== Fees Table ===== */
.fees-table td {
    font-size: 11px;
    padding: 5px 8px;
}

/* ===== Signatures ===== */
.signature-block {
    margin-top: 60px;
}
.signature {
    width: 30%;
    text-align: center;
    float: left;
    margin-right: 3%;
}
.signature .line {
    margin-top: 60px;
    border-top: 1px solid #000;
    width: 80%;
    margin-left: auto;
    margin-right: auto;
}
.signature-label {
    margin-top: 5px;
    font-size: 13px;
}
.clearfix {
    clear: both;
}

</style>

<t t-foreach="docs" t-as="o">
<div class="page">

    <!-- ================================================ -->
    <!-- JOURNAL TRANSFER LAYOUT                          -->
    <!-- ================================================ -->
    <t t-if="o.payment_method == 'journal_transfer'">

        <div class="pv-title">
            <h2>INTERNAL TRANSFER VOUCHER</h2>
            <h3>سند تحويل داخلي</h3>
        </div>

        <!-- Voucher No / Date  |  Amount Box -->
        <div style="width:65%; float:left;">
            <table class="table-bordered pv-header-table">
                <tr>
                    <td width="30%"><strong>Voucher No</strong></td>
                    <td width="40%" style="text-align:center;">
                        <span t-esc="o.name"/>
                    </td>
                    <td width="30%"><strong>رقم السند</strong></td>
                </tr>
                <tr>
                    <td><strong>Date</strong></td>
                    <td style="text-align:center;">
                        <span t-esc="o.date"/>
                    </td>
                    <td><strong>التاريخ</strong></td>
                </tr>
            </table>
        </div>

        <div style="width:30%; float:right;">
            <table class="table-bordered amount-box">
                <tr>
                    <td>
                        <span t-field="o.amount"
                              t-options="{'widget':'monetary','currency_field':'currency_id'}"/>
                    </td>
                </tr>
            </table>
        </div>

        <div class="clearfix"></div>

        <!-- Source / Destination info -->
        <table class="table-bordered pv-main-table" style="margin-top:25px;">
            <tr>
                <td width="25%"><strong>Source Journal</strong></td>
                <td width="50%" style="text-align:center;">
                    <span t-esc="o.journal_id.name"/>
                </td>
                <td width="25%"><strong>المصدر</strong></td>
            </tr>
            <tr>
                <td><strong>Amount in Words</strong></td>
                <td style="text-align:center; direction:rtl;">
                    <span t-esc="o.amount_in_words_ar"/> فقط لا غير
                </td>
                <td><strong>المبلغ كتابةً</strong></td>
            </tr>
            <tr>
                <td><strong>Notes</strong></td>
                <td style="text-align:center;">
                    <span t-esc="o.description"/>
                </td>
                <td><strong>ملاحظات</strong></td>
            </tr>
        </table>

        <!-- Destination journals breakdown -->
        <table class="table-bordered dest-table" style="margin-top:15px;">
            <thead>
                <tr>
                    <th>Destination Journal / الوجهة</th>
                    <th>Amount / المبلغ</th>
                </tr>
            </thead>
            <tbody>
                <t t-foreach="o.line_ids" t-as="line">
                    <tr>
                        <td><span t-esc="line.journal_id.name"/></td>
                        <td>
                            <span t-field="line.amount"
                                  t-options="{'widget':'monetary','currency_field':'currency_id'}"/>
                        </td>
                    </tr>
                </t>
            </tbody>
        </table>

        <!-- Bank fees for transfer -->
        <t t-if="o.has_bank_fees and o.fee_amount">
            <t t-set="fee_tax_amount" t-value="0.0"/>
            <t t-if="o.fee_tax_id">
                <t t-set="fee_tax_amount"
                   t-value="o.fee_tax_id.compute_all(o.fee_amount, currency=o.currency_id)['total_included'] - o.fee_amount"/>
            </t>
            <t t-set="grand_total" t-value="o.amount + o.fee_amount + fee_tax_amount"/>
            <table class="table-bordered fees-table" style="margin-top:15px;">
                <thead>
                    <tr style="background-color:#f3f6f9;">
                        <th style="text-align:center; padding:6px;">Amount / المبلغ</th>
                        <th style="text-align:center; padding:6px;">Bank Fees / رسوم بنكية</th>
                        <th style="text-align:center; padding:6px;">VAT on Fees / ضريبة الرسوم</th>
                        <th style="text-align:center; padding:6px;">Total Deducted / إجمالي الخصم</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td style="text-align:center;">
                            <span t-field="o.amount"
                                  t-options="{'widget':'monetary','currency_field':'currency_id'}"/>
                        </td>
                        <td style="text-align:center;">
                            <span t-field="o.fee_amount"
                                  t-options="{'widget':'monetary','currency_field':'currency_id'}"/>
                        </td>
                        <td style="text-align:center;">
                            <t t-if="o.fee_tax_id">
                                <span t-esc="'%.2f' % fee_tax_amount"/>
                            </t>
                            <t t-else="">—</t>
                        </td>
                        <td style="text-align:center; font-weight:bold;">
                            <span t-esc="'%.2f' % grand_total"/>
                            <span t-esc="' ' + o.currency_id.symbol"/>
                        </td>
                    </tr>
                </tbody>
            </table>
        </t>

        <!-- Signatures: 3 for transfer -->
        <div class="signature-block">
            <div class="signature">
                <div class="line"></div>
                <div class="signature-label">Prepared By / أعده</div>
            </div>
            <div class="signature">
                <div class="line"></div>
                <div class="signature-label">Approved By / اعتمده</div>
            </div>
            <div class="signature">
                <div class="line"></div>
                <div class="signature-label">Received By / استلمه</div>
            </div>
            <div class="clearfix"></div>
        </div>

    </t>

    <!-- ================================================ -->
    <!-- STANDARD PAYMENT VOUCHER LAYOUT                  -->
    <!-- (cash / cheque / bank_transfer)                  -->
    <!-- ================================================ -->
    <t t-else="">

        <div class="pv-title">
            <h2>PAYMENT VOUCHER</h2>
            <h3>سند صرف</h3>
        </div>

        <div style="width:65%; float:left;">
            <table class="table-bordered pv-header-table">
                <tr>
                    <td width="30%"><strong>Voucher No</strong></td>
                    <td width="40%" style="text-align:center;">
                        <span t-esc="o.name"/>
                    </td>
                    <td width="30%"><strong>رقم السند</strong></td>
                </tr>
                <tr>
                    <td><strong>Date</strong></td>
                    <td style="text-align:center;">
                        <span t-esc="o.date"/>
                    </td>
                    <td><strong>التاريخ</strong></td>
                </tr>
            </table>
        </div>

        <div style="width:30%; float:right;">
            <table class="table-bordered amount-box">
                <tr>
                    <td>
                        <span t-field="o.amount"
                              t-options="{'widget':'monetary','currency_field':'currency_id'}"/>
                    </td>
                </tr>
            </table>
        </div>

        <div class="clearfix"></div>

        <table class="table-bordered pv-main-table" style="margin-top:25px;">
            <tr>
                <td width="25%"><strong>Paid To</strong></td>
                <td width="50%" style="text-align:center;">
                    <span t-esc="o.partner_id.display_name"/>
                </td>
                <td width="25%"><strong>تصرف إلى</strong></td>
            </tr>
            <tr>
                <td><strong>Amount in Words</strong></td>
                <td style="text-align:center; direction:rtl;">
                    <span t-esc="o.amount_in_words_ar"/> فقط لا غير
                </td>
                <td><strong>المبلغ كتابةً</strong></td>
            </tr>
            <tr>
                <td><strong>Paid For</strong></td>
                <td style="text-align:center;">
                    <span t-esc="o.description"/>
                </td>
                <td><strong>وذلك مقابل</strong></td>
            </tr>
            <tr>
                <td><strong>Payment Method</strong></td>
                <td style="text-align:center;">
                    <t t-if="o.payment_method == 'cash'">Cash / نقداً</t>
                    <t t-if="o.payment_method == 'cheque'">Cheque / شيك</t>
                    <t t-if="o.payment_method == 'bank_transfer'">Bank Transfer / تحويل بنكي</t>
                </td>
                <td><strong>طريقة الدفع</strong></td>
            </tr>
            <tr>
                <td><strong>Journal</strong></td>
                <td style="text-align:center;">
                    <span t-esc="o.journal_id.name"/>
                </td>
                <td><strong>دفتر اليومية</strong></td>
            </tr>
        </table>

        <!-- Bank fees for payment -->
        <t t-if="o.has_bank_fees and o.fee_amount">
            <t t-set="fee_tax_amount" t-value="0.0"/>
            <t t-if="o.fee_tax_id">
                <t t-set="fee_tax_amount"
                   t-value="o.fee_tax_id.compute_all(o.fee_amount, currency=o.currency_id)['total_included'] - o.fee_amount"/>
            </t>
            <t t-set="grand_total" t-value="o.amount + o.fee_amount + fee_tax_amount"/>
            <table class="table-bordered fees-table" style="margin-top:15px;">
                <thead>
                    <tr style="background-color:#f3f6f9;">
                        <th style="text-align:center; padding:6px;">Amount / المبلغ</th>
                        <th style="text-align:center; padding:6px;">Bank Fees / رسوم بنكية</th>
                        <th style="text-align:center; padding:6px;">VAT on Fees / ضريبة الرسوم</th>
                        <th style="text-align:center; padding:6px;">Total / الإجمالي</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td style="text-align:center;">
                            <span t-field="o.amount"
                                  t-options="{'widget':'monetary','currency_field':'currency_id'}"/>
                        </td>
                        <td style="text-align:center;">
                            <span t-field="o.fee_amount"
                                  t-options="{'widget':'monetary','currency_field':'currency_id'}"/>
                        </td>
                        <td style="text-align:center;">
                            <t t-if="o.fee_tax_id">
                                <span t-esc="'%.2f' % fee_tax_amount"/>
                            </t>
                            <t t-else="">—</t>
                        </td>
                        <td style="text-align:center; font-weight:bold;">
                            <span t-esc="'%.2f' % grand_total"/>
                            <span t-esc="' ' + o.currency_id.symbol"/>
                        </td>
                    </tr>
                </tbody>
            </table>
        </t>

        <!-- Signatures: 2 for payment -->
        <div class="signature-block">
            <div class="signature">
                <div class="line"></div>
                <div class="signature-label">Paid By / صرفه</div>
            </div>
            <div class="signature" style="float:right;">
                <div class="line"></div>
                <div class="signature-label">Received By / استلمه</div>
            </div>
            <div class="clearfix"></div>
        </div>

    </t>

</div>
</t>

        </main>
    </t>
</template>

</odoo>

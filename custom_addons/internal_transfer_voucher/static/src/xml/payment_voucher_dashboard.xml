<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="internal_transfer_voucher.PaymentVoucherListView"
       t-inherit="web.ListView"
       t-inherit-mode="primary">

        <!-- BEFORE the renderer so dashboard appears at the TOP -->
        <xpath expr="//Layout" position="before">
            <PaymentVoucherDashboard/>
        </xpath>

    </t>

    <t t-name="internal_transfer_voucher.PaymentVoucherDashboard">
        <div class="o_payment_voucher_dashboard px-3 py-3 border-bottom bg-view">
            <div class="d-flex flex-wrap gap-2">

                <div class="pv_card pv_card_neutral" t-on-click="clearDashboardDomain">
                    <div class="pv_value"><t t-esc="data.all_count"/></div>
                    <div class="pv_label">All</div>
                </div>

                <div class="pv_card pv_card_blue"
                     t-on-click="() => this.setDashboardDomain([['state','=','draft']], 'Draft')">
                    <div class="pv_value"><t t-esc="data.draft_count"/></div>
                    <div class="pv_label">Draft</div>
                </div>

                <div class="pv_card pv_card_green"
                     t-on-click="() => this.setDashboardDomain([['state','=','posted']], 'Posted')">
                    <div class="pv_value"><t t-esc="data.posted_count"/></div>
                    <div class="pv_label">Posted</div>
                </div>

                <div class="pv_card pv_card_red"
                     t-on-click="() => this.setDashboardDomain([['state','=','cancel']], 'Cancelled')">
                    <div class="pv_value"><t t-esc="data.cancel_count"/></div>
                    <div class="pv_label">Cancelled</div>
                </div>

                <div class="pv_card pv_card_neutral"
                     t-on-click="() => this.setDashboardDomain([['payment_method','=','cash']], 'Cash')">
                    <div class="pv_value"><t t-esc="data.cash_count"/></div>
                    <div class="pv_label">Cash</div>
                </div>

                <div class="pv_card pv_card_neutral"
                     t-on-click="() => this.setDashboardDomain([['payment_method','=','cheque']], 'Cheque')">
                    <div class="pv_value"><t t-esc="data.cheque_count"/></div>
                    <div class="pv_label">Cheque</div>
                </div>

                <div class="pv_card pv_card_neutral"
                     t-on-click="() => this.setDashboardDomain([['payment_method','=','bank_transfer']], 'Bank Transfer')">
                    <div class="pv_value"><t t-esc="data.bank_count"/></div>
                    <div class="pv_label">Bank Transfer</div>
                </div>

                <div class="pv_card pv_card_neutral"
                     t-on-click="() => this.setDashboardDomain([['payment_method','=','journal_transfer']], 'Journal Transfer')">
                    <div class="pv_value"><t t-esc="data.transfer_count"/></div>
                    <div class="pv_label">Journal Transfer</div>
                </div>

                <!-- Fixed: use filterMyVouchers() instead of context.uid -->
                <div class="pv_card pv_card_purple" t-on-click="filterMyVouchers">
                    <div class="pv_value"><t t-esc="data.my_count"/></div>
                    <div class="pv_label">My Vouchers</div>
                </div>

                <div class="pv_card pv_card_total">
                    <div class="pv_value">
                        <t t-esc="formatAmount(data.total_posted_amount)"/>
                        <t t-esc="data.currency_symbol"/>
                    </div>
                    <div class="pv_label">Total Posted</div>
                </div>

            </div>
        </div>
    </t>

</templates>

<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="internal_transfer_voucher.PaymentVoucherListView"
       t-inherit="web.ListView"
       t-inherit-mode="primary">

        <xpath expr="//Layout" position="before">
            <PaymentVoucherDashboard onFilter.bind="onDashboardFilter"/>
        </xpath>

    </t>

    <t t-name="internal_transfer_voucher.PaymentVoucherDashboard">
        <div class="o_payment_voucher_dashboard bg-view border-bottom">
            <table class="pv_table">
                <thead>
                    <tr>
                        <!-- empty top-left label cell -->
                        <th class="pv_row_label"/>
                        <th class="pv_col_head">Draft</th>
                        <th class="pv_col_head">Posted</th>
                        <th class="pv_col_head">Cancelled</th>
                        <th class="pv_col_head pv_sep">Cash</th>
                        <th class="pv_col_head">Cheque</th>
                        <th class="pv_col_head">Bank Transfer</th>
                        <th class="pv_col_head">Journal Transfer</th>
                        <th class="pv_col_head pv_sep pv_total_col">Total Posted</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- ALL row -->
                    <tr>
                        <td class="pv_row_label"
                            t-on-click="() => this.filter([])">All</td>

                        <td class="pv_cell pv_blue"
                            t-on-click="() => this.filter([['state','=','draft']])">
                            <t t-esc="data.draft_count"/>
                        </td>
                        <td class="pv_cell pv_green"
                            t-on-click="() => this.filter([['state','=','posted']])">
                            <t t-esc="data.posted_count"/>
                        </td>
                        <td class="pv_cell pv_red"
                            t-on-click="() => this.filter([['state','=','cancel']])">
                            <t t-esc="data.cancel_count"/>
                        </td>

                        <td class="pv_cell pv_sep"
                            t-on-click="() => this.filter([['payment_method','=','cash']])">
                            <t t-esc="data.cash_count"/>
                        </td>
                        <td class="pv_cell"
                            t-on-click="() => this.filter([['payment_method','=','cheque']])">
                            <t t-esc="data.cheque_count"/>
                        </td>
                        <td class="pv_cell"
                            t-on-click="() => this.filter([['payment_method','=','bank_transfer']])">
                            <t t-esc="data.bank_count"/>
                        </td>
                        <td class="pv_cell"
                            t-on-click="() => this.filter([['payment_method','=','journal_transfer']])">
                            <t t-esc="data.transfer_count"/>
                        </td>

                        <td class="pv_cell pv_sep pv_total_col">
                            <t t-esc="formatAmount(data.total_posted_amount)"/>
                            <span class="pv_symbol"><t t-esc="data.currency_symbol"/></span>
                        </td>
                    </tr>

                    <!-- MY row -->
                    <tr>
                        <td class="pv_row_label"
                            t-on-click="() => this.filter(myDomain)">My</td>

                        <td class="pv_cell pv_blue"
                            t-on-click="() => this.filter([['state','=','draft'],['create_uid','=',myDomain[0][2]]])">
                            <t t-esc="data.my_draft_count"/>
                        </td>
                        <td class="pv_cell pv_green"
                            t-on-click="() => this.filter([['state','=','posted'],['create_uid','=',myDomain[0][2]]])">
                            <t t-esc="data.my_posted_count"/>
                        </td>
                        <td class="pv_cell pv_red"
                            t-on-click="() => this.filter([['state','=','cancel'],['create_uid','=',myDomain[0][2]]])">
                            <t t-esc="data.my_cancel_count"/>
                        </td>

                        <td class="pv_cell pv_sep"
                            t-on-click="() => this.filter([['payment_method','=','cash'],['create_uid','=',myDomain[0][2]]])">
                            <t t-esc="data.my_cash_count"/>
                        </td>
                        <td class="pv_cell"
                            t-on-click="() => this.filter([['payment_method','=','cheque'],['create_uid','=',myDomain[0][2]]])">
                            <t t-esc="data.my_cheque_count"/>
                        </td>
                        <td class="pv_cell"
                            t-on-click="() => this.filter([['payment_method','=','bank_transfer'],['create_uid','=',myDomain[0][2]]])">
                            <t t-esc="data.my_bank_count"/>
                        </td>
                        <td class="pv_cell"
                            t-on-click="() => this.filter([['payment_method','=','journal_transfer'],['create_uid','=',myDomain[0][2]]])">
                            <t t-esc="data.my_transfer_count"/>
                        </td>

                        <td class="pv_cell pv_sep pv_total_col">
                            <t t-esc="formatAmount(data.my_total_posted_amount)"/>
                            <span class="pv_symbol"><t t-esc="data.currency_symbol"/></span>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </t>

</templates>

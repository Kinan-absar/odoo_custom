<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="internal_transfer_voucher.ReceiptVoucherListView"
       t-inherit="web.ListView"
       t-inherit-mode="primary">

        <xpath expr="//Layout" position="before">
            <ReceiptVoucherDashboard onFilter.bind="onDashboardFilter"/>
        </xpath>

    </t>

    <t t-name="internal_transfer_voucher.ReceiptVoucherDashboard">
        <div class="o_receipt_voucher_dashboard bg-view border-bottom">
            <table class="rv_table">
                <thead>
                    <tr>
                        <th class="rv_row_label"/>
                        <th class="rv_col_head">Draft</th>
                        <th class="rv_col_head">Posted</th>
                        <th class="rv_col_head">Cancelled</th>
                        <th class="rv_col_head rv_sep">Cash</th>
                        <th class="rv_col_head">Cheque</th>
                        <th class="rv_col_head">Bank Transfer</th>
                        <th class="rv_col_head rv_sep rv_total_col">Total Posted</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- ALL row -->
                    <tr>
                        <td class="rv_row_label"
                            t-on-click="() => this.filter([])">All</td>

                        <td class="rv_cell rv_blue"
                            t-on-click="() => this.filter([['state','=','draft']])">
                            <t t-esc="data.draft_count"/>
                        </td>
                        <td class="rv_cell rv_green"
                            t-on-click="() => this.filter([['state','=','posted']])">
                            <t t-esc="data.posted_count"/>
                        </td>
                        <td class="rv_cell rv_red"
                            t-on-click="() => this.filter([['state','=','cancel']])">
                            <t t-esc="data.cancel_count"/>
                        </td>

                        <td class="rv_cell rv_sep"
                            t-on-click="() => this.filter([['receipt_method','=','cash']])">
                            <t t-esc="data.cash_count"/>
                        </td>
                        <td class="rv_cell"
                            t-on-click="() => this.filter([['receipt_method','=','cheque']])">
                            <t t-esc="data.cheque_count"/>
                        </td>
                        <td class="rv_cell"
                            t-on-click="() => this.filter([['receipt_method','=','bank_transfer']])">
                            <t t-esc="data.bank_count"/>
                        </td>

                        <td class="rv_cell rv_sep rv_total_col">
                            <t t-esc="formatAmount(data.total_posted_amount)"/>
                            <span class="rv_symbol"><t t-esc="data.currency_symbol"/></span>
                        </td>
                    </tr>

                    <!-- MY row -->
                    <tr>
                        <td class="rv_row_label"
                            t-on-click="() => this.filter(myDomain)">My</td>

                        <td class="rv_cell rv_blue"
                            t-on-click="() => this.filter([['state','=','draft'],['create_uid','=',myDomain[0][2]]])">
                            <t t-esc="data.my_draft_count"/>
                        </td>
                        <td class="rv_cell rv_green"
                            t-on-click="() => this.filter([['state','=','posted'],['create_uid','=',myDomain[0][2]]])">
                            <t t-esc="data.my_posted_count"/>
                        </td>
                        <td class="rv_cell rv_red"
                            t-on-click="() => this.filter([['state','=','cancel'],['create_uid','=',myDomain[0][2]]])">
                            <t t-esc="data.my_cancel_count"/>
                        </td>

                        <td class="rv_cell rv_sep"
                            t-on-click="() => this.filter([['receipt_method','=','cash'],['create_uid','=',myDomain[0][2]]])">
                            <t t-esc="data.my_cash_count"/>
                        </td>
                        <td class="rv_cell"
                            t-on-click="() => this.filter([['receipt_method','=','cheque'],['create_uid','=',myDomain[0][2]]])">
                            <t t-esc="data.my_cheque_count"/>
                        </td>
                        <td class="rv_cell"
                            t-on-click="() => this.filter([['receipt_method','=','bank_transfer'],['create_uid','=',myDomain[0][2]]])">
                            <t t-esc="data.my_bank_count"/>
                        </td>

                        <td class="rv_cell rv_sep rv_total_col">
                            <t t-esc="formatAmount(data.my_total_posted_amount)"/>
                            <span class="rv_symbol"><t t-esc="data.currency_symbol"/></span>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </t>

</templates>

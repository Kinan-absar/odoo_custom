<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Measurements List -->
    <template id="portal_employee_measurements" name="Employee Portal - Measurements">
        <t t-call="employee_portal_suite.employee_portal_layout">
            <div class="container mt-4">
                <div class="row">
                    <div class="col-8">
                        <h3>Measurements</h3>
                    </div>
                    <div class="col-4 text-right">
                        <a href="/my/employee/measurement/new" class="btn btn-primary">
                            <i class="fa fa-plus"/> New Measurement
                        </a>
                    </div>
                </div>

                <t t-if="not measurements">
                    <div class="alert alert-info mt-3" role="alert">
                        There are currently no measurements. Click "New Measurement" to create one.
                    </div>
                </t>

                <t t-if="measurements">
                    <div class="table-responsive mt-3">
                        <table class="table table-hover">
                            <thead class="thead-light">
                                <tr>
                                    <th>Measurement #</th>
                                    <th>Contract</th>
                                    <th>Date</th>
                                    <th>Period</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="measurements" t-as="measurement">
                                    <tr>
                                        <td>
                                            <a t-attf-href="/my/employee/measurement/#{measurement.id}">
                                                <t t-esc="measurement.name"/>
                                            </a>
                                        </td>
                                        <td><span t-field="measurement.contract_id"/></td>
                                        <td><span t-field="measurement.date"/></td>
                                        <td><span t-field="measurement.period_from"/> - <span t-field="measurement.period_to"/></td>
                                        <td>
                                            <span t-if="measurement.state == 'draft'" class="badge badge-secondary">Draft</span>
                                            <span t-if="measurement.state == 'submitted'" class="badge badge-info">Submitted</span>
                                            <span t-if="measurement.state == 'checked'" class="badge badge-primary">Checked</span>
                                            <span t-if="measurement.state == 'approved'" class="badge badge-success">Approved</span>
                                            <span t-if="measurement.state == 'rejected'" class="badge badge-danger">Rejected</span>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>

                    <t t-if="pager" t-call="portal.pager"/>
                </t>

                <div class="row mt-3 mb-4">
                    <div class="col-12">
                        <a href="/my/employee" class="btn btn-secondary">
                            <i class="fa fa-arrow-left"/> Back to Dashboard
                        </a>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Measurement Detail -->
    <template id="portal_employee_measurement_detail" name="Employee Portal - Measurement Detail Enhanced">
        <t t-call="employee_portal_suite.employee_portal_layout">
            <div class="container measurement-portal-page">
                <style type="text/css">
                    .measurement-portal-page {
                        font-size: 15px;
                        color: #1f2937;
                    }
                    .measurement-portal-page h3 {
                        font-size: 2.2rem;
                        font-weight: 700;
                        letter-spacing: -0.02em;
                    }
                    .measurement-portal-page .badge {
                        font-size: 0.82rem;
                    }
                    .measurement-portal-page .measurement-alert {
                        border-radius: 14px;
                        border-width: 1px;
                        padding: 0.95rem 1.1rem;
                        font-size: 0.98rem;
                        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.06);
                        animation: measurementAlertFade 5s ease forwards;
                    }
                    .measurement-portal-page .measurement-alert i {
                        margin-right: 0.45rem;
                    }
                    .measurement-portal-page .card {
                        border: 1px solid #d9dee7;
                        border-radius: 16px;
                        overflow: hidden;
                        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.04);
                    }
                    .measurement-portal-page .card-header {
                        background: #f8fafc;
                        border-bottom: 1px solid #e5e7eb;
                        padding: 1rem 1.4rem;
                    }
                    .measurement-portal-page .card-header h5 {
                        margin: 0;
                        font-size: 1.1rem;
                        font-weight: 700;
                    }
                    .measurement-portal-page .card-body {
                        padding: 1.25rem 1.4rem;
                    }
                    .measurement-portal-page .measurement-progress-meta {
                        font-size: 0.92rem;
                        color: #475569;
                    }
                    .measurement-portal-page .progress {
                        height: 16px !important;
                        background: #e8edf3;
                        border-radius: 999px;
                        overflow: hidden;
                    }
                    .measurement-portal-page .progress-bar {
                        font-size: 0.82rem;
                        font-weight: 700;
                        line-height: 16px;
                    }
                    .measurement-portal-page .measurement-section-header {
                        background: linear-gradient(135deg, #1f4d3a 0%, #2b6d52 100%);
                        color: #fff;
                    }
                    .measurement-portal-page .measurement-toolbar .btn {
                        border-radius: 10px;
                        font-size: 0.92rem;
                        font-weight: 600;
                        padding: 0.45rem 0.8rem;
                    }
                    .measurement-portal-page .table-responsive {
                        border: 1px solid #e5e7eb;
                        border-radius: 14px;
                        overflow: hidden;
                    }
                    .measurement-portal-page .measurement-table {
                        margin-bottom: 0;
                        table-layout: fixed;
                        font-size: 0.95rem;
                    }
                    .measurement-portal-page .measurement-table thead th {
                        background: #f8fafc;
                        color: #0f172a;
                        border-bottom: 1px solid #dbe2ea;
                        font-size: 0.86rem;
                        font-weight: 700;
                        padding: 0.8rem 0.6rem;
                        vertical-align: middle;
                    }
                    .measurement-portal-page .measurement-table tbody td {
                        padding: 0.72rem 0.6rem;
                        vertical-align: middle;
                        border-color: #e8edf3;
                    }
                    .measurement-portal-page .measurement-table tbody tr:nth-child(even) {
                        background: #fbfdff;
                    }
                    .measurement-portal-page .measurement-table .text-right {
                        text-align: right !important;
                    }
                    .measurement-portal-page .measurement-table .qty-cell input,
                    .measurement-portal-page .measurement-table .remarks-cell input {
                        margin-left: auto;
                    }
                    .measurement-portal-page .measurement-table .qty-input {
                        max-width: 110px;
                        min-width: 90px;
                        border-radius: 10px;
                        font-size: 0.92rem;
                    }
                    .measurement-portal-page .measurement-table .remarks-input {
                        max-width: 170px;
                        border-radius: 10px;
                        font-size: 0.9rem;
                    }
                    .measurement-portal-page .measurement-table .qty-badge {
                        display: inline-flex;
                        align-items: center;
                        justify-content: center;
                        min-width: 82px;
                        border-radius: 999px;
                        padding: 0.26rem 0.6rem;
                        font-size: 0.84rem;
                        font-weight: 700;
                    }
                    .measurement-portal-page .measurement-actions .btn {
                        border-radius: 12px;
                        font-weight: 700;
                        padding: 0.72rem 1.05rem;
                    }
                    @keyframes measurementAlertFade {
                        0%, 75% { opacity: 1; transform: translateY(0); }
                        100% { opacity: 0; transform: translateY(-6px); }
                    }
                </style>
                <div class="row mt-4">
                    <div class="col-8">
                        <h3 class="mb-3">
                            <small class="text-muted">Measurement -</small> <span t-field="measurement.name"/>
                            <span t-if="measurement.state == 'draft'" class="badge badge-secondary ml-2">Draft</span>
                            <span t-if="measurement.state == 'submitted'" class="badge badge-info ml-2">Submitted</span>
                            <span t-if="measurement.state == 'checked'" class="badge badge-primary ml-2">Checked</span>
                            <span t-if="measurement.state == 'approved'" class="badge badge-success ml-2">Approved</span>
                            <span t-if="measurement.state == 'rejected'" class="badge badge-danger ml-2">Rejected</span>
                        </h3>
                    </div>
                    <div class="col-4 text-right">
                        <t t-set="progress_pct" t-value="int((contract_certified / contract_revised * 100) if contract_revised and contract_revised > 0 else 0)"/>
                        <div class="mb-2">
                            <span class="badge badge-info" style="font-size: 14px;">
                                Contract Progress: <t t-esc="progress_pct"/>%
                            </span>
                        </div>
                    </div>
                </div>

                <t t-if="success == 'saved'">
                    <div class="alert alert-success measurement-alert" role="alert">
                        <i class="fa fa-check-circle"></i> <strong>Success!</strong> Quantities saved successfully.
                    </div>
                </t>

                <t t-if="success == 'submitted'">
                    <div class="alert alert-success measurement-alert" role="alert">
                        <i class="fa fa-check-circle"></i> <strong>Submitted!</strong> Measurement submitted for approval.
                    </div>
                </t>

                <t t-if="error == 'validation'">
                    <div class="alert alert-warning measurement-alert" role="alert">
                        <i class="fa fa-exclamation-triangle"></i> <strong>Validation Error!</strong> Some quantities exceed allowed amount. Check chatter below for details.
                    </div>
                </t>

                <t t-if="error == 'system'">
                    <div class="alert alert-danger measurement-alert" role="alert">
                        <i class="fa fa-times-circle"></i> <strong>Error!</strong> Could not save measurement. Please contact support.
                    </div>
                </t>

                <t t-if="error == 'submit'">
                    <div class="alert alert-danger measurement-alert" role="alert">
                        <i class="fa fa-times-circle"></i> <strong>Submit Failed!</strong> Could not submit measurement. Please contact support.
                    </div>
                </t>

                <t t-if="error == 'no_lines'">
                    <div class="alert alert-warning measurement-alert" role="alert">
                        <i class="fa fa-exclamation-triangle"></i>
                        <strong>No quantities entered!</strong> Enter at least one quantity before submitting.
                    </div>
                </t>

                <div class="row mb-3">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body py-2">
                                <div class="d-flex justify-content-between mb-1">
                                    <small><strong>Contract Progress</strong></small>
                                    <small class="measurement-progress-meta">
                                        <t t-esc="'%.2f' % (contract_certified or 0.0)"/> /
                                        <t t-esc="'%.2f' % (contract_revised or 0.0)"/>
                                        (<t t-esc="progress_pct"/>%)
                                    </small>
                                </div>
                                <div class="progress" style="height: 20px;">
                                    <div class="progress-bar"
                                         t-att-class="'bg-success' if progress_pct >= 80 else 'bg-primary' if progress_pct >= 50 else 'bg-warning'"
                                         role="progressbar"
                                         t-att-style="'width: ' + str(progress_pct) + '%'"
                                         t-att-aria-valuenow="progress_pct"
                                         aria-valuemin="0"
                                         aria-valuemax="100">
                                        <t t-esc="progress_pct"/>%
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-lg-6">
                        <div class="card">
                            <div class="card-header">
                                <h5>Measurement Information</h5>
                            </div>
                            <div class="card-body">
                                <div class="row mb-2">
                                    <div class="col-5"><strong>Contract:</strong></div>
                                    <div class="col-7"><span t-field="measurement.contract_id"/></div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-5"><strong>Project:</strong></div>
                                    <div class="col-7"><span t-field="measurement.contract_id.project_id"/></div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-5"><strong>Date:</strong></div>
                                    <div class="col-7"><span t-field="measurement.date"/></div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-5"><strong>Period:</strong></div>
                                    <div class="col-7">
                                        <span t-field="measurement.period_from"/> - <span t-field="measurement.period_to"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <t t-if="measurement.state == 'draft'">
                    <div class="card mt-4">
                        <div class="card-header measurement-section-header">
                            <h5 class="mb-0">
                                <i class="fa fa-edit"/> Add Measurement Quantities
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row mb-3 measurement-toolbar">
                                <div class="col-md-6">
                                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="applyBulkQuantity(100)">
                                        <i class="fa fa-percent"/> Apply 100% to All Items
                                    </button>
                                    <button type="button" class="btn btn-sm btn-outline-secondary ml-2" onclick="applyBulkQuantity(50)">
                                        <i class="fa fa-percent"/> Apply 50% to All
                                    </button>
                                    <button type="button" class="btn btn-sm btn-outline-danger ml-2" onclick="clearAllQuantities()">
                                        <i class="fa fa-eraser"/> Clear All
                                    </button>
                                </div>
                            </div>

                            <form method="POST" t-attf-action="/my/employee/measurement/#{measurement.id}/add_lines" id="measurement_form" enctype="multipart/form-data">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                <div class="table-responsive">
                                    <table class="table table-sm table-bordered measurement-table">
                                        <thead class="thead-light">
                                            <tr>
                                                <th style="width: 3%;">#</th>
                                                <th style="width: 8%;">Item Code</th>
                                                <th style="width: 25%;">Description</th>
                                                <th style="width: 8%;" class="text-right">Contract Qty</th>
                                                <th style="width: 8%;" class="text-right">Previous Qty</th>
                                                <th style="width: 8%;" class="text-right">Remaining</th>
                                                <th style="width: 10%;" class="text-right">Current Qty *</th>
                                                <th style="width: 6%;">Unit</th>
                                                <th style="width: 10%;" class="text-right">Unit Rate</th>
                                                <th style="width: 14%;">Remarks</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-set="row_no" t-value="0"/>
                                            <t t-foreach="boq_lines" t-as="boq_line">
                                                <t t-set="row_no" t-value="row_no + 1"/>
                                                <t t-set="existing_line" t-value="existing_lines.get(boq_line.id) if existing_lines else False"/>
                                                <t t-set="previous_qty" t-value="previous_qty_map.get(boq_line.id, 0.0) if previous_qty_map else 0.0"/>
                                                <t t-set="allowed_qty" t-value="boq_line.revised_qty or boq_line.contract_qty"/>
                                                <t t-set="remaining_qty" t-value="allowed_qty - previous_qty"/>

                                                <tr t-att-id="'row_' + str(boq_line.id)">
                                                    <td class="text-center"><strong><t t-esc="row_no"/></strong></td>
                                                    <td><strong><t t-esc="boq_line.item_code or ''"/></strong></td>
                                                    <td><t t-esc="boq_line.description"/></td>
                                                    <td class="text-right">
                                                        <t t-esc="'%.2f' % boq_line.contract_qty"/>
                                                        <input type="hidden" t-att-name="'contract_qty_' + str(boq_line.id)" t-att-value="boq_line.contract_qty"/>
                                                    </td>
                                                    <td class="text-right text-primary">
                                                        <strong><t t-esc="'%.2f' % previous_qty"/></strong>
                                                    </td>
                                                    <td class="text-right">
                                                        <span class="qty-badge"
                                                              t-att-class="'qty-badge badge badge-' + ('success' if remaining_qty > 0 else 'secondary')">
                                                            <t t-esc="'%.2f' % remaining_qty"/>
                                                        </span>
                                                        <input type="hidden" t-att-name="'remaining_qty_' + str(boq_line.id)" t-att-value="remaining_qty"/>
                                                    </td>
                                                    <td class="text-right qty-cell">
                                                        <input type="number"
                                                               step="0.01"
                                                               min="0"
                                                               class="form-control form-control-sm text-right qty-input"
                                                               t-att-name="'qty_' + str(boq_line.id)"
                                                               t-att-id="'qty_' + str(boq_line.id)"
                                                               t-att-data-boq-id="boq_line.id"
                                                               t-att-data-remaining="remaining_qty"
                                                               t-att-value="'%.2f' % (existing_line.current_qty if existing_line else 0.0)"
                                                               onchange="validateQuantity(this)"/>
                                                    </td>
                                                    <td><small><t t-esc="boq_line.uom_id.name"/></small></td>
                                                    <td class="text-right"><small><t t-esc="'%.2f' % boq_line.unit_rate"/></small></td>
                                                    <td class="remarks-cell">
                                                        <input type="text"
                                                               class="form-control form-control-sm remarks-input"
                                                               t-att-name="'remarks_' + str(boq_line.id)"
                                                               t-att-value="existing_line.remarks if existing_line and existing_line.remarks else ''"
                                                               placeholder="Optional notes"/>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>

                                <div class="mt-3">
                                    <h6><i class="fa fa-camera"/> Attach Photos (Optional)</h6>
                                    <input type="file" name="photos" class="form-control-file" multiple="multiple" accept="image/*"/>
                                    <small class="form-text text-muted">You can select multiple photos to attach to this measurement</small>
                                </div>

                                <div class="mt-4 measurement-actions">
                                    <button type="submit" name="action" value="save" class="btn btn-success">
                                        <i class="fa fa-save"/> Save Quantities
                                    </button>
                                    <button type="submit" name="action" value="submit" class="btn btn-primary ml-2">
                                        <i class="fa fa-check"/> Save &amp; Submit for Approval
                                    </button>
                                    <a t-attf-href="/my/employee/measurements" class="btn btn-secondary ml-2">
                                        <i class="fa fa-times"/> Cancel
                                    </a>
                                </div>
                            </form>

                            <script type="text/javascript">
                                <![CDATA[
                                function validateQuantity(input) {
                                    var qty = parseFloat(input.value) || 0;
                                    var remaining = parseFloat(input.getAttribute('data-remaining')) || 0;
                                    var row = input.closest('tr');

                                    var existingWarning = row.querySelector('.qty-warning');
                                    if (existingWarning) {
                                        existingWarning.remove();
                                    }

                                    if (qty > remaining) {
                                        input.style.borderColor = '#ffc107';
                                        input.style.backgroundColor = '#fff3cd';

                                        var warning = document.createElement('div');
                                        warning.className = 'qty-warning';
                                        warning.style.cssText = 'color: #856404; font-size: 11px; margin-top: 2px;';
                                        warning.innerHTML = '<i class="fa fa-exclamation-triangle"></i> Exceeds remaining: ' + remaining.toFixed(2);
                                        input.parentNode.appendChild(warning);
                                    } else {
                                        input.style.borderColor = '';
                                        input.style.backgroundColor = '';
                                    }
                                }

                                function applyBulkQuantity(percentage) {
                                    var inputs = document.querySelectorAll('.qty-input');
                                    inputs.forEach(function(input) {
                                        var boqId = input.getAttribute('data-boq-id');
                                        var contractQtyInput = document.querySelector('input[name="contract_qty_' + boqId + '"]');
                                        if (contractQtyInput) {
                                            var contractQty = parseFloat(contractQtyInput.value) || 0;
                                            var newQty = (contractQty * percentage / 100).toFixed(2);
                                            input.value = newQty;
                                            validateQuantity(input);
                                        }
                                    });
                                }

                                function clearAllQuantities() {
                                    var inputs = document.querySelectorAll('.qty-input');
                                    inputs.forEach(function(input) {
                                        input.value = '0.00';
                                        input.style.borderColor = '';
                                        input.style.backgroundColor = '';
                                        var warning = input.parentNode.querySelector('.qty-warning');
                                        if (warning) warning.remove();
                                    });
                                }

                                document.addEventListener('DOMContentLoaded', function() {
                                    window.setTimeout(function() {
                                        document.querySelectorAll('.measurement-alert').forEach(function(alertBox) {
                                            alertBox.style.pointerEvents = 'none';
                                        });
                                    }, 4200);

                                    var inputs = document.querySelectorAll('.qty-input');
                                    inputs.forEach(function(input) {
                                        if (parseFloat(input.value) > 0) {
                                            validateQuantity(input);
                                        }
                                    });
                                });
                                ]]>
                            </script>
                        </div>
                    </div>
                </t>

                <t t-if="measurement.line_ids and measurement.state != 'draft'">
                    <div class="card mt-4">
                        <div class="card-header">
                            <h5>Measurement Lines</h5>
                        </div>
                        <div class="card-body">
                            <table class="table table-sm table-striped">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Item Code</th>
                                        <th>Description</th>
                                        <th class="text-right">Previous Qty</th>
                                        <th class="text-right">Current Qty</th>
                                        <th class="text-right">Cumulative Qty</th>
                                        <th>Unit</th>
                                        <th class="text-right">Unit Rate</th>
                                        <th>Remarks</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-set="line_no" t-value="0"/>
                                    <t t-foreach="measurement.line_ids" t-as="line">
                                        <t t-set="line_no" t-value="line_no + 1"/>
                                        <tr>
                                            <td><t t-esc="line_no"/></td>
                                            <td>
                                                <strong>
                                                    <t t-if="line.boq_line_id.item_code">
                                                        <t t-esc="line.boq_line_id.item_code"/>
                                                    </t>
                                                </strong>
                                            </td>
                                            <td><span t-field="line.description"/></td>
                                            <td class="text-right"><span t-field="line.previous_qty"/></td>
                                            <td class="text-right"><strong><span t-field="line.current_qty"/></strong></td>
                                            <td class="text-right"><span t-field="line.cumulative_qty"/></td>
                                            <td><span t-field="line.boq_line_id.uom_id"/></td>
                                            <td class="text-right">
                                                <span t-field="line.unit_rate" t-options='{"widget": "monetary", "display_currency": measurement.contract_id.currency_id}'/>
                                            </td>
                                            <td><t t-esc="line.remarks or '-'"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </t>

                <div class="row mt-4 mb-4">
                    <div class="col-12">
                        <a href="/my/employee/measurements" class="btn btn-secondary">
                            <i class="fa fa-arrow-left"/> Back to Measurements
                        </a>
                        <a href="/my/employee" class="btn btn-primary">
                            <i class="fa fa-home"/> Dashboard
                        </a>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- New Measurement -->
    <template id="portal_employee_measurement_new" name="Employee Portal - New Measurement">
        <t t-call="employee_portal_suite.employee_portal_layout">
            <div class="container">
                <div class="row mt-4">
                    <div class="col-12">
                        <h3>New Measurement</h3>
                    </div>
                </div>

                <t t-if="error == 'create_failed'">
                    <div class="alert alert-danger mt-3" role="alert">
                        Could not create measurement. Please check the entered data.
                    </div>
                </t>

                <form method="POST" action="/my/employee/measurement/new" class="mt-4">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="contract_id">Contract *</label>
                                <select name="contract_id" id="contract_id" class="form-control" required="required">
                                    <option value="">Select Contract...</option>
                                    <t t-foreach="contracts" t-as="contract">
                                        <option t-att-value="contract.id">
                                            <t t-esc="contract.name"/> - <t t-esc="contract.project_id.name"/>
                                        </option>
                                    </t>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="date">Date *</label>
                                <input type="date" name="date" id="date" class="form-control" required="required"/>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="period_from">Period From *</label>
                                <input type="date" name="period_from" id="period_from" class="form-control" required="required"/>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="period_to">Period To *</label>
                                <input type="date" name="period_to" id="period_to" class="form-control" required="required"/>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-info">
                        <i class="fa fa-info-circle"/> After creating the measurement, you'll be able to add quantities for each BOQ item.
                    </div>

                    <div class="form-group">
                        <button type="submit" class="btn btn-primary">
                            <i class="fa fa-save"/> Create Measurement
                        </button>
                        <a href="/my/employee/measurements" class="btn btn-secondary">
                            <i class="fa fa-times"/> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </t>
    </template>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Contracts List -->
    <template id="portal_employee_contracts" name="Employee Portal - Contracts">
        <t t-call="employee_portal_suite.employee_portal_layout">
            <div class="container mt-4">
                <div class="row">
                    <div class="col-12">
                        <h3>Construction Contracts</h3>
                    </div>
                </div>

                <t t-if="not contracts">
                    <div class="alert alert-info mt-3" role="alert">
                        There are currently no contracts for your account.
                    </div>
                </t>

                <t t-if="contracts">
                    <div class="d-flex justify-content-end mt-3 mb-3">
                        <form method="get" action="/my/employee/contracts" class="d-flex flex-wrap align-items-center" style="gap: 0.65rem 0.85rem;">
                            <input type="hidden" name="sortby" t-att-value="sortby or 'date'"/>
                            <div class="d-flex align-items-center" style="gap: 0.5rem;">
                                <label class="mb-0 font-weight-bold text-muted">Show:</label>
                                <select name="status_filter" class="form-control" style="min-width: 150px; max-width: 180px; border-radius: 12px;">
                                    <t t-foreach="status_options.items() if status_options else []" t-as="status_option">
                                        <option t-att-value="status_option[0]" t-att-selected="status_filter == status_option[0] and 'selected' or None">
                                            <t t-esc="status_option[1]['label']"/>
                                        </option>
                                    </t>
                                </select>
                            </div>
                            <div class="d-flex align-items-center" style="gap: 0.5rem;">
                                <label class="mb-0 font-weight-bold text-muted">Direction:</label>
                                <select name="direction_filter" class="form-control" style="min-width: 170px; max-width: 190px; border-radius: 12px;">
                                    <t t-foreach="direction_options.items() if direction_options else []" t-as="direction_option">
                                        <option t-att-value="direction_option[0]" t-att-selected="direction_filter == direction_option[0] and 'selected' or None">
                                            <t t-esc="direction_option[1]['label']"/>
                                        </option>
                                    </t>
                                </select>
                            </div>
                            <button type="submit" class="btn btn-primary">Apply</button>
                            <a href="/my/employee/contracts" class="btn btn-secondary">Reset</a>
                        </form>
                    </div>

                    <div class="table-responsive mt-3">
                        <table class="table table-hover">
                            <thead class="thead-light">
                                <tr>
                                    <th>Contract #</th>
                                    <th>Project</th>
                                    <th>Direction</th>
                                    <th>Start Date</th>
                                    <th>End Date</th>
                                    <th class="text-right">Contract Value</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="contracts" t-as="contract">
                                    <tr>
                                        <td><a t-attf-href="/my/employee/contract/#{contract.id}"><t t-esc="contract.name"/></a></td>
                                        <td><span t-field="contract.project_id"/></td>
                                        <td><span t-esc="'Client Contract' if contract.contract_direction == 'inbound' else 'Subcontract'"/></td>
                                        <td><span t-field="contract.date_start"/></td>
                                        <td><span t-field="contract.date_end"/></td>
                                        <td class="text-right"><span t-field="contract.revised_amount" t-options='{"widget": "monetary", "display_currency": contract.currency_id}'/></td>
                                        <td>
                                            <span t-if="contract.state == 'draft'" class="badge badge-secondary">Draft</span>
                                            <span t-if="contract.state == 'under_review'" class="badge badge-info">Under Review</span>
                                            <span t-if="contract.state == 'approved'" class="badge badge-success">Approved</span>
                                            <span t-if="contract.state == 'active'" class="badge badge-primary">Active</span>
                                            <span t-if="contract.state == 'completed'" class="badge badge-success">Completed</span>
                                            <span t-if="contract.state == 'closed'" class="badge badge-dark">Closed</span>
                                            <span t-if="contract.state == 'cancelled'" class="badge badge-danger">Cancelled</span>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination -->
                    <t t-if="pager" t-call="portal.pager"/>
                </t>

                <div class="row mt-3 mb-4">
                    <div class="col-12">
                        <a href="/my/employee" class="btn btn-secondary">
                            <i class="fa fa-arrow-left"/> Back to Dashboard
                        </a>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Contract Detail - FIXED -->
    <template id="portal_employee_contract_detail" name="Employee Portal - Contract Detail">
        <t t-call="employee_portal_suite.employee_portal_layout">
            <div class="container">
                <div class="row mt-4">
                    <div class="col-md-8">
                        <h3 class="mb-3">
                            <small class="text-muted">Contract -</small> <span t-field="contract.name"/>
                        </h3>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-12">
                        <a t-attf-href="/my/employee/contract/#{contract.id}?report_type=pdf" class="btn btn-primary" target="_blank" rel="noopener">
                            <i class="fa fa-print"/> Print Contract
                        </a>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-lg-6">
                        <div class="card">
                            <div class="card-header">
                                <h5>Contract Information</h5>
                            </div>
                            <div class="card-body">
                                <div class="row mb-2">
                                    <div class="col-5"><strong>Project:</strong></div>
                                    <div class="col-7"><span t-field="contract.project_id"/></div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-5"><strong>Partner:</strong></div>
                                    <div class="col-7"><span t-field="contract.partner_id"/></div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-5"><strong>Direction:</strong></div>
                                    <div class="col-7">
                                        <span t-if="contract.contract_direction == 'inbound'" class="badge badge-info">Client Contract</span>
                                        <span t-if="contract.contract_direction == 'outbound'" class="badge badge-warning">Subcontract</span>
                                    </div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-5"><strong>Start Date:</strong></div>
                                    <div class="col-7"><span t-field="contract.date_start"/></div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-5"><strong>End Date:</strong></div>
                                    <div class="col-7"><span t-field="contract.date_end"/></div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-5"><strong>Status:</strong></div>
                                    <div class="col-7">
                                        <span t-if="contract.state == 'draft'" class="badge badge-secondary">Draft</span>
                                        <span t-if="contract.state == 'under_review'" class="badge badge-info">Under Review</span>
                                        <span t-if="contract.state == 'approved'" class="badge badge-success">Approved</span>
                                        <span t-if="contract.state == 'active'" class="badge badge-primary">Active</span>
                                        <span t-if="contract.state == 'completed'" class="badge badge-success">Completed</span>
                                        <span t-if="contract.state == 'closed'" class="badge badge-dark">Closed</span>
                                        <span t-if="contract.state == 'cancelled'" class="badge badge-danger">Cancelled</span>
                                    </div>
                                </div>
                            <div class="row mb-2">
                                <div class="col-5"><strong>Payment Terms:</strong></div>
                                <div class="col-7">
                                    <span t-field="contract.payment_term_id"/>
                                </div>
                            </div>
                        </div>
                    </div>
                     </div>

                    <div class="col-lg-6">
                        <div class="card">
                            <div class="card-header">
                                <h5>Financial Summary</h5>
                            </div>
                            <div class="card-body">
                                <div class="row mb-2">
                                    <div class="col-6"><strong>Original Amount:</strong></div>
                                    <div class="col-6 text-right"><span t-field="contract.original_amount" t-options='{"widget": "monetary", "display_currency": contract.currency_id}'/></div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-6"><strong>Revised Amount:</strong></div>
                                    <div class="col-6 text-right"><span t-field="contract.revised_amount" t-options='{"widget": "monetary", "display_currency": contract.currency_id}'/></div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-6"><strong>Total Certified:</strong></div>
                                    <div class="col-6 text-right"><span t-field="contract.total_certified_amount" t-options='{"widget": "monetary", "display_currency": contract.currency_id}'/></div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-6"><strong>Total Measured:</strong></div>
                                    <div class="col-6 text-right"><span t-field="contract.total_measured_amount" t-options='{"widget": "monetary", "display_currency": contract.currency_id}'/></div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-6"><strong>Advance %:</strong></div>
                                    <div class="col-6 text-right"><span t-field="contract.advance_percent"/>%</div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-6"><strong>Advance Amount:</strong></div>
                                    <div class="col-6 text-right"><span t-field="contract.advance_amount" t-options='{"widget": "monetary", "display_currency": contract.currency_id}'/></div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-6"><strong>Advance Recovered:</strong></div>
                                    <div class="col-6 text-right"><span t-field="contract.advance_recovered" t-options='{"widget": "monetary", "display_currency": contract.currency_id}'/></div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-6"><strong>Advance Balance:</strong></div>
                                    <div class="col-6 text-right"><span t-field="contract.advance_balance" t-options='{"widget": "monetary", "display_currency": contract.currency_id}'/></div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-6"><strong>Latest Advance Payment:</strong></div>
                                    <div class="col-6 text-right">
                                        <t t-set="latest_advance" t-value="contract.advance_ids[:1]"/>
                                        <t t-if="latest_advance">
                                            <span t-if="latest_advance.payment_status == 'no_move'" class="badge badge-secondary">Not Invoiced</span>
                                            <span t-if="latest_advance.payment_status == 'not_paid'" class="badge badge-warning">Not Paid</span>
                                            <span t-if="latest_advance.payment_status == 'partial'" class="badge badge-info">Partial</span>
                                            <span t-if="latest_advance.payment_status == 'in_payment'" class="badge badge-primary">In Payment</span>
                                            <span t-if="latest_advance.payment_status == 'paid'" class="badge badge-success">Paid</span>
                                            <span t-if="latest_advance.payment_status == 'cancelled'" class="badge badge-danger">Cancelled</span>
                                        </t>
                                        <t t-if="not latest_advance">-</t>
                                    </div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-6"><strong>Retention %:</strong></div>
                                    <div class="col-6 text-right"><span t-field="contract.retention_percent"/>%</div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-6"><strong>VAT %:</strong></div>
                                    <div class="col-6 text-right"><span t-field="contract.vat_percent"/>%</div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-6"><strong>Latest Retention Release:</strong></div>
                                    <div class="col-6 text-right">
                                        <t t-set="latest_retention" t-value="contract.retention_release_ids[:1]"/>
                                        <t t-if="latest_retention">
                                            <span t-if="latest_retention.payment_status == 'no_move'" class="badge badge-secondary">Not Posted</span>
                                            <span t-if="latest_retention.payment_status == 'not_paid'" class="badge badge-warning">Not Paid</span>
                                            <span t-if="latest_retention.payment_status == 'partial'" class="badge badge-info">Partial</span>
                                            <span t-if="latest_retention.payment_status == 'in_payment'" class="badge badge-primary">In Payment</span>
                                            <span t-if="latest_retention.payment_status == 'paid'" class="badge badge-success">Paid</span>
                                            <span t-if="latest_retention.payment_status == 'cancelled'" class="badge badge-danger">Cancelled</span>
                                        </t>
                                        <t t-if="not latest_retention">-</t>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <t t-if="contract.boq_line_ids">
                    <div class="card mt-4">
                        <div class="card-header">
                            <h5>Bill of Quantities</h5>
                        </div>
                        <div class="card-body">
                            <table class="table table-sm table-striped">
                                <thead>
                                    <tr>
                                        <th>Item Code</th>
                                        <th>Description</th>
                                        <th class="text-right">Quantity</th>
                                        <th>Unit</th>
                                        <th class="text-right">Unit Rate</th>
                                        <th class="text-right">Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="contract.boq_line_ids" t-as="line">
                                        <tr>
                                            <td><span t-esc="line.item_code or ''"/></td>
                                            <td><span t-esc="line.description or ''"/></td>
                                            <td class="text-right"><t t-esc="'%.2f' % (line.contract_qty or 0)"/></td>
                                            <td><span t-field="line.uom_id"/></td>
                                            <td class="text-right"><span t-field="line.unit_rate" t-options='{"widget": "monetary", "display_currency": contract.currency_id}'/></td>
                                            <td class="text-right"><span t-field="line.total_amount" t-options='{"widget": "monetary", "display_currency": contract.currency_id}'/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </t>

                <div class="row mt-4 mb-4">
                    <div class="col-12">
                        <a href="/my/employee/contracts" class="btn btn-secondary">
                            <i class="fa fa-arrow-left"/> Back to Contracts
                        </a>
                        <a href="/my/employee" class="btn btn-primary">
                            <i class="fa fa-home"/> Dashboard
                        </a>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Variations List with NEW button -->
    <template id="portal_employee_variations" name="Employee Portal - Variations">
        <t t-call="employee_portal_suite.employee_portal_layout">
            <div class="container mt-4">
                <div class="row">
                    <div class="col-8">
                        <h3>Variations</h3>
                    </div>
                    <div class="col-4 text-right">
                        <a href="/my/employee/variation/new" class="btn btn-warning">
                            <i class="fa fa-plus"/> New Variation Request
                        </a>
                    </div>
                </div>

                <t t-if="not variations">
                    <div class="alert alert-info mt-3" role="alert">
                        There are currently no variations. Click "New Variation Request" to create one.
                    </div>
                </t>

                <t t-if="variations">
                    <form method="get" action="/my/employee/variations" class="form-row align-items-end mt-3 mb-3">
                        <input type="hidden" name="sortby" t-att-value="sortby or 'date'"/>
                        <div class="col-md-4 col-lg-3">
                            <label class="small font-weight-bold mb-1">Project</label>
                            <select name="project_filter" class="form-control">
                                <t t-foreach="project_options or []" t-as="project_option">
                                    <option t-att-value="project_option['value']" t-att-selected="project_filter == project_option['value'] and 'selected' or None">
                                        <t t-esc="project_option['label']"/>
                                    </option>
                                </t>
                            </select>
                        </div>
                        <div class="col-md-4 col-lg-3">
                            <label class="small font-weight-bold mb-1">Status</label>
                            <select name="status_filter" class="form-control">
                                <t t-foreach="status_options.items() if status_options else []" t-as="status_option">
                                    <option t-att-value="status_option[0]" t-att-selected="status_filter == status_option[0] and 'selected' or None">
                                        <t t-esc="status_option[1]['label']"/>
                                    </option>
                                </t>
                            </select>
                        </div>
                        <div class="col-md-4 col-lg-3">
                            <button type="submit" class="btn btn-primary mr-2">Apply</button>
                            <a href="/my/employee/variations" class="btn btn-secondary">Reset</a>
                        </div>
                    </form>

                    <div class="table-responsive mt-3">
                        <table class="table table-hover">
                            <thead class="thead-light">
                                <tr>
                                    <th>Variation #</th>
                                    <th>Contract</th>
                                    <th>Project</th>
                                    <th>Date</th>
                                    <th>Description</th>
                                    <th class="text-right">Amount</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="variations" t-as="variation">
                                    <tr>
                                        <td><a t-attf-href="/my/employee/variation/#{variation.id}"><t t-esc="variation.name"/></a></td>
                                        <td><span t-field="variation.contract_id"/></td>
                                        <td><span t-field="variation.contract_id.project_id"/></td>
                                        <td><span t-field="variation.date"/></td>
                                        <td><span t-field="variation.description"/></td>
                                        <td class="text-right"><span t-field="variation.total_amount" t-options='{"widget": "monetary", "display_currency": variation.currency_id}'/></td>
                                        <td>
                                            <span t-if="variation.state == 'draft'" class="badge badge-secondary">Draft</span>
                                            <span t-if="variation.state == 'submitted'" class="badge badge-info">Submitted</span>
                                            <span t-if="variation.state == 'approved'" class="badge badge-success">Approved</span>
                                            <span t-if="variation.state == 'rejected'" class="badge badge-danger">Rejected</span>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination -->
                    <t t-if="pager" t-call="portal.pager"/>
                </t>

                <div class="row mt-3 mb-4">
                    <div class="col-12">
                        <a href="/my/employee" class="btn btn-secondary">
                            <i class="fa fa-arrow-left"/> Back to Dashboard
                        </a>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Variation Detail -->
    <template id="portal_employee_variation_detail" name="Employee Portal - Variation Detail">
        <t t-call="employee_portal_suite.employee_portal_layout">
            <div class="container">
                <div class="row mt-4">
                    <div class="col-12">
                        <h3 class="mb-3">
                            <small class="text-muted">Variation -</small> <span t-field="variation.name"/>
                            <span t-if="variation.state == 'draft'" class="badge badge-secondary ml-2">Draft</span>
                            <span t-if="variation.state == 'submitted'" class="badge badge-info ml-2">Submitted</span>
                            <span t-if="variation.state == 'approved'" class="badge badge-success ml-2">Approved</span>
                            <span t-if="variation.state == 'rejected'" class="badge badge-danger ml-2">Rejected</span>
                        </h3>
                    </div>
                </div>

                <t t-set="description_parts" t-value="(variation.description or '').split('\n\nReason: ', 1)"/>
                <t t-set="variation_summary" t-value="description_parts[0] if description_parts else ''"/>
                <t t-set="variation_reason" t-value="description_parts[1] if len(description_parts) &gt; 1 else ''"/>

                <t t-if="success == 'saved'">
                    <div class="alert alert-success" role="alert">
                        Variation line saved successfully.
                    </div>
                </t>
                <t t-if="success == 'submitted'">
                    <div class="alert alert-success" role="alert">
                        Variation submitted for approval.
                    </div>
                </t>
                <t t-if="error == 'boq_required'">
                    <div class="alert alert-warning" role="alert">
                        Please select a BOQ line for all variation types except New Item.
                    </div>
                </t>
                <t t-if="error == 'validation'">
                    <div class="alert alert-warning" role="alert">
                        Could not save the variation line. Please check the entered values.
                    </div>
                </t>
                <t t-if="error == 'system'">
                    <div class="alert alert-danger" role="alert">
                        Something went wrong while saving the variation.
                    </div>
                </t>

                <div class="row mb-4">
                    <div class="col-lg-8">
                        <div class="card">
                            <div class="card-header">
                                <h5>Variation Information</h5>
                            </div>
                            <div class="card-body">
                                <div class="row mb-2">
                                    <div class="col-4"><strong>Contract:</strong></div>
                                    <div class="col-8"><span t-field="variation.contract_id"/></div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-4"><strong>Date:</strong></div>
                                    <div class="col-8"><span t-field="variation.date"/></div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-4"><strong>Project:</strong></div>
                                    <div class="col-8"><span t-field="variation.contract_id.project_id"/></div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-4"><strong>Description:</strong></div>
                                    <div class="col-8" style="white-space: pre-line;"><t t-esc="variation_summary or '-'"/></div>
                                </div>
                                <div class="row mb-2" t-if="variation_reason">
                                    <div class="col-4"><strong>Reason:</strong></div>
                                    <div class="col-8" style="white-space: pre-line;"><t t-esc="variation_reason"/></div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-4"><strong>Total Amount:</strong></div>
                                    <div class="col-8"><span t-field="variation.total_amount" t-options='{"widget": "monetary", "display_currency": variation.currency_id}'/></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <t t-if="variation.state == 'draft'">
                    <div class="card mt-4">
                        <div class="card-header">
                            <h5>Add Variation Line</h5>
                        </div>
                        <div class="card-body">
                            <form method="POST" t-attf-action="/my/employee/variation/#{variation.id}/add_line">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label>Type *</label>
                                            <select name="type" class="form-control" required="required">
                                                <option value="">Select type...</option>
                                                <t t-foreach="line_types" t-as="line_type">
                                                    <option t-att-value="line_type[0]"><t t-esc="line_type[1]"/></option>
                                                </t>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label>BOQ Line</label>
                                            <select name="boq_line_id" class="form-control">
                                                <option value="">Select BOQ line...</option>
                                                <t t-foreach="boq_lines" t-as="boq_line">
                                                    <option t-att-value="boq_line.id">
                                                        <t t-esc="boq_line.item_code or '-'"/> - <t t-esc="boq_line.description or ''"/>
                                                    </option>
                                                </t>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label>Unit of Measure</label>
                                            <select name="uom_id" class="form-control">
                                                <option value="">Auto from BOQ</option>
                                                <t t-foreach="uoms" t-as="uom">
                                                    <option t-att-value="uom.id"><t t-esc="uom.name"/></option>
                                                </t>
                                            </select>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label>Section</label>
                                            <input type="text" name="section" class="form-control"/>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label>Item Code</label>
                                            <input type="text" name="item_code" class="form-control"/>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label>Variation Qty</label>
                                            <input type="number" step="0.01" min="0" name="variation_qty" class="form-control" required="required"/>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label>Unit Rate</label>
                                            <input type="number" step="0.01" min="0" name="unit_rate" class="form-control" required="required"/>
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label>Description</label>
                                    <textarea name="line_description" class="form-control" rows="3"/>
                                </div>

                                <div class="form-group">
                                    <button type="submit" name="action" value="save" class="btn btn-warning">
                                        <i class="fa fa-save"/> Save Line
                                    </button>
                                    <button type="submit" name="action" value="submit" class="btn btn-primary">
                                        <i class="fa fa-check"/> Save &amp; Submit
                                    </button>
                                    <t t-if="variation.line_ids">
                                        <button type="submit" name="action" value="submit" class="btn btn-success" formnovalidate="formnovalidate">
                                            <i class="fa fa-paper-plane"/> Submit Existing Lines
                                        </button>
                                    </t>
                                </div>
                            </form>
                        </div>
                    </div>
                </t>

                <t t-if="variation.line_ids">
                    <div class="card mt-4">
                        <div class="card-header">
                            <h5>Variation Lines</h5>
                        </div>
                        <div class="card-body">
                            <table class="table table-sm table-striped">
                                <thead>
                                    <tr>
                                        <th>Type</th>
                                        <th>BOQ Ref</th>
                                        <th>Section</th>
                                        <th>Item Code</th>
                                        <th>Description</th>
                                        <th class="text-right">Original Qty</th>
                                        <th class="text-right">Variation Qty</th>
                                        <th class="text-right">Revised Qty</th>
                                        <th>Unit</th>
                                        <th class="text-right">Unit Rate</th>
                                        <th class="text-right">Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="variation.line_ids" t-as="line">
                                        <tr>
                                            <td>
                                                <t t-if="line.type == 'increase'">Quantity Increase</t>
                                                <t t-if="line.type == 'decrease'">Quantity Decrease</t>
                                                <t t-if="line.type == 'new'">New Item</t>
                                                <t t-if="line.type == 'omit'">Omit Item</t>
                                                <t t-if="line.type == 'rate'">Rate Change</t>
                                            </td>
                                            <td>
                                                <t t-if="line.boq_line_id">
                                                    <t t-esc="line.boq_line_id.item_code or line.boq_line_id.display_name"/>
                                                </t>
                                                <t t-elif="line.created_boq_line_id">
                                                    <t t-esc="line.created_boq_line_id.item_code or line.created_boq_line_id.display_name"/>
                                                </t>
                                                <t t-else="">-</t>
                                            </td>
                                            <td><t t-esc="line.section or '-'"/></td>
                                            <td><t t-esc="line.item_code or '-'"/></td>
                                            <td><span t-field="line.description"/></td>
                                            <td class="text-right"><span t-field="line.original_qty"/></td>
                                            <td class="text-right"><span t-field="line.variation_qty"/></td>
                                            <td class="text-right"><span t-field="line.revised_qty"/></td>
                                            <td><span t-field="line.uom_id"/></td>
                                            <td class="text-right"><span t-field="line.unit_rate" t-options='{"widget": "monetary", "display_currency": variation.currency_id}'/></td>
                                            <td class="text-right"><span t-field="line.amount" t-options='{"widget": "monetary", "display_currency": variation.currency_id}'/></td>
                                        </tr>
                                        <tr t-if="line.type == 'new' and line.created_boq_line_id">
                                            <td colspan="10" class="text-muted small">
                                                Approved new item created BOQ line:
                                                <strong><t t-esc="line.created_boq_line_id.item_code or line.created_boq_line_id.display_name"/></strong>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </t>

                <div class="row mt-4 mb-4">
                    <div class="col-12">
                        <a href="/my/employee/variations" class="btn btn-secondary">
                            <i class="fa fa-arrow-left"/> Back to Variations
                        </a>
                        <a href="/my/employee" class="btn btn-primary">
                            <i class="fa fa-home"/> Dashboard
                        </a>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- NEW Variation Form -->
    <template id="portal_employee_variation_new" name="Employee Portal - New Variation">
        <t t-call="employee_portal_suite.employee_portal_layout">
            <div class="container">
                <div class="row mt-4">
                    <div class="col-12">
                        <h3>New Variation Request</h3>
                    </div>
                </div>

                <form method="POST" action="/my/employee/variation/new" class="mt-4">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="contract_id">Contract *</label>
                                <select name="contract_id" id="contract_id" class="form-control" required="required">
                                    <option value="">Select Contract...</option>
                                    <t t-foreach="contracts" t-as="contract">
                                        <option t-att-value="contract.id"><t t-esc="contract.name"/> - <t t-esc="contract.project_id.name"/></option>
                                    </t>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="date">Date *</label>
                                <input type="date" name="date" id="date" class="form-control" required="required"/>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="description">Description of Change *</label>
                        <textarea name="description" id="description" class="form-control" rows="4" required="required" placeholder="Describe the scope change or variation request..."></textarea>
                    </div>

                    <div class="form-group">
                        <label for="reason">Reason for Variation</label>
                        <textarea name="reason" id="reason" class="form-control" rows="3" placeholder="Explain why this variation is needed..."></textarea>
                    </div>

                    <div class="alert alert-info">
                        <i class="fa fa-info-circle"/> After creating the variation, you'll be able to add line items with quantities and rates.
                    </div>

                    <div class="form-group">
                        <button type="submit" class="btn btn-warning">
                            <i class="fa fa-save"/> Submit Variation Request
                        </button>
                        <a href="/my/employee/variations" class="btn btn-secondary">
                            <i class="fa fa-times"/> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </t>
    </template>
</odoo>

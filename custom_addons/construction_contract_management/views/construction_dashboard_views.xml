<odoo>

    <record id="view_construction_dashboard_form" model="ir.ui.view">
        <field name="name">construction.dashboard.form</field>
        <field name="model">construction.dashboard</field>
        <field name="arch" type="xml">
            <form string="Construction Dashboard" create="0" delete="0">
                <sheet>
                    <div class="oe_title">
                        <h1>Construction Dashboard</h1>
                    </div>
                    <group string="Filters">
                        <group>
                            <field name="selected_contract_id" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <button name="action_clear_contract_filter"
                                    string="Clear Filter"
                                    type="object"
                                    class="btn-secondary"
                                    invisible="not selected_contract_id"/>
                        </group>
                    </group>
                    <group string="Key Metrics">
                        <group>
                            <field name="active_contract_count" readonly="1"/>
                            <button name="action_open_active_contracts" string="Open Active Contracts" type="object" class="btn-link"/>
                        </group>
                        <group>
                            <field name="pending_ipc_count" readonly="1"/>
                            <button name="action_open_pending_ipcs" string="Open Pending IPCs" type="object" class="btn-link"/>
                        </group>
                        <group>
                            <field name="pending_variation_count" readonly="1"/>
                            <button name="action_open_pending_variations" string="Open Pending Variations" type="object" class="btn-link"/>
                        </group>
                        <group>
                            <field name="pending_advance_count" readonly="1"/>
                            <button name="action_open_pending_advances" string="Open Pending Advances" type="object" class="btn-link"/>
                        </group>
                    </group>

                    <group string="Financial Summary">
                        <group>
                            <field name="total_revised_amount" readonly="1"/>
                        </group>
                        <group>
                            <field name="total_certified_amount" readonly="1"/>
                        </group>
                        <group>
                            <field name="total_invoiced_amount" readonly="1"/>
                        </group>
                        <group>
                            <field name="total_paid_amount" readonly="1"/>
                        </group>
                    </group>

                    <group string="Balances">
                        <group>
                            <field name="total_advance_balance" readonly="1"/>
                        </group>
                        <group>
                            <field name="total_retention_balance" readonly="1"/>
                        </group>
                        <group>
                            <field name="pending_retention_release_count" readonly="1"/>
                            <button name="action_open_pending_retention_releases" string="Open Pending Releases" type="object" class="btn-link"/>
                        </group>
                    </group>

                    <group string="Quick Actions">
                        <group>
                            <button name="action_new_contract" string="New Contract" type="object" class="btn-primary"/>
                        </group>
                        <group>
                            <button name="action_new_ipc" string="New IPC" type="object" class="btn-primary"/>
                        </group>
                        <group>
                            <button name="action_new_variation" string="New Variation" type="object" class="btn-primary"/>
                        </group>
                        <group>
                            <button name="action_new_advance" string="New Advance" type="object" class="btn-primary"/>
                        </group>
                        <group>
                            <button name="action_new_retention_release" string="New Retention Release" type="object" class="btn-primary"/>
                        </group>
                    </group>

                    <group string="Navigation">
                        <button name="action_open_contracts" string="Open All Contracts" type="object" class="btn-secondary"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_construction_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">construction.dashboard</field>
        <field name="view_mode">form</field>
        <field name="res_id" ref="construction_contract_management.construction_dashboard_main"/>
        <field name="target">current</field>
    </record>

</odoo>
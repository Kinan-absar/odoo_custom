<odoo>

    <!-- List View -->
    <record id="view_construction_ipc_list" model="ir.ui.view">
        <field name="name">construction.ipc.list</field>
        <field name="model">construction.ipc</field>
        <field name="arch" type="xml">
            <list string="IPCs" default_order="id desc">
                <field name="name"/>
                <field name="contract_id"/>
                <field name="contract_direction"/>
                <field name="measurement_id"/>
                <field name="ipc_date"/>
                <field name="current_work_value"/>
                <field name="retention_amount"/>
                <field name="advance_recovery_amount"/>
                <field name="deduction_amount"/>
                <field name="net_amount"/>
                <field name="payment_status"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_construction_ipc_form" model="ir.ui.view">
        <field name="name">construction.ipc.form</field>
        <field name="model">construction.ipc</field>
        <field name="arch" type="xml">
            <form string="IPC">
                <header>
                    <button name="action_load_from_measurement" string="Load from Measurement" type="object" class="btn-primary" invisible="state != 'draft' or not measurement_id"/>
                    <button name="action_submit_review" string="Submit for Review" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object" class="btn-primary" invisible="state != 'under_review'"/>
                    <button name="action_done" string="Mark Done" type="object" invisible="state != 'approved'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ['done','cancelled']"/>
                    <button name="action_reset_to_draft" string="Reset to Draft" type="object" invisible="state == 'draft'"/>
                    <button name="action_create_move"
                            string="Create Invoice/Bill"
                            type="object"
                            class="btn-primary"
                            invisible="state not in ['approved','done'] or move_id"/>
                    <button name="%(construction_contract_management.action_report_construction_ipc)d"
                            string="Print"
                            type="action"
                            class="btn-secondary"
                            invisible="not id"/>
                    <button name="action_view_move"
                            string="View Invoice/Bill"
                            type="object"
                            invisible="not move_id"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,under_review,approved,done,cancelled"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_move"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-file-text-o"
                                invisible="not move_id">
                            <field name="move_count" widget="statinfo" string="Invoice/Bill"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="contract_id"/>
                            <field name="contract_direction" readonly="1"/>
                            <field name="measurement_id" domain="[('contract_id', '=', contract_id), ('state', '=', 'approved')]"/>
                        </group>
                        <group>
                            <field name="ipc_date"/>
                            <field name="period_from"/>
                            <field name="period_to"/>
                            <field name="payment_status" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                       <page string="IPC Lines">
    <field name="line_ids" >
        <list editable="bottom">
            <field name="display_type" column_invisible="True"/>

            <field name="boq_line_id" invisible="display_type != False"/>
            <field name="measurement_line_id" optional="hide" invisible="display_type != False"/>
            <field name="description" 
       decoration-bf="display_type == 'line_section'"
       decoration-it="display_type == 'line_note'" readonly="1"/>

            <field name="previous_qty" invisible="display_type != False"/>
            <field name="previous_percent" readonly="1" invisible="display_type != False"/>
            <field name="current_qty" invisible="display_type != False"/>
            <field name="current_percent" readonly="1" invisible="display_type != False"/>
            <field name="cumulative_qty" invisible="display_type != False"/>
            <field name="cumulative_percent" readonly="1" invisible="display_type != False"/>
            <field name="allowed_qty" readonly="1" invisible="display_type != False"/>
            <field name="remaining_qty" readonly="1" invisible="display_type != False"/>
            <field name="unit_rate" invisible="display_type != False"/>
            <field name="current_value" readonly="1" invisible="display_type != False"/>
            <field name="cumulative_value" readonly="1" invisible="display_type != False"/>
        </list>
    </field>
</page>

                        <page string="Amounts">
                            <group>
                                <group>
                                    <field name="previous_certified_value" readonly="1"/>
                                    <field name="current_work_value" readonly="1"/>
                                    <field name="cumulative_certified_value" readonly="1"/>
                                </group>
                                <group>
                                    <field name="advance_recovery_amount" readonly="1"/>
                                    <field name="vat_amount" readonly="1"/>
                                    <field name="gross_with_vat" readonly="1"/>
                                    <field name="retention_amount" readonly="1"/>
                                    <field name="deduction_amount"/>
                                    <field name="net_amount" readonly="1"/>
                                    <field name="payment_status" readonly="1"/>
                                    <field name="move_id" readonly="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_construction_ipc_search" model="ir.ui.view">
        <field name="name">construction.ipc.search</field>
        <field name="model">construction.ipc</field>
        <field name="arch" type="xml">
            <search string="Search IPCs">
                <field name="name"/>
                <field name="contract_id"/>
                <field name="measurement_id"/>

                <filter string="Client Contract" name="filter_inbound" domain="[('contract_direction','=','inbound')]"/>
                <filter string="Subcontract" name="filter_outbound" domain="[('contract_direction','=','outbound')]"/>
                <filter string="Approved" name="filter_approved" domain="[('state','=','approved')]"/>
                <filter string="Done" name="filter_done" domain="[('state','=','done')]"/>

                <group expand="0" string="Group By">
                    <filter string="Contract" name="group_contract" context="{'group_by': 'contract_id'}"/>
                    <filter string="Direction" name="group_direction" context="{'group_by': 'contract_direction'}"/>
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_construction_ipc" model="ir.actions.act_window">
        <field name="name">IPCs</field>
        <field name="res_model">construction.ipc</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_construction_ipc_search"/>
    </record>

</odoo>

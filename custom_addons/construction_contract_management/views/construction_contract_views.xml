<odoo>

    <!-- List View -->
    <record id="view_construction_contract_list" model="ir.ui.view">
        <field name="name">construction.contract.list</field>
        <field name="model">construction.contract</field>
        <field name="arch" type="xml">
            <list string="Construction Contracts" default_order="id desc">
                <field name="name"/>
                <field name="project_id"/>
                <field name="partner_id"/>
                <field name="contract_direction"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="original_amount"/>
                <field name="revised_amount"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_construction_contract_form" model="ir.ui.view">
        <field name="name">construction.contract.form</field>
        <field name="model">construction.contract</field>
        <field name="arch" type="xml">
            <form string="Construction Contract">
                <header>
                    <button name="action_submit_review" string="Submit for Review" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object" class="btn-primary" invisible="state != 'under_review'"/>
                    <button name="action_activate" string="Activate" type="object" class="btn-primary" invisible="state != 'approved'"/>
                    <button name="action_complete" string="Mark Completed" type="object" invisible="state != 'active'"/>
                    <button name="action_close" string="Close" type="object" invisible="state not in ['completed']"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ['closed','cancelled']"/>
                    <button name="action_reset_to_draft" string="Reset to Draft" type="object" invisible="state == 'draft'"/>

                    <field name="state" widget="statusbar" statusbar_visible="draft,under_review,approved,active,completed,closed,cancelled"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" name="action_view_measurements" class="oe_stat_button" icon="fa-ruler">
                            <field name="measurement_count" widget="statinfo" string="Measurements"/>
                        </button>
                        <button type="object" name="action_view_ipcs" class="oe_stat_button" icon="fa-file-text-o">
                            <field name="ipc_count" widget="statinfo" string="IPCs"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="partner_id"/>
                            <field name="contract_direction"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="currency_id" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Contract Details">
                            <group>
                                <group>
                                    <field name="original_amount"/>
                                    <field name="revised_amount" readonly="1"/>
                                    <field name="retention_percent"/>
                                    <field name="advance_percent"/>
                                </group>
                                <group>
                                    <field name="scope"/>
                                    <field name="notes"/>
                                </group>
                            </group>
                        </page>

                        <page string="BOQ Lines">
                            <field name="boq_line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="section"/>
                                    <field name="item_code"/>
                                    <field name="description"/>
                                    <field name="uom_id"/>
                                    <field name="contract_qty"/>
                                    <field name="unit_rate"/>
                                    <field name="total_amount" readonly="1"/>
                                    <field name="measured_qty" readonly="1"/>
                                    <field name="certified_qty" readonly="1"/>
                                    <field name="remaining_qty" readonly="1"/>
                                </list>
                            </field>
                        </page>

                        <page string="Measurements">
                            <field name="measurement_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="date"/>
                                    <field name="period_from"/>
                                    <field name="period_to"/>
                                    <field name="prepared_by"/>
                                    <field name="checked_by"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>

                        <page string="IPCs">
                            <field name="ipc_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="ipc_date"/>
                                    <field name="measurement_id"/>
                                    <field name="current_work_value"/>
                                    <field name="retention_amount"/>
                                    <field name="net_amount"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_construction_contract_search" model="ir.ui.view">
        <field name="name">construction.contract.search</field>
        <field name="model">construction.contract</field>
        <field name="arch" type="xml">
            <search string="Search Contracts">
                <field name="name"/>
                <field name="project_id"/>
                <field name="partner_id"/>

                <filter string="Inbound" name="filter_inbound" domain="[('contract_direction','=','inbound')]"/>
                <filter string="Outbound" name="filter_outbound" domain="[('contract_direction','=','outbound')]"/>

                <filter string="Draft" name="filter_draft" domain="[('state','=','draft')]"/>
                <filter string="Active" name="filter_active" domain="[('state','=','active')]"/>
                <filter string="Closed" name="filter_closed" domain="[('state','=','closed')]"/>

                <group expand="0" string="Group By">
                    <filter string="Project" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Partner" name="group_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Direction" name="group_direction" context="{'group_by': 'contract_direction'}"/>
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_construction_contract" model="ir.actions.act_window">
        <field name="name">Contracts</field>
        <field name="res_model">construction.contract</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_construction_contract_search"/>
        <field name="help" type="html">
            <p>Create and manage inbound and outbound construction contracts.</p>
        </field>
    </record>

</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_construction_common_styles">
        <style type="text/css">
            .construction-report {
                font-family: 'DejaVu Sans', Arial, sans-serif;
                color: #172033;
                font-size: 10pt;
                line-height: 1.35;
            }
            .construction-report .report-header {
                margin-bottom: 18px;
                padding: 18px 20px;
                border: 1px solid #d7dfeb;
                border-radius: 18px;
                background: linear-gradient(180deg, #f8fbff 0%, #eef4fb 100%);
            }
            .construction-report .report-eyebrow {
                margin: 0 0 6px 0;
                color: #52708f;
                font-size: 9pt;
                font-weight: 700;
                letter-spacing: 0.08em;
                text-transform: uppercase;
            }
            .construction-report .report-title-row {
                width: 100%;
                border-collapse: collapse;
                border: none !important;
                outline: none !important;
                box-shadow: none !important;
                background: transparent !important;
            }
            .construction-report .report-title-row tr,
            .construction-report .report-title-row td {
                vertical-align: top;
                border: none !important;
                outline: none !important;
                box-shadow: none !important;
                background: transparent !important;
            }
            .construction-report .report-title {
                margin: 0;
                color: #15233b;
                font-size: 23pt;
                font-weight: 800;
                letter-spacing: -0.02em;
            }
            .construction-report .report-subtitle {
                margin-top: 4px;
                color: #5e6f85;
                font-size: 10pt;
            }
            .construction-report .report-badge {
                display: inline-block;
                padding: 7px 14px;
                border-radius: 999px;
                background: #15233b;
                color: #ffffff;
                font-size: 9pt;
                font-weight: 700;
                white-space: nowrap;
            }
            .construction-report .meta-grid {
                width: 100%;
                border-collapse: separate;
                border-spacing: 10px;
                margin: 0 -10px 14px -10px;
            }
            .construction-report .meta-card {
                padding: 12px 14px;
                border: 1px solid #dce4ef;
                border-radius: 14px;
                background: #ffffff;
            }
            .construction-report .meta-label {
                margin-bottom: 4px;
                color: #65758a;
                font-size: 8.5pt;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.04em;
            }
            .construction-report .meta-value {
                color: #1c2940;
                font-size: 11pt;
                font-weight: 700;
            }
            .construction-report .section-title {
                margin: 18px 0 10px 0;
                color: #15233b;
                font-size: 12.5pt;
                font-weight: 800;
            }
            .construction-report .summary-table,
            .construction-report .data-table {
                width: 100%;
                border-collapse: collapse;
            }
            .construction-report .summary-table td {
                padding: 9px 10px;
                border: 1px solid #dfe6ef;
            }
            .construction-report .summary-table .label-cell {
                color: #506174;
                font-weight: 700;
                background: #f7f9fc;
            }
            .construction-report .summary-table .value-cell {
                text-align: right;
                font-weight: 700;
                color: #172033;
            }
            .construction-report .summary-table .emphasis td {
                background: #edf4fb;
                font-weight: 800;
            }
            .construction-report .data-table thead th {
                padding: 10px 8px;
                border: 1px solid #d7dfeb;
                background: #1c3554;
                color: #ffffff;
                font-size: 8.8pt;
                font-weight: 700;
                text-align: left;
            }
            .construction-report .data-table tbody td {
                padding: 8px 8px;
                border: 1px solid #e0e7f0;
                vertical-align: top;
            }
            .construction-report .data-table tbody tr:nth-child(even) td {
                background: #f9fbfe;
            }
            .construction-report .text-right {
                text-align: right;
            }
            .construction-report .text-center {
                text-align: center;
            }
            .construction-report .muted {
                color: #6c7d91;
            }
            .construction-report .mono {
                font-variant-numeric: tabular-nums;
            }
            .construction-report .note-box {
                margin-top: 14px;
                padding: 12px 14px;
                border: 1px solid #dce4ef;
                border-radius: 14px;
                background: #fbfcfe;
            }
            .construction-report .note-box .note-title {
                margin-bottom: 4px;
                font-size: 9pt;
                font-weight: 800;
                color: #24344c;
                text-transform: uppercase;
            }
            .construction-report .signature-grid {
                width: 100%;
                border-collapse: separate;
                border-spacing: 12px;
                margin: 22px -12px 0 -12px;
            }
            .construction-report .signature-box {
                padding: 10px 12px 16px 12px;
                border: 1px solid #dce4ef;
                border-radius: 14px;
                text-align: center;
                height: 86px;
            }
            .construction-report .signature-label {
                color: #516277;
                font-size: 9pt;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.04em;
            }
            .construction-report .signature-line {
                margin-top: 40px;
                border-top: 1px solid #9db0c7;
                font-size: 8.5pt;
                color: #66768a;
                padding-top: 5px;
            }
            .construction-report .two-col {
                width: 100%;
                border-collapse: separate;
                border-spacing: 14px;
                margin: 0 -14px;
            }
            .construction-report .two-col > tbody > tr > td {
                width: 50%;
                vertical-align: top;
            }
            .construction-report .pill {
                display: inline-block;
                padding: 2px 8px;
                border-radius: 999px;
                background: #eef3f9;
                color: #38506d;
                font-size: 8.2pt;
                font-weight: 700;
            }
        </style>
    </template>
</odoo>

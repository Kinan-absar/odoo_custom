<odoo>
    <template id="report_construction_advance">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Advance Payment Report</h2>

                        <div class="row mb-3">
                            <div class="col-6">
                                <strong>Advance No:</strong> <span t-field="o.name"/><br/>
                                <strong>Date:</strong> <span t-field="o.date"/><br/>
                                <strong>Contract:</strong> <span t-field="o.contract_id.name"/><br/>
                                <strong>Project:</strong> <span t-field="o.contract_id.project_id.name"/><br/>
                                <strong>Partner:</strong> <span t-field="o.contract_id.partner_id.name"/>
                            </div>
                            <div class="col-6">
                                <strong>Direction:</strong> <span t-field="o.contract_direction"/><br/>
                                <strong>Status:</strong> <span t-field="o.state"/><br/>
                                <strong>Invoice/Bill:</strong> <span t-field="o.move_id.name"/>
                            </div>
                        </div>

                        <table class="table table-sm table-bordered mt-4">
                            <tr>
                                <td>Advance Amount</td>
                                <td class="text-end"><span t-field="o.amount"/></td>
                            </tr>
                            <tr>
                                <td>VAT</td>
                                <td class="text-end"><span t-field="o.tax_amount"/></td>
                            </tr>
                            <tr>
                                <td><strong>Total Amount</strong></td>
                                <td class="text-end"><strong t-field="o.total_amount"/></td>
                            </tr>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
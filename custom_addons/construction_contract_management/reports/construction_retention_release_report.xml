<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_construction_retention_release">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-set="state_labels" t-value="{'draft': 'Draft', 'posted': 'Posted', 'cancelled': 'Cancelled'}"/>
                <t t-set="method_labels" t-value="{'invoice': 'Invoice / Bill', 'journal': 'Journal Entry'}"/>
                <t t-call="web.external_layout">
                    <div class="page construction-report">
                        <t t-call="construction_contract_management.report_construction_common_styles"/>

                        <div class="report-header">
                            <p class="report-eyebrow">Construction Document</p>
                            <div class="report-title-row">
                                <div class="report-title-main">
                                    <h1 class="report-title">Retention Release</h1>
                                    <div class="report-subtitle">
                                        <span t-esc="doc.name"/> for <span t-esc="doc.contract_id.name"/>
                                    </div>
                                </div>
                                <div class="report-title-side">
                                    <span class="report-badge" t-esc="state_labels.get(doc.state, doc.state)"/>
                                </div>
                            </div>
                        </div>

                        <table class="meta-grid">
                            <tr>
                                <td>
                                    <div class="meta-card">
                                        <div class="meta-label">Project</div>
                                        <div class="meta-value"><span t-field="doc.project_id"/></div>
                                    </div>
                                </td>
                                <td>
                                    <div class="meta-card">
                                        <div class="meta-label">Contract</div>
                                        <div class="meta-value"><span t-field="doc.contract_id"/></div>
                                    </div>
                                </td>
                                <td>
                                    <div class="meta-card">
                                        <div class="meta-label">Date</div>
                                        <div class="meta-value"><span t-field="doc.date"/></div>
                                    </div>
                                </td>
                                <td>
                                    <div class="meta-card">
                                        <div class="meta-label">Partner</div>
                                        <div class="meta-value"><span t-field="doc.partner_id"/></div>
                                    </div>
                                </td>
                            </tr>
                        </table>

                        <table class="two-col">
                            <tr>
                                <td>
                                    <div class="section-title">Release Details</div>
                                    <table class="summary-table">
                                        <tr>
                                            <td class="label-cell">Direction</td>
                                            <td class="value-cell"><span t-esc="'Client Contract' if doc.contract_direction == 'inbound' else 'Subcontract'"/></td>
                                        </tr>
                                        <tr>
                                            <td class="label-cell">Release Method</td>
                                            <td class="value-cell"><span t-esc="method_labels.get(doc.release_method, doc.release_method or '-')"/></td>
                                        </tr>
                                        <tr>
                                            <td class="label-cell">Entry / Invoice Ref.</td>
                                            <td class="value-cell"><span t-esc="doc.move_id.name or '-'"/></td>
                                        </tr>
                                    </table>
                                </td>
                                <td>
                                    <div class="section-title">Amounts</div>
                                    <table class="summary-table">
                                        <tr>
                                            <td class="label-cell">Available Retention</td>
                                            <td class="value-cell"><span t-field="doc.available_retention" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                        </tr>
                                        <tr class="emphasis">
                                            <td class="label-cell">Release Amount</td>
                                            <td class="value-cell"><span t-field="doc.amount" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </table>

                        <t t-if="doc.notes">
                            <div class="note-box">
                                <div class="note-title">Notes</div>
                                <div t-esc="doc.notes"/>
                            </div>
                        </t>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>

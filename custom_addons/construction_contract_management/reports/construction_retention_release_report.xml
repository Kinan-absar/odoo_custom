<odoo>
    <template id="report_construction_retention_release">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Retention Release Report</h2>

                        <div class="row mb-3">
                            <div class="col-6">
                                <strong>Release No:</strong> <span t-field="o.name"/><br/>
                                <strong>Date:</strong> <span t-field="o.date"/><br/>
                                <strong>Contract:</strong> <span t-field="o.contract_id.name"/><br/>
                                <strong>Project:</strong> <span t-field="o.contract_id.project_id.name"/><br/>
                                <strong>Partner:</strong> <span t-field="o.contract_id.partner_id.name"/>
                            </div>
                            <div class="col-6">
                                <strong>Direction:</strong> <span t-field="o.contract_direction"/><br/>
                                <strong>Method:</strong> <span t-field="o.release_method"/><br/>
                                <strong>Status:</strong> <span t-field="o.state"/><br/>
                                <strong>Entry/Invoice:</strong> <span t-field="o.move_id.name"/>
                            </div>
                        </div>

                        <t t-if="o.notes">
                            <p><strong>Notes:</strong> <span t-field="o.notes"/></p>
                        </t>

                        <table class="table table-sm table-bordered mt-4">
                            <tr>
                                <td>Available Retention</td>
                                <td class="text-end"><span t-field="o.available_retention"/></td>
                            </tr>
                            <tr>
                                <td><strong>Release Amount</strong></td>
                                <td class="text-end"><strong t-field="o.amount"/></td>
                            </tr>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
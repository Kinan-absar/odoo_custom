<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_construction_ipc">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        
                        <style>
                            /* Compact, print-friendly B&W design */
                            .page {
                                font-family: 'DejaVu Sans', Arial, sans-serif;
                                font-size: 9pt;
                                color: #000;
                                line-height: 1.3;
                            }
                            
                            /* Header - Minimal */
                            .ipc-header {
                                text-align: center;
                                border-bottom: 3px solid #000;
                                padding-bottom: 8px;
                                margin-bottom: 15px;
                            }
                            
                            .ipc-header h1 {
                                font-size: 16pt;
                                font-weight: bold;
                                margin: 0;
                                text-transform: uppercase;
                                letter-spacing: 1px;
                            }
                            
                            .ipc-header h2 {
                                font-size: 13pt;
                                margin: 3px 0 0 0;
                                font-weight: 600;
                            }
                            
                            /* Compact Meta Info - 3 columns */
                            .meta-table {
                                width: 100%;
                                margin-bottom: 15px;
                                border-collapse: collapse;
                                font-size: 8pt;
                            }
                            
                            .meta-table td {
                                padding: 5px 8px;
                                border: 1px solid #000;
                                vertical-align: top;
                            }
                            
                            .meta-table .meta-label {
                                font-weight: bold;
                                text-transform: uppercase;
                                font-size: 7pt;
                                margin-bottom: 2px;
                            }
                            
                            .meta-table .meta-label-ar {
                                font-size: 7pt;
                                display: block;
                            }
                            
                            .meta-table .meta-value {
                                font-size: 9pt;
                                font-weight: bold;
                                margin-top: 2px;
                            }
                            
                            /* Compact Items Table */
                            .items-table {
                                width: 100%;
                                border-collapse: collapse;
                                margin: 12px 0;
                                font-size: 8pt;
                            }
                            
                            .items-table th {
                                background-color: #000;
                                color: #fff;
                                padding: 6px 4px;
                                text-align: left;
                                font-weight: bold;
                                border: 1px solid #000;
                                font-size: 7.5pt;
                            }
                            
                            .items-table th.text-right {
                                text-align: right;
                            }
                            
                            .items-table .ar-label {
                                display: block;
                                font-size: 7pt;
                                margin-top: 2px;
                                font-weight: normal;
                            }
                            
                            .items-table td {
                                padding: 5px 4px;
                                border: 1px solid #000;
                            }
                            
                            .items-table td.text-right {
                                text-align: right;
                            }
                            
                            .items-table tbody tr:nth-child(even) {
                                background-color: #f5f5f5;
                            }
                            
                            .item-code {
                                border: 1px solid #000;
                                padding: 2px 5px;
                                font-size: 7pt;
                                font-weight: bold;
                                display: inline-block;
                                margin-bottom: 2px;
                            }
                            
                            /* Compact Summary - Inline */
                            .summary-table {
                                width: 50%;
                                margin-left: auto;
                                margin-top: 12px;
                                border-collapse: collapse;
                                font-size: 8pt;
                            }
                            
                            .summary-table td {
                                padding: 5px 8px;
                                border: 1px solid #000;
                            }
                            
                            .summary-table .label-cell {
                                font-weight: 600;
                                width: 60%;
                            }
                            
                            .summary-table .label-ar {
                                display: block;
                                font-size: 7pt;
                                margin-top: 2px;
                                font-weight: normal;
                            }
                            
                            .summary-table .value-cell {
                                text-align: right;
                                font-weight: bold;
                                width: 40%;
                            }
                            
                            .summary-table .total-row {
                                background-color: #e0e0e0;
                                font-weight: bold;
                            }
                            
                            .summary-table .total-row td {
                                padding: 7px 8px;
                                font-size: 9pt;
                                border-top: 2px solid #000;
                            }
                            
                            /* Compact Notes */
                            .notes-box {
                                margin-top: 12px;
                                padding: 8px 10px;
                                border: 1px solid #000;
                                font-size: 7pt;
                            }
                            
                            .notes-box h4 {
                                margin: 0 0 5px 0;
                                font-size: 8pt;
                                font-weight: bold;
                            }
                            
                            .notes-box p {
                                margin: 0;
                                line-height: 1.4;
                            }
                            
                            /* Compact Signatures */
                            .signatures-table {
                                width: 100%;
                                margin-top: 20px;
                                border-collapse: collapse;
                                font-size: 7pt;
                            }
                            
                            .signatures-table td {
                                width: 33.33%;
                                text-align: center;
                                padding: 12px 5px;
                                border: 1px solid #000;
                            }
                            
                            .signatures-table .sig-title {
                                font-weight: bold;
                                font-size: 8pt;
                                margin-bottom: 2px;
                            }
                            
                            .signatures-table .sig-title-ar {
                                font-size: 7pt;
                                margin-bottom: 20px;
                            }
                            
                            .signatures-table .sig-line {
                                margin-top: 25px;
                                padding-top: 5px;
                                border-top: 1px solid #000;
                                font-size: 6pt;
                            }
                            
                            /* Print optimization */
                            @media print {
                                .page {
                                    margin: 0;
                                    padding: 10mm;
                                }
                            }
                            
                            /* Prevent page breaks */
                            .items-table, .summary-table, .signatures-table {
                                page-break-inside: avoid;
                            }
                        </style>

                        <!-- Header -->
                        <div class="ipc-header">
                            <h1>INTERIM PAYMENT CERTIFICATE</h1>
                            <h2>شهادة دفعة مرحلية</h2>
                        </div>

                        <!-- Compact Meta Information - 3 columns -->
                        <table class="meta-table">
                            <tr>
                                <td style="width: 33.33%;">
                                    <div class="meta-label">
                                        IPC NO.
                                        <span class="meta-label-ar">رقم الشهادة</span>
                                    </div>
                                    <div class="meta-value">
                                        <span t-field="doc.name"/>
                                    </div>
                                </td>
                                <td style="width: 33.33%;">
                                    <div class="meta-label">
                                        DATE
                                        <span class="meta-label-ar">التاريخ</span>
                                    </div>
                                    <div class="meta-value">
                                        <span t-field="doc.ipc_date"/>
                                    </div>
                                </td>
                                <td style="width: 33.33%;">
                                    <div class="meta-label">
                                        CONTRACT
                                        <span class="meta-label-ar">العقد</span>
                                    </div>
                                    <div class="meta-value">
                                        <span t-field="doc.contract_id.name"/>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <div class="meta-label">
                                        PROJECT
                                        <span class="meta-label-ar">المشروع</span>
                                    </div>
                                    <div class="meta-value">
                                        <span t-field="doc.contract_id.project_id.name"/>
                                    </div>
                                </td>
                                <td>
                                    <div class="meta-label">
                                        PARTNER
                                        <span class="meta-label-ar">الشريك</span>
                                    </div>
                                    <div class="meta-value">
                                        <span t-field="doc.contract_id.partner_id.name"/>
                                    </div>
                                </td>
                                <td>
                                    <div class="meta-label">
                                        PERIOD
                                        <span class="meta-label-ar">الفترة</span>
                                    </div>
                                    <div class="meta-value">
                                        <span t-field="doc.period_from"/> - <span t-field="doc.period_to"/>
                                    </div>
                                </td>
                            </tr>
                        </table>

                        <!-- Compact Line Items Table -->
                        <table class="items-table">
                            <thead>
                                <tr>
                                    <th style="width: 28%;">
                                        Description
                                        <span class="ar-label">الوصف</span>
                                    </th>
                                    <th class="text-right" style="width: 10%;">
                                        Prev. Qty
                                        <span class="ar-label">السابقة</span>
                                    </th>
                                    <th class="text-right" style="width: 10%;">
                                        Curr. Qty
                                        <span class="ar-label">الحالية</span>
                                    </th>
                                    <th class="text-right" style="width: 10%;">
                                        Cumul. Qty
                                        <span class="ar-label">التراكمية</span>
                                    </th>
                                    <th class="text-right" style="width: 15%;">
                                        Rate
                                        <span class="ar-label">السعر</span>
                                    </th>
                                    <th class="text-right" style="width: 15%;">
                                        Amount
                                        <span class="ar-label">القيمة</span>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="doc.line_ids" t-as="line">
                                    <td>
                                        <t t-if="line.boq_line_id.item_code">
                                            <span class="item-code" t-field="line.boq_line_id.item_code"/>
                                            <br/>
                                        </t>
                                        <span t-field="line.description"/>
                                    </td>
                                    <td class="text-right">
                                        <span t-field="line.previous_qty"/>
                                    </td>
                                    <td class="text-right">
                                        <span t-field="line.current_qty"/>
                                    </td>
                                    <td class="text-right">
                                        <span t-field="line.cumulative_qty"/>
                                    </td>
                                    <td class="text-right">
                                        <span t-field="line.unit_rate"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                    <td class="text-right">
                                        <span t-field="line.current_value"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Compact Summary -->
                        <table class="summary-table">
                            <tbody>
                                <tr>
                                    <td class="label-cell">
                                        Previous Certified
                                        <span class="label-ar">المعتمد السابق</span>
                                    </td>
                                    <td class="value-cell">
                                        <span t-field="doc.previous_certified_value"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="label-cell">
                                        Current Work Value
                                        <span class="label-ar">قيمة الأعمال الحالية</span>
                                    </td>
                                    <td class="value-cell">
                                        <span t-field="doc.current_work_value"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="label-cell">
                                        Cumulative Certified
                                        <span class="label-ar">المعتمد التراكمي</span>
                                    </td>
                                    <td class="value-cell">
                                        <span t-field="doc.cumulative_certified_value"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="label-cell">
                                        Advance Recovery
                                        <span class="label-ar">استرداد الدفعة المقدمة</span>
                                    </td>
                                    <td class="value-cell">
                                        <span t-field="doc.advance_recovery_amount"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="label-cell">
                                        VAT
                                        <span class="label-ar">ضريبة القيمة المضافة</span>
                                    </td>
                                    <td class="value-cell">
                                        <span t-field="doc.vat_amount"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="label-cell">
                                        Gross With VAT
                                        <span class="label-ar">الإجمالي شامل الضريبة</span>
                                    </td>
                                    <td class="value-cell">
                                        <span t-field="doc.gross_with_vat"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="label-cell">
                                        Retention
                                        <span class="label-ar">الاستقطاع</span>
                                    </td>
                                    <td class="value-cell">
                                        <span t-field="doc.retention_amount"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="label-cell">
                                        Deductions
                                        <span class="label-ar">الخصومات</span>
                                    </td>
                                    <td class="value-cell">
                                        <span t-field="doc.deduction_amount"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                </tr>
                                <tr class="total-row">
                                    <td class="label-cell">
                                        Net Amount
                                        <span class="label-ar">صافي المبلغ</span>
                                    </td>
                                    <td class="value-cell">
                                        <span t-field="doc.net_amount"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Compact Notes -->
                        <div class="notes-box">
                            <h4>NOTES / ملاحظات</h4>
                            <p>
                                All quantities and amounts are subject to review and approval according to contract terms. 
                                جميع الكميات والمبالغ خاضعة للمراجعة والاعتماد وفقاً لشروط العقد.
                            </p>
                        </div>

                        <!-- Compact Signatures -->
                        <table class="signatures-table">
                            <tr>
                                <td>
                                    <div class="sig-title">PREPARED BY</div>
                                    <div class="sig-title-ar">إعداد</div>
                                    <div class="sig-line">Signature &amp; Date</div>
                                </td>
                                <td>
                                    <div class="sig-title">CHECKED BY</div>
                                    <div class="sig-title-ar">مراجعة</div>
                                    <div class="sig-line">Signature &amp; Date</div>
                                </td>
                                <td>
                                    <div class="sig-title">APPROVED BY</div>
                                    <div class="sig-title-ar">اعتماد</div>
                                    <div class="sig-line">Signature &amp; Date</div>
                                </td>
                            </tr>
                        </table>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_construction_ipc">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-set="state_labels" t-value="{'draft': 'Draft', 'under_review': 'Under Review', 'approved': 'Approved', 'done': 'Done', 'cancelled': 'Cancelled'}"/>
                <t t-call="web.external_layout">
                    <div class="page construction-report">
                        <t t-call="construction_contract_management.report_construction_common_styles"/>

                        <div class="report-header">
                            <p class="report-eyebrow">Construction Document</p>
                            <div class="report-title-row">
                                <div class="report-title-main">
                                    <h1 class="report-title">Interim Payment Certificate</h1>
                                    <div class="report-subtitle">
                                        <span t-esc="doc.name"/> for <span t-esc="doc.contract_id.name"/>
                                    </div>
                                </div>
                                <div class="report-title-side">
                                    <span class="report-badge" t-esc="state_labels.get(doc.state, doc.state)"/>
                                </div>
                            </div>
                        </div>

                        <table class="meta-grid">
                            <tr>
                                <td>
                                    <div class="meta-card">
                                        <div class="meta-label">Project</div>
                                        <div class="meta-value"><span t-field="doc.project_id"/></div>
                                    </div>
                                </td>
                                <td>
                                    <div class="meta-card">
                                        <div class="meta-label">Contract</div>
                                        <div class="meta-value"><span t-field="doc.contract_id"/></div>
                                    </div>
                                </td>
                                <td>
                                    <div class="meta-card">
                                        <div class="meta-label">IPC Date</div>
                                        <div class="meta-value"><span t-field="doc.ipc_date"/></div>
                                    </div>
                                </td>
                                <td>
                                    <div class="meta-card">
                                        <div class="meta-label">Period</div>
                                        <div class="meta-value">
                                            <span t-field="doc.period_from"/> - <span t-field="doc.period_to"/>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </table>

                        <table class="two-col">
                            <tr>
                                <td>
                                    <div class="section-title">Contract Snapshot</div>
                                    <table class="summary-table">
                                        <tr>
                                            <td class="label-cell">Partner</td>
                                            <td class="value-cell"><span t-field="doc.contract_id.partner_id"/></td>
                                        </tr>
                                        <tr>
                                            <td class="label-cell">Direction</td>
                                            <td class="value-cell">
                                                <span t-esc="'Client Contract' if doc.contract_direction == 'inbound' else 'Subcontract'"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="label-cell">Measurement</td>
                                            <td class="value-cell"><span t-esc="doc.measurement_id.name or '-'"/></td>
                                        </tr>
                                        <tr>
                                            <td class="label-cell">Certificate Ref.</td>
                                            <td class="value-cell"><span t-field="doc.name"/></td>
                                        </tr>
                                    </table>
                                </td>
                                <td>
                                    <div class="section-title">Financial Summary</div>
                                    <table class="summary-table">
                                        <tr>
                                            <td class="label-cell">Previous Certified</td>
                                            <td class="value-cell"><span t-field="doc.previous_certified_value" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                        </tr>
                                        <tr>
                                            <td class="label-cell">Current Work Value</td>
                                            <td class="value-cell"><span t-field="doc.current_work_value" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                        </tr>
                                        <tr>
                                            <td class="label-cell">Advance Recovery</td>
                                            <td class="value-cell"><span t-field="doc.advance_recovery_amount" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                        </tr>
                                        <tr>
                                            <td class="label-cell">Retention</td>
                                            <td class="value-cell"><span t-field="doc.retention_amount" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                        </tr>
                                        <tr>
                                            <td class="label-cell">VAT</td>
                                            <td class="value-cell"><span t-field="doc.vat_amount" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                        </tr>
                                        <tr class="emphasis">
                                            <td class="label-cell">Net Amount</td>
                                            <td class="value-cell"><span t-field="doc.net_amount" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </table>

                        <div class="section-title">Certified Quantities</div>
<table class="data-table">
    <thead>
        <tr>
            <th>Item Code</th>
            <th>Description</th>
            <th class="text-right">Previous Qty</th>
            <th class="text-right">Current Qty</th>
            <th class="text-right">Total Qty</th>
            <th class="text-right">Rate</th>
            <th class="text-right">Current Value</th>
            <th class="text-right">Total Value</th>
        </tr>
    </thead>
    <tbody>
        <t t-set="lines" t-value="doc.line_ids.sorted(lambda l: (l.boq_line_id.sequence, l.id))"/>
        <t t-set="section_total" t-value="0.0"/>
        <t t-set="grand_total" t-value="0.0"/>
        <t t-set="current_section" t-value="''"/>

        <t t-foreach="lines" t-as="line">
            <t t-if="line.display_type == 'line_section'">
                <t t-if="current_section">
                    <tr class="subtotal-row">
                        <td colspan="6" class="subtotal-label">Subtotal - <span t-esc="current_section"/></td>
                        <td class="subtotal-value">
                            <span t-esc="'{} {:,.2f}'.format(doc.currency_id.symbol or '', section_total or 0.0)"/>
                        </td>
                        <td></td>
                    </tr>
                </t>
                <t t-set="section_total" t-value="0.0"/>
                <t t-set="current_section" t-value="line.description or 'Section'"/>
                <tr class="section-row">
                    <td colspan="8"><span t-esc="line.description or 'Section'"/></td>
                </tr>
            </t>

            <t t-elif="line.display_type == 'line_note'">
                <tr class="note-row">
                    <td colspan="8"><span t-esc="line.description or ''"/></td>
                </tr>
            </t>

            <t t-else="">
                <t t-set="section_total" t-value="section_total + (line.current_value or 0.0)"/>
                <t t-set="grand_total" t-value="grand_total + (line.current_value or 0.0)"/>

                <tr>
                    <td><span t-esc="line.boq_line_id.item_code or '-'"/></td>
                    <td><span t-esc="line.description or '-'"/></td>
                    <td class="text-right mono"><span t-esc="'{:,.2f}'.format(line.previous_qty or 0.0)"/></td>
                    <td class="text-right mono"><span t-esc="'{:,.2f}'.format(line.current_qty or 0.0)"/></td>
                    <td class="text-right mono"><span t-esc="'{:,.2f}'.format(line.cumulative_qty or 0.0)"/></td>
                    <td class="text-right">
                        <span t-field="line.unit_rate" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                    </td>
                    <td class="text-right">
                        <span t-field="line.current_value" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                    </td>
                    <td class="text-right">
                        <span t-field="line.cumulative_value" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                    </td>
                </tr>
            </t>
        </t>

        <t t-if="current_section">
            <tr class="subtotal-row">
                <td colspan="6" class="subtotal-label">Subtotal - <span t-esc="current_section"/></td>
                <td class="subtotal-value">
                    <span t-esc="'{} {:,.2f}'.format(doc.currency_id.symbol or '', section_total or 0.0)"/>
                </td>
                <td></td>
            </tr>
        </t>

        <tr class="grand-total-row">
            <td colspan="6" class="subtotal-label">Grand Total</td>
            <td class="subtotal-value">
                <span t-esc="'{} {:,.2f}'.format(doc.currency_id.symbol or '', grand_total or 0.0)"/>
            </td>
            <td></td>
        </tr>
    </tbody>
</table>

                        <div class="note-box">
    <div class="note-title">Settlement</div>
    <table class="summary-table">
        <tr>
            <td class="label-cell">Cumulative Certified</td>
            <td class="value-cell">
                <span t-field="doc.cumulative_certified_value"
                      t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
            </td>
        </tr>
        <tr>
            <td class="label-cell">Advance Recovery</td>
            <td class="value-cell">
                <span t-field="doc.advance_recovery_amount"
                      t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
            </td>
        </tr>
        <tr>
            <td class="label-cell">Retention</td>
            <td class="value-cell">
                <span t-field="doc.retention_amount"
                      t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
            </td>
        </tr>
        <tr>
            <td class="label-cell">Other Deductions</td>
            <td class="value-cell">
                <span t-field="doc.deduction_amount"
                      t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
            </td>
        </tr>
        <tr>
            <td class="label-cell">VAT</td>
            <td class="value-cell">
                <span t-field="doc.vat_amount"
                      t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
            </td>
        </tr>
        <tr class="emphasis">
            <td class="label-cell">Net Amount</td>
            <td class="value-cell">
                <span t-field="doc.net_amount"
                      t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
            </td>
        </tr>
    </table>
</div>

                        <table class="signature-grid">
                            <tr>
                                <td>
                                    <div class="signature-box">
                                        <div class="signature-label">Prepared By</div>
                                        <div class="signature-line">Name / Signature</div>
                                    </div>
                                </td>
                                <td>
                                    <div class="signature-box">
                                        <div class="signature-label">Reviewed By</div>
                                        <div class="signature-line">Name / Signature</div>
                                    </div>
                                </td>
                                <td>
                                    <div class="signature-box">
                                        <div class="signature-label">Approved By</div>
                                        <div class="signature-line">Name / Signature</div>
                                    </div>
                                </td>
                            </tr>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>

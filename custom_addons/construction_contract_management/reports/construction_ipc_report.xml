<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_construction_ipc">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        
                        <style>
                            /* PDF-safe styling only */
                            .page {
                                font-family: 'DejaVu Sans', Arial, sans-serif;
                                font-size: 10pt;
                                color: #2c3e50;
                            }
                            
                            /* Header Section */
                            .ipc-header {
                                background: #1a365d;
                                color: white;
                                padding: 25px 30px;
                                margin-bottom: 25px;
                                text-align: center;
                            }
                            
                            .ipc-header h1 {
                                font-size: 24pt;
                                font-weight: bold;
                                margin: 0 0 8px 0;
                                letter-spacing: 1px;
                            }
                            
                            .ipc-header h2 {
                                font-size: 18pt;
                                margin: 0;
                                font-weight: 600;
                            }
                            
                            /* Meta Grid */
                            .meta-grid {
                                width: 100%;
                                margin-bottom: 25px;
                                border-collapse: collapse;
                            }
                            
                            .meta-grid td {
                                padding: 12px 15px;
                                border: 1px solid #cbd5e0;
                                vertical-align: top;
                                width: 50%;
                            }
                            
                            .meta-grid .meta-label {
                                font-size: 9pt;
                                font-weight: bold;
                                color: #4a5568;
                                text-transform: uppercase;
                                letter-spacing: 0.5px;
                                margin-bottom: 5px;
                            }
                            
                            .meta-grid .meta-label-ar {
                                font-size: 9pt;
                                color: #718096;
                                display: block;
                                margin-top: 3px;
                            }
                            
                            .meta-grid .meta-value {
                                font-size: 11pt;
                                font-weight: bold;
                                color: #1a202c;
                                margin-top: 5px;
                            }
                            
                            .meta-grid .highlight-cell {
                                background-color: #f7fafc;
                                border-left: 4px solid #d4af37;
                            }
                            
                            /* Line Items Table */
                            .items-table {
                                width: 100%;
                                border-collapse: collapse;
                                margin: 25px 0;
                                font-size: 9pt;
                            }
                            
                            .items-table thead th {
                                background-color: #1a365d;
                                color: white;
                                padding: 12px 8px;
                                text-align: left;
                                font-weight: bold;
                                border: 1px solid #2d3748;
                            }
                            
                            .items-table thead th.text-right {
                                text-align: right;
                            }
                            
                            .items-table thead .ar-label {
                                display: block;
                                font-size: 8pt;
                                margin-top: 3px;
                                font-weight: normal;
                                opacity: 0.9;
                            }
                            
                            .items-table tbody td {
                                padding: 10px 8px;
                                border: 1px solid #e2e8f0;
                            }
                            
                            .items-table tbody td.text-right {
                                text-align: right;
                            }
                            
                            .items-table tbody tr:nth-child(even) {
                                background-color: #f8f9fa;
                            }
                            
                            .item-code {
                                background-color: #d4af37;
                                color: white;
                                padding: 3px 8px;
                                border-radius: 3px;
                                font-size: 8pt;
                                font-weight: bold;
                                display: inline-block;
                                margin-bottom: 3px;
                            }
                            
                            /* Summary Section */
                            .summary-wrapper {
                                width: 100%;
                                margin-top: 30px;
                            }
                            
                            .summary-box {
                                width: 55%;
                                margin-left: auto;
                                border: 2px solid #cbd5e0;
                            }
                            
                            .summary-header {
                                background-color: #edf2f7;
                                padding: 10px 15px;
                                border-bottom: 3px solid #d4af37;
                            }
                            
                            .summary-header h3 {
                                margin: 0;
                                font-size: 12pt;
                                font-weight: bold;
                                color: #1a365d;
                            }
                            
                            .summary-table {
                                width: 100%;
                                border-collapse: collapse;
                                font-size: 9pt;
                            }
                            
                            .summary-table td {
                                padding: 10px 15px;
                                border-bottom: 1px solid #e2e8f0;
                            }
                            
                            .summary-table .label-cell {
                                font-weight: 600;
                                color: #2d3748;
                                width: 60%;
                            }
                            
                            .summary-table .label-ar {
                                display: block;
                                font-size: 8pt;
                                color: #718096;
                                margin-top: 3px;
                                font-weight: normal;
                            }
                            
                            .summary-table .value-cell {
                                text-align: right;
                                font-weight: bold;
                                color: #1a202c;
                                width: 40%;
                            }
                            
                            .summary-table .total-row {
                                background-color: #f7fafc;
                                border-top: 3px solid #d4af37;
                            }
                            
                            .summary-table .total-row td {
                                padding: 12px 15px;
                                font-size: 11pt;
                                font-weight: bold;
                            }
                            
                            .summary-table .total-row .value-cell {
                                color: #1a365d;
                            }
                            
                            /* Notes Section */
                            .notes-box {
                                margin-top: 30px;
                                padding: 15px 20px;
                                background-color: #f7fafc;
                                border-left: 4px solid #d4af37;
                                border: 1px solid #cbd5e0;
                            }
                            
                            .notes-box h4 {
                                margin: 0 0 10px 0;
                                font-size: 10pt;
                                font-weight: bold;
                                color: #1a365d;
                                text-transform: uppercase;
                            }
                            
                            .notes-box p {
                                margin: 0;
                                font-size: 9pt;
                                line-height: 1.5;
                            }
                            
                            .notes-box .ar-text {
                                display: block;
                                margin-top: 8px;
                            }
                            
                            /* Signatures */
                            .signatures-table {
                                width: 100%;
                                margin-top: 50px;
                                border-collapse: collapse;
                            }
                            
                            .signatures-table td {
                                width: 33.33%;
                                text-align: center;
                                padding: 20px 10px;
                                border: 2px dashed #cbd5e0;
                            }
                            
                            .signatures-table .sig-title {
                                font-weight: bold;
                                font-size: 10pt;
                                color: #1a365d;
                                text-transform: uppercase;
                                margin-bottom: 3px;
                            }
                            
                            .signatures-table .sig-title-ar {
                                font-size: 9pt;
                                color: #718096;
                                margin-bottom: 30px;
                            }
                            
                            .signatures-table .sig-line {
                                margin-top: 40px;
                                padding-top: 8px;
                                border-top: 2px solid #2d3748;
                                font-size: 8pt;
                                color: #718096;
                            }
                        </style>

                        <!-- Header -->
                        <div class="ipc-header">
                            <h1>INTERIM PAYMENT CERTIFICATE</h1>
                            <h2>شهادة دفعة مرحلية</h2>
                        </div>

                        <!-- Meta Information -->
                        <table class="meta-grid">
                            <tr>
                                <td class="highlight-cell">
                                    <div class="meta-label">
                                        IPC NO.
                                        <span class="meta-label-ar">رقم الشهادة</span>
                                    </div>
                                    <div class="meta-value">
                                        <span t-field="doc.name"/>
                                    </div>
                                </td>
                                <td class="highlight-cell">
                                    <div class="meta-label">
                                        DATE
                                        <span class="meta-label-ar">التاريخ</span>
                                    </div>
                                    <div class="meta-value">
                                        <span t-field="doc.ipc_date"/>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td class="highlight-cell">
                                    <div class="meta-label">
                                        CONTRACT
                                        <span class="meta-label-ar">العقد</span>
                                    </div>
                                    <div class="meta-value">
                                        <span t-field="doc.contract_id.name"/>
                                    </div>
                                </td>
                                <td class="highlight-cell">
                                    <div class="meta-label">
                                        PROJECT
                                        <span class="meta-label-ar">المشروع</span>
                                    </div>
                                    <div class="meta-value">
                                        <span t-field="doc.contract_id.project_id.name"/>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td class="highlight-cell">
                                    <div class="meta-label">
                                        PARTNER
                                        <span class="meta-label-ar">الطرف</span>
                                    </div>
                                    <div class="meta-value">
                                        <span t-field="doc.contract_id.partner_id.name"/>
                                    </div>
                                </td>
                                <td class="highlight-cell">
                                    <div class="meta-label">
                                        PERIOD
                                        <span class="meta-label-ar">الفترة</span>
                                    </div>
                                    <div class="meta-value">
                                        <span t-field="doc.period_from"/> - <span t-field="doc.period_to"/>
                                    </div>
                                </td>
                            </tr>
                        </table>

                        <!-- Line Items Table -->
                        <table class="items-table">
                            <thead>
                                <tr>
                                    <th>
                                        Description
                                        <span class="ar-label">الوصف</span>
                                    </th>
                                    <th class="text-right" style="width: 12%;">
                                        Previous Qty
                                        <span class="ar-label">الكمية السابقة</span>
                                    </th>
                                    <th class="text-right" style="width: 12%;">
                                        Current Qty
                                        <span class="ar-label">الكمية الحالية</span>
                                    </th>
                                    <th class="text-right" style="width: 12%;">
                                        Cumulative Qty
                                        <span class="ar-label">الكمية التراكمية</span>
                                    </th>
                                    <th class="text-right" style="width: 13%;">
                                        Rate
                                        <span class="ar-label">السعر</span>
                                    </th>
                                    <th class="text-right" style="width: 13%;">
                                        Amount
                                        <span class="ar-label">القيمة</span>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="doc.line_ids" t-as="line">
                                    <td>
                                        <t t-if="line.boq_line_id.item_code">
                                            <span class="item-code" t-field="line.boq_line_id.item_code"/>
                                            <br/>
                                        </t>
                                        <span t-field="line.description"/>
                                    </td>
                                    <td class="text-right">
                                        <span t-field="line.previous_qty"/>
                                    </td>
                                    <td class="text-right">
                                        <span t-field="line.current_qty"/>
                                    </td>
                                    <td class="text-right">
                                        <span t-field="line.cumulative_qty"/>
                                    </td>
                                    <td class="text-right">
                                        <span t-field="line.unit_rate"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                    <td class="text-right">
                                        <span t-field="line.current_value"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Summary Section -->
                        <div class="summary-wrapper">
                            <div class="summary-box">
                                <div class="summary-header">
                                    <h3>Financial Summary</h3>
                                </div>
                                <table class="summary-table">
                                    <tbody>
                                        <tr>
                                            <td class="label-cell">
                                                Previous Certified
                                                <span class="label-ar">المعتمد السابق</span>
                                            </td>
                                            <td class="value-cell">
                                                <span t-field="doc.previous_certified_value"
                                                      t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="label-cell">
                                                Current Work Value
                                                <span class="label-ar">قيمة الأعمال الحالية</span>
                                            </td>
                                            <td class="value-cell">
                                                <span t-field="doc.current_work_value"
                                                      t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="label-cell">
                                                Cumulative Certified
                                                <span class="label-ar">المعتمد التراكمي</span>
                                            </td>
                                            <td class="value-cell">
                                                <span t-field="doc.cumulative_certified_value"
                                                      t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="label-cell">
                                                Advance Recovery
                                                <span class="label-ar">استرداد الدفعة المقدمة</span>
                                            </td>
                                            <td class="value-cell">
                                                <span t-field="doc.advance_recovery_amount"
                                                      t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="label-cell">
                                                VAT
                                                <span class="label-ar">ضريبة القيمة المضافة</span>
                                            </td>
                                            <td class="value-cell">
                                                <span t-field="doc.vat_amount"
                                                      t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="label-cell">
                                                Gross With VAT
                                                <span class="label-ar">الإجمالي شامل الضريبة</span>
                                            </td>
                                            <td class="value-cell">
                                                <span t-field="doc.gross_with_vat"
                                                      t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="label-cell">
                                                Retention
                                                <span class="label-ar">الاستقطاع</span>
                                            </td>
                                            <td class="value-cell">
                                                <span t-field="doc.retention_amount"
                                                      t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="label-cell">
                                                Deductions
                                                <span class="label-ar">الخصومات</span>
                                            </td>
                                            <td class="value-cell">
                                                <span t-field="doc.deduction_amount"
                                                      t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                            </td>
                                        </tr>
                                        <tr class="total-row">
                                            <td class="label-cell">
                                                Net Amount
                                                <span class="label-ar">صافي المبلغ</span>
                                            </td>
                                            <td class="value-cell">
                                                <span t-field="doc.net_amount"
                                                      t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Notes -->
                        <div class="notes-box">
                            <h4>Notes / ملاحظات</h4>
                            <p>
                                All quantities and amounts are subject to review and approval according to contract terms.
                                <span class="ar-text">جميع الكميات والمبالغ خاضعة للمراجعة والاعتماد وفقاً لشروط العقد.</span>
                            </p>
                        </div>

                        <!-- Signatures -->
                        <table class="signatures-table">
                            <tr>
                                <td>
                                    <div class="sig-title">PREPARED BY</div>
                                    <div class="sig-title-ar">إعداد</div>
                                    <div class="sig-line">Signature &amp; Date</div>
                                </td>
                                <td>
                                    <div class="sig-title">CHECKED BY</div>
                                    <div class="sig-title-ar">مراجعة</div>
                                    <div class="sig-line">Signature &amp; Date</div>
                                </td>
                                <td>
                                    <div class="sig-title">APPROVED BY</div>
                                    <div class="sig-title-ar">اعتماد</div>
                                    <div class="sig-line">Signature &amp; Date</div>
                                </td>
                            </tr>
                        </table>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
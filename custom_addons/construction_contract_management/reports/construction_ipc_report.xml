<odoo>
    <template id="report_construction_ipc">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">

                        <!-- Title -->
                        <div style="text-align:center; margin-bottom:20px;">
                            <h2 style="margin:0;">INTERIM PAYMENT CERTIFICATE</h2>
                            <h3 style="margin:4px 0 0 0; direction:rtl;">شهادة دفعة مرحلية</h3>
                        </div>

                        <!-- Header Info -->
                        <table style="width:100%; border-collapse:collapse; margin-bottom:20px; font-size:13px;">
                            <tbody>
                                <tr>
                                    <td style="width:25%; padding:4px;">
                                        <strong>IPC No.</strong><br/>
                                        <span style="direction:rtl;">رقم الشهادة</span>
                                    </td>
                                    <td style="width:25%; padding:4px;">
                                        <span t-field="doc.name"/>
                                    </td>
                                    <td style="width:25%; padding:4px; text-align:right;">
                                        <strong style="direction:rtl;">التاريخ</strong><br/>Date
                                    </td>
                                    <td style="width:25%; padding:4px; text-align:right;">
                                        <span t-field="doc.ipc_date"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding:4px;">
                                        <strong>Contract</strong><br/>
                                        <span style="direction:rtl;">العقد</span>
                                    </td>
                                    <td style="padding:4px;">
                                        <span t-field="doc.contract_id.name"/>
                                    </td>
                                    <td style="padding:4px; text-align:right;">
                                        <strong style="direction:rtl;">المشروع</strong><br/>Project
                                    </td>
                                    <td style="padding:4px; text-align:right;">
                                        <span t-field="doc.contract_id.project_id.name"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding:4px;">
                                        <strong>Partner</strong><br/>
                                        <span style="direction:rtl;">الطرف</span>
                                    </td>
                                    <td style="padding:4px;">
                                        <span t-field="doc.contract_id.partner_id.name"/>
                                    </td>
                                    <td style="padding:4px; text-align:right;">
                                        <strong style="direction:rtl;">الفترة</strong><br/>Period
                                    </td>
                                    <td style="padding:4px; text-align:right;">
                                        <span t-field="doc.period_from"/>
                                        <span> - </span>
                                        <span t-field="doc.period_to"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Lines -->
                        <table class="table table-sm" style="width:100%; border-collapse:collapse; font-size:12px;">
                            <thead>
                                <tr style="background:#e9ecef;">
                                    <th style="border:1px solid #999; padding:6px;">
                                        Description<br/><span style="direction:rtl;">الوصف</span>
                                    </th>
                                    <th style="border:1px solid #999; padding:6px; text-align:right;">
                                        Previous Qty<br/><span style="direction:rtl;">الكمية السابقة</span>
                                    </th>
                                    <th style="border:1px solid #999; padding:6px; text-align:right;">
                                        Current Qty<br/><span style="direction:rtl;">الكمية الحالية</span>
                                    </th>
                                    <th style="border:1px solid #999; padding:6px; text-align:right;">
                                        Cumulative Qty<br/><span style="direction:rtl;">الكمية التراكمية</span>
                                    </th>
                                    <th style="border:1px solid #999; padding:6px; text-align:right;">
                                        Rate<br/><span style="direction:rtl;">السعر</span>
                                    </th>
                                    <th style="border:1px solid #999; padding:6px; text-align:right;">
                                        Amount<br/><span style="direction:rtl;">القيمة</span>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="doc.line_ids" t-as="line">
                                    <td style="border:1px solid #999; padding:6px;">
                                        <t t-if="line.boq_line_id.item_code">
                                            <strong t-field="line.boq_line_id.item_code"/><br/>
                                        </t>
                                        <span t-field="line.description"/>
                                    </td>
                                    <td style="border:1px solid #999; padding:6px; text-align:right;">
                                        <span t-field="line.previous_qty"/>
                                    </td>
                                    <td style="border:1px solid #999; padding:6px; text-align:right;">
                                        <span t-field="line.current_qty"/>
                                    </td>
                                    <td style="border:1px solid #999; padding:6px; text-align:right;">
                                        <span t-field="line.cumulative_qty"/>
                                    </td>
                                    <td style="border:1px solid #999; padding:6px; text-align:right;">
                                        <span t-field="line.unit_rate"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                    <td style="border:1px solid #999; padding:6px; text-align:right;">
                                        <span t-field="line.current_value"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Summary -->
                        <div style="margin-top:20px; width:45%; margin-left:auto; page-break-inside: avoid;">
                            <table style="width:100%; border-collapse:collapse; font-size:12px;">
                                <tbody>
                                    <tr>
                                        <td style="border:1px solid #999; padding:6px;">
                                            Previous Certified<br/><span style="direction:rtl;">المعتمد السابق</span>
                                        </td>
                                        <td style="border:1px solid #999; padding:6px; text-align:right;">
                                            <span t-field="doc.previous_certified_value"
                                                  t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="border:1px solid #999; padding:6px;">
                                            Current Work Value<br/><span style="direction:rtl;">قيمة الأعمال الحالية</span>
                                        </td>
                                        <td style="border:1px solid #999; padding:6px; text-align:right;">
                                            <span t-field="doc.current_work_value"
                                                  t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="border:1px solid #999; padding:6px;">
                                            Cumulative Certified<br/><span style="direction:rtl;">المعتمد التراكمي</span>
                                        </td>
                                        <td style="border:1px solid #999; padding:6px; text-align:right;">
                                            <span t-field="doc.cumulative_certified_value"
                                                  t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="border:1px solid #999; padding:6px;">
                                            Advance Recovery<br/><span style="direction:rtl;">استرداد الدفعة المقدمة</span>
                                        </td>
                                        <td style="border:1px solid #999; padding:6px; text-align:right;">
                                            <span t-field="doc.advance_recovery_amount"
                                                  t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="border:1px solid #999; padding:6px;">
                                            VAT<br/><span style="direction:rtl;">ضريبة القيمة المضافة</span>
                                        </td>
                                        <td style="border:1px solid #999; padding:6px; text-align:right;">
                                            <span t-field="doc.vat_amount"
                                                  t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="border:1px solid #999; padding:6px;">
                                            Gross With VAT<br/><span style="direction:rtl;">الإجمالي شامل الضريبة</span>
                                        </td>
                                        <td style="border:1px solid #999; padding:6px; text-align:right;">
                                            <span t-field="doc.gross_with_vat"
                                                  t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="border:1px solid #999; padding:6px;">
                                            Retention<br/><span style="direction:rtl;">الاستقطاع</span>
                                        </td>
                                        <td style="border:1px solid #999; padding:6px; text-align:right;">
                                            <span t-field="doc.retention_amount"
                                                  t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="border:1px solid #999; padding:6px;">
                                            Deductions<br/><span style="direction:rtl;">الخصومات</span>
                                        </td>
                                        <td style="border:1px solid #999; padding:6px; text-align:right;">
                                            <span t-field="doc.deduction_amount"
                                                  t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                        </td>
                                    </tr>
                                    <tr style="background:#f2f2f2;">
                                        <td style="border:1px solid #999; padding:6px;">
                                            <strong>Net Amount</strong><br/><strong style="direction:rtl;">صافي المبلغ</strong>
                                        </td>
                                        <td style="border:1px solid #999; padding:6px; text-align:right;">
                                            <strong t-field="doc.net_amount"
                                                    t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <div style="clear:both;"/>

                        <!-- Notes -->
                        <div style="margin-top:30px; font-size:12px;">
                            <strong>Notes / ملاحظات</strong>
                            <p style="margin-top:8px;">
                                All quantities and amounts are subject to review and approval according to contract terms.<br/>
                                <span style="direction:rtl; display:block; text-align:right;">
                                    جميع الكميات والمبالغ خاضعة للمراجعة والاعتماد وفقًا لشروط العقد.
                                </span>
                            </p>
                        </div>

                        <!-- Signatures -->
                        <table style="width:100%; margin-top:50px; border-collapse:collapse; font-size:12px;">
                            <tr>
                                <td style="width:33%; text-align:center; padding:20px;">
                                    <strong>Prepared By</strong><br/>
                                    <span style="direction:rtl;">إعداد</span><br/><br/><br/>
                                    ______________________
                                </td>
                                <td style="width:33%; text-align:center; padding:20px;">
                                    <strong>Checked By</strong><br/>
                                    <span style="direction:rtl;">مراجعة</span><br/><br/><br/>
                                    ______________________
                                </td>
                                <td style="width:33%; text-align:center; padding:20px;">
                                    <strong>Approved By</strong><br/>
                                    <span style="direction:rtl;">اعتماد</span><br/><br/><br/>
                                    ______________________
                                </td>
                            </tr>
                        </table>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
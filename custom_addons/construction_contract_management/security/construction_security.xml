<odoo>
    <record id="module_category_construction_contract" model="ir.module.category">
        <field name="name">Construction</field>
        <field name="description">Construction Contract Management</field>
        <field name="sequence">25</field>
    </record>

    <record id="group_construction_user" model="res.groups">
        <field name="name">Construction User</field>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 
    ============================================================================
    CONSTRUCTION PORTAL SECURITY MODEL
    ============================================================================
    
    ROLES:
    
    1. PORTAL USER (Employee with limited access via employee portal):
       - View ALL contracts (assigned or not)
       - CREATE measurements (submit for approval)
       - CREATE variation requests (submit for approval)
       - View approved IPCs
       - READ ONLY on other documents
    
    2. CONSTRUCTION USER (Internal employee with full backend access):
       - View ALL contracts
       - Check/approve measurements
       - Generate IPCs
       - Create advances, retention releases
       - Full CRUD except final approvals
    
    3. CONSTRUCTION MANAGER (Manager):
       - Everything Construction User can do
       - Approve IPCs
       - Activate/close contracts
       - Full control
    
    ============================================================================
    -->

    <!-- ========================================= -->
    <!-- PORTAL USERS - All employees using portal -->
    <!-- ========================================= -->
    
    <!-- Portal: View Allowed Contracts -->
    <record id="construction_contract_portal_rule" model="ir.rule">
        <field name="name">Portal Employee: Allowed Contracts</field>
        <field name="model_id" ref="model_construction_contract"/>
        <field name="domain_force">['|', ('portal_visibility_restricted', '=', False), ('portal_employee_ids', 'in', [user.employee_id.id])]</field>
        <field name="groups" eval="[(4, ref('group_construction_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Portal: View Allowed BOQ Lines -->
    <record id="construction_boq_portal_rule" model="ir.rule">
        <field name="name">Portal Employee: Allowed BOQ Lines</field>
        <field name="model_id" ref="model_construction_contract_boq_line"/>
        <field name="domain_force">['|', ('contract_id.portal_visibility_restricted', '=', False), ('contract_id.portal_employee_ids', 'in', [user.employee_id.id])]</field>
        <field name="groups" eval="[(4, ref('group_construction_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Portal: CREATE & View Measurements -->
    <record id="construction_measurement_portal_rule" model="ir.rule">
        <field name="name">Portal Employee: Create/View Measurements</field>
        <field name="model_id" ref="model_construction_measurement"/>
        <field name="domain_force">['|', ('contract_id.portal_visibility_restricted', '=', False), ('contract_id.portal_employee_ids', 'in', [user.employee_id.id])]</field>
        <field name="groups" eval="[(4, ref('group_construction_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Portal: CREATE & View Measurement Lines -->
    <record id="construction_measurement_line_portal_rule" model="ir.rule">
        <field name="name">Portal Employee: Create/View Measurement Lines</field>
        <field name="model_id" ref="model_construction_measurement_line"/>
        <field name="domain_force">['|', ('measurement_id.contract_id.portal_visibility_restricted', '=', False), ('measurement_id.contract_id.portal_employee_ids', 'in', [user.employee_id.id])]</field>
        <field name="groups" eval="[(4, ref('group_construction_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Portal: CREATE & View Variations -->
    <record id="construction_variation_portal_rule" model="ir.rule">
        <field name="name">Portal Employee: Create/View Variation Requests</field>
        <field name="model_id" ref="model_construction_variation"/>
        <field name="domain_force">['|', ('contract_id.portal_visibility_restricted', '=', False), ('contract_id.portal_employee_ids', 'in', [user.employee_id.id])]</field>

        <field name="name">Portal Employee: View Advances</field>
        <field name="model_id" ref="model_construction_advance"/>
        <field name="domain_force">['|', ('contract_id.portal_visibility_restricted', '=', False), ('contract_id.portal_employee_ids', 'in', [user.employee_id.id])]</field>

<odoo>
    <!-- Portal users can only see contracts where they are the partner -->
    <record id="construction_contract_portal_rule" model="ir.rule">
        <field name="name">Portal User: Own Contracts Only</field>
        <field name="model_id" ref="model_construction_contract"/>
        <field name="domain_force">[('partner_id', 'child_of', [user.partner_id.commercial_partner_id.id])]</field>
        <field name="groups" eval="[(4, ref('construction_contract_management.group_construction_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>


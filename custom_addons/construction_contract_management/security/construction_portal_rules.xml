        <field name="name">Portal Employee: Create/View Variation Lines</field>
        <field name="model_id" ref="model_construction_variation_line"/>
        <field name="domain_force">['|', ('variation_id.contract_id.portal_visibility_restricted', '=', False), ('variation_id.contract_id.portal_employee_ids', 'in', [user.employee_id.id])]</field>
        <field name="groups" eval="[(4, ref('group_construction_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Portal: View Approved IPCs Only -->
    <record id="construction_ipc_portal_rule" model="ir.rule">
        <field name="name">Portal Employee: View Approved IPCs</field>
        <field name="model_id" ref="model_construction_ipc"/>
        <field name="domain_force">['&amp;', ('state', 'in', ['approved', 'done']), '|', ('contract_id.portal_visibility_restricted', '=', False), ('contract_id.portal_employee_ids', 'in', [user.employee_id.id])]</field>
        <field name="groups" eval="[(4, ref('group_construction_portal'))]"/>
        <field name="perm_read" eval="True"/>

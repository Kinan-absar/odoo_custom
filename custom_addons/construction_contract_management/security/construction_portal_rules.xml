        <field name="model_id" ref="model_construction_ipc_line"/>
        <field name="domain_force">['&amp;', ('ipc_id.state', 'in', ['approved', 'done']), '|', ('ipc_id.contract_id.portal_visibility_restricted', '=', False), ('ipc_id.contract_id.portal_employee_ids', 'in', [user.employee_id.id])]</field>
        <field name="groups" eval="[(4, ref('group_construction_portal'))]"/>
        <field name="perm_read" eval="True"/>

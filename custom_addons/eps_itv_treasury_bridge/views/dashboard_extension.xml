<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="employee_portal_dashboard_treasury"
              inherit_id="employee_portal_suite.employee_portal_dashboard">
        <xpath expr="//div[hasclass('row')]" position="inside">
            <t t-if="request.env.user.has_group('employee_portal_suite.group_employee_portal_ceo')">
                <t t-set="treasury_pending_count" t-value="request.env['cash.plan.line'].sudo().search_count([('company_id','in',request.env.user.company_ids.ids),('flow_type','=','out'),('ceo_decision','=','pending')])"/>
                <t t-set="treasury_held_count" t-value="request.env['cash.plan.line'].sudo().search_count([('company_id','in',request.env.user.company_ids.ids),('flow_type','=','out'),('ceo_decision','=','held')])"/>
                <t t-set="weekly_plan_count" t-value="request.env['cash.plan.run'].sudo().search_count([('company_id','in',request.env.user.company_ids.ids)])"/>
                <div class="col-6 col-md-6">
                    <a href="/my/employee/treasury/payments" class="dashboard-link">
                        <div class="dashboard-card">
                            <div class="card-top"><div class="card-icon bg-warning-soft"><i class="fa fa-check-square-o"></i></div><span class="card-title">Payment Approvals</span></div>
                            <div class="card-bottom"><div class="card-bottom-number-row"><span class="card-number"><t t-esc="treasury_pending_count"/></span><t t-if="treasury_pending_count &gt; 0"><span class="badge-pulse"></span></t></div><span class="small text-muted">Outgoing payments awaiting CEO review; held payments remain in the On Hold tab</span></div>
                        </div>
                    </a>
                </div>
                <div class="col-6 col-md-6">
                    <a href="/my/employee/treasury/plans" class="dashboard-link">
                        <div class="dashboard-card">
                            <div class="card-top"><div class="card-icon bg-info-soft"><i class="fa fa-line-chart"></i></div><span class="card-title">Weekly Cash Plans</span></div>
                            <div class="card-bottom"><div class="card-bottom-number-row"><span class="card-number"><t t-esc="weekly_plan_count"/></span></div><span class="small text-muted">Full weekly cash forecast and actuals</span></div>
                        </div>
                    </a>
                </div>
            </t>
        </xpath>
    </template>
</odoo>
